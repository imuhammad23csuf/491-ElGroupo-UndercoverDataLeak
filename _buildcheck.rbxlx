        </Item>
        <Item class="LocalScript" referent="71">
          <Properties>
            <string name="Name">HidingCloset</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")

local prompt = script.Parent
if not prompt:IsA("ProximityPrompt") then
	return
end

local closet = prompt:FindFirstAncestorWhichIsA("Model")
local door = closet and closet:FindFirstChild("Door")
local frame = closet and closet:FindFirstChild("Frame")
local base = frame and frame:FindFirstChild("Base")
local hidingPosition = base and base:FindFirstChild("HidingPosition")
local exitPosition = base and base:FindFirstChild("ExitPosition")
local hidingUiTemplate = closet and closet:FindFirstChild("HidingUI")
local somebodyHiding = closet and closet:FindFirstChild("somebodyHiding")
local userInside = closet and closet:FindFirstChild("userInside")

if not (door and hidingPosition and exitPosition and hidingUiTemplate and somebodyHiding and userInside) then
	warn("[HidingCloset] Missing required closet children for", closet and closet:GetFullName() or prompt:GetFullName())
	return
end

local INTERACTS = {
	HIDE = "Hide",
	EXIT = "Exit",
}

local busy = false

local function playDoorSound(name)
	local sound = door:FindFirstChild(name)
	if sound and sound:IsA("Sound") then
		sound:Play()
	end
end

local function rotateDoor(direction)
	for _ = 1, 20 do
		door:PivotTo(door:GetPivot() * CFrame.fromEulerAngles(0, direction * 0.1, 0))
		task.wait(0.01)
	end
end

local function getWorldPosition(instance)
	if instance:IsA("Attachment") then
		return instance.WorldPosition
	end
	if instance:IsA("BasePart") then
		return instance.Position
	end
	return nil
end

local function fadeHidingUi(player, targetTransparency)
	local playerGui = player:FindFirstChild("PlayerGui")
	local ui = playerGui and playerGui:FindFirstChild("HidingUI")
	local image = ui and ui:FindFirstChild("ImageLabel")
	if not image or not image:IsA("ImageLabel") then
		return
	end

	local step = image.ImageTransparency < targetTransparency and 0.1 or -0.1
	while math.abs(image.ImageTransparency - targetTransparency) > 0.05 do
		image.ImageTransparency = math.clamp(image.ImageTransparency + step, 0, 1)
		task.wait(0.025)
	end
	image.ImageTransparency = targetTransparency

	if targetTransparency >= 1 and ui then
		ui:Destroy()
	end
end

prompt.Triggered:Connect(function(triggeringPlayer)
	if busy then
		return
	end

	local player = triggeringPlayer or Players.LocalPlayer
	if not player or not player:IsA("Player") then
		return
	end

	if userInside.Value ~= "" and userInside.Value ~= player.Name then
		return
	end

	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local hidePosition = getWorldPosition(hidingPosition)
	local leavePosition = getWorldPosition(exitPosition)
	if not character or not root or not hidePosition or not leavePosition then
		return
	end

	busy = true
	prompt.Enabled = false

	playDoorSound("DoorOpen")
	rotateDoor(-1)

	if prompt.ActionText == INTERACTS.HIDE then
		root.Anchored = true
		character:MoveTo(hidePosition)

		local playerGui = player:FindFirstChild("PlayerGui")
		if playerGui and not playerGui:FindFirstChild("HidingUI") then
			hidingUiTemplate:Clone().Parent = playerGui
		end

		somebodyHiding.Value = true
		userInside.Value = player.Name
	elseif prompt.ActionText == INTERACTS.EXIT then
		root.Anchored = false
		character:MoveTo(leavePosition)
		somebodyHiding.Value = false
		userInside.Value = ""
	end

	rotateDoor(1)
	playDoorSound("DoorClose")

	if prompt.ActionText == INTERACTS.HIDE then
		fadeHidingUi(player, 0.5)
		prompt.ActionText = INTERACTS.EXIT
	else
		fadeHidingUi(player, 1)
		prompt.ActionText = INTERACTS.HIDE
	end

	prompt.Enabled = true
	busy = false
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="72">
          <Properties>
            <string name="Name">MalwareEffects</string>
            <string name="Source"><![CDATA[local Players = game:GetService('Players')
local Workspace = game:GetService('Workspace')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local SoundService = game:GetService('SoundService')

local Player = Players.LocalPlayer

local OVERLAY_PREFIX = 'WannaWailSurface'
local SCREEN_FACE = Enum.NormalId.Front
local SPREAD_INTERVAL = 15
local CONTAINMENT_CLEAR_INTERVAL = 10
local INFECTION_SOUND_ID = 'rbxassetid://6655708496'
local INFECTION_SOUND_NAME = 'WannaWailHit'

local ATTR_ACTIVE = 'WannaWailActive'
local ATTR_COUNT = 'WannaWailInfectedCount'
local ATTR_LAST_MACHINE = 'WannaWailLastMachine'
local ATTR_SOURCE_BLOCKED = 'WannaWailSourceBlocked'
local ATTR_FIREWALL_BLOCKED = 'WannaWailFirewallRuleAdded'
local ATTR_PROCESS_KILLED = 'WannaWailProcessKilled'
local ATTR_LOADER_REMOVED = 'WannaWailLoaderRemoved'
local ATTR_CONTAINED = 'WannaWailContained'

local outbreakToken = 0
local outbreakRunning = false
local lastChapterNumber = 0
local infectedEntries = {}
local containmentClearToken = 0
local containmentCleanupRunning = false

local remotes = ReplicatedStorage:WaitForChild('Remotes')
local getSessionInfoRemote = remotes:WaitForChild('GetSessionInfo')

local function make(className, props)
    local instance = Instance.new(className)
    for key, value in pairs(props or {}) do
        instance[key] = value
    end
    return instance
end

local function setAttr(name, value)
    if Player:GetAttribute(name) ~= value then
        Player:SetAttribute(name, value)
    end
end

local function playInfectionSound()
    local sound = SoundService:FindFirstChild(INFECTION_SOUND_NAME)
    if not (sound and sound:IsA('Sound')) then
        sound = make('Sound', {
            Name = INFECTION_SOUND_NAME,
            Parent = SoundService,
            SoundId = INFECTION_SOUND_ID,
            Volume = 0.75,
            RollOffMaxDistance = 0,
        })
    end

    sound:Stop()
    pcall(function()
        sound.TimePosition = 0
    end)
    sound:Play()
end

local function getCurrentChapter()
    return tonumber(Player:GetAttribute('CurrentChapter')) or 0
end

local function isIncidentChapter()
    local chapter = getCurrentChapter()
    return chapter == 3 or chapter == 4
end

local function getScenarioSessionInfo()
    local ok, info = pcall(function()
        return getSessionInfoRemote:InvokeServer()
    end)
    if ok and type(info) == 'table' then
        return info
    end
    return nil
end

local function canStartOutbreak()
    local currentChapter = getCurrentChapter()
    if currentChapter == 4 then
        return true
    end
    if currentChapter ~= 3 then
        return false
    end

    local sessionInfo = getScenarioSessionInfo()
    if not sessionInfo or sessionInfo.scenarioId ~= 'Chapter3_Malware' then
        return false
    end

    local stepId = tostring(sessionInfo.stepId or '')
    if stepId == '' then
        return false
    end

    return stepId ~= 'ch3_mail_site' and stepId ~= 'ch3_inbox_triage'
end

local function refreshContainedFlag()
    local contained = Player:GetAttribute(ATTR_SOURCE_BLOCKED) == true
        and Player:GetAttribute(ATTR_FIREWALL_BLOCKED) == true
        and Player:GetAttribute(ATTR_PROCESS_KILLED) == true
        and Player:GetAttribute(ATTR_LOADER_REMOVED) == true
    setAttr(ATTR_CONTAINED, contained)
    return contained
end

local function resetTelemetry()
    setAttr(ATTR_ACTIVE, false)
    setAttr(ATTR_COUNT, 0)
    setAttr(ATTR_LAST_MACHINE, '')
    setAttr(ATTR_SOURCE_BLOCKED, false)
    setAttr(ATTR_FIREWALL_BLOCKED, false)
    setAttr(ATTR_PROCESS_KILLED, false)
    setAttr(ATTR_LOADER_REMOVED, false)
    setAttr(ATTR_CONTAINED, false)
end

local function isPcSetupModel(model)
    local lowerName = model.Name:lower()
    return lowerName == 'pc setup' or lowerName:find('pc setup', 1, true) ~= nil
end

local function isLikelyScreenName(name)
    local lowerName = tostring(name or ''):lower()
    return lowerName == 'screen'
        or lowerName == 'monitor'
        or lowerName == 'display'
        or lowerName:find('screen', 1, true) ~= nil
        or lowerName:find('monitor', 1, true) ~= nil
        or lowerName:find('display', 1, true) ~= nil
end

local function makeHostLabel(model, index)
    local base = 'Office Terminal'
    local parent = model.Parent
    if parent and parent ~= Workspace and parent.Name ~= 'Workspace' and parent.Name ~= 'PC Setup' then
        base = parent.Name
    end
    return string.format('%s %02d', base, index)
end

local function findScreenPart(model)
    local exact = model:FindFirstChild('Screen', true)
    if exact and exact:IsA('BasePart') then
        return exact
    end

    for _, descendant in ipairs(model:GetDescendants()) do
        if descendant:IsA('BasePart') and isLikelyScreenName(descendant.Name) then
            return descendant
        end
    end

    return nil
end

local function collectEntries()
    local entries = {}
    local seenParts = {}

    for _, instance in ipairs(Workspace:GetDescendants()) do
        if instance:IsA('Model') and isPcSetupModel(instance) then
            local screen = findScreenPart(instance)
            if screen and not seenParts[screen] then
                seenParts[screen] = true
                entries[#entries + 1] = {
                    model = instance,
                    part = screen,
                    infected = false,
                }
            end
        end
    end

    if #entries == 0 then
        for _, instance in ipairs(Workspace:GetDescendants()) do
            if instance:IsA('BasePart') and isLikelyScreenName(instance.Name) and not seenParts[instance] then
                local model = instance:FindFirstAncestorOfClass('Model')
                if model then
                    seenParts[instance] = true
                    entries[#entries + 1] = {
                        model = model,
                        part = instance,
                        infected = false,
                    }
                end
            end
        end
    end

    table.sort(entries, function(a, b)
        return a.part:GetFullName() < b.part:GetFullName()
    end)

    for index, entry in ipairs(entries) do
        entry.label = makeHostLabel(entry.model, index)
    end

    return entries
end

local function overlayName()
    return OVERLAY_PREFIX
end

local function clearOverlays()
    for _, instance in ipairs(Workspace:GetDescendants()) do
        if instance:IsA('SurfaceGui') then
            local name = instance.Name
            if name == OVERLAY_PREFIX or name:sub(1, #OVERLAY_PREFIX) == OVERLAY_PREFIX then
                instance:Destroy()
            end
        end
    end
    infectedEntries = {}
    outbreakRunning = false
    containmentClearToken = containmentClearToken + 1
    containmentCleanupRunning = false
end

local function buildPopup(parent, name, position, size, titleText, bodyText)
    local frame = make('Frame', {
        Parent = parent,
        Name = name,
        BackgroundColor3 = Color3.fromRGB(45, 6, 6),
        BorderColor3 = Color3.fromRGB(255, 80, 80),
        BorderSizePixel = 2,
        Position = position,
        Size = size,
    })

    make('TextLabel', {
        Parent = frame,
        BackgroundColor3 = Color3.fromRGB(170, 28, 28),
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        Text = titleText,
        TextColor3 = Color3.new(1, 1, 1),
        TextSize = 18,
        Size = UDim2.new(1, 0, 0, 28),
    })

    make('TextLabel', {
        Parent = frame,
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = bodyText,
        TextColor3 = Color3.fromRGB(255, 220, 220),
        TextSize = 16,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        Position = UDim2.new(0, 10, 0, 36),
        Size = UDim2.new(1, -20, 1, -46),
    })
end

local function ensureOverlay(entry)
    local gui = entry.part:FindFirstChild(overlayName())
    if gui and gui:IsA('SurfaceGui') then
        return gui
    end

    for _, child in ipairs(entry.part:GetChildren()) do
        if child:IsA('SurfaceGui') and child.Name:sub(1, #OVERLAY_PREFIX) == OVERLAY_PREFIX then
            child:Destroy()
        end
    end

    gui = make('SurfaceGui', {
        Name = overlayName(),
        Parent = entry.part,
        Face = SCREEN_FACE,
        AlwaysOnTop = true,
        LightInfluence = 0,
        SizingMode = Enum.SurfaceGuiSizingMode.PixelsPerStud,
        PixelsPerStud = 40,
        CanvasSize = Vector2.new(1024, 576),
        ZOffset = 1,
    })

    local background = make('Frame', {
        Parent = gui,
        Name = 'Background',
        BackgroundColor3 = Color3.fromRGB(18, 0, 0),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
    })

    make('TextLabel', {
        Parent = background,
        Name = 'Title',
        BackgroundColor3 = Color3.fromRGB(198, 29, 29),
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBlack,
        Text = 'WANNAWAIL',
        TextColor3 = Color3.new(1, 1, 1),
        TextSize = 15,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 0, 70),
    })

    make('TextLabel', {
        Parent = background,
        Name = 'Message',
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = 'FILES ENCRYPTED',
        TextColor3 = Color3.fromRGB(255, 235, 235),
        TextSize = 15,
        Position = UDim2.new(0, 40, 0, 98),
        Size = UDim2.new(1, -80, 0, 40),
    })

    make('TextLabel', {
        Parent = background,
        Name = 'Subtext',
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = 'TRANSFER 50 ROBUX TO UNLOCK FILES',
        TextColor3 = Color3.fromRGB(255, 198, 198),
        TextSize = 22,
        Position = UDim2.new(0, 40, 0, 146),
        Size = UDim2.new(1, -80, 0, 30),
    })

    make('TextLabel', {
        Parent = background,
        Name = 'HostLabel',
        BackgroundTransparency = 1,
        Font = Enum.Font.Code,
        Text = entry.label,
        TextColor3 = Color3.fromRGB(255, 112, 112),
        TextSize = 20,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, 40, 0, 182),
        Size = UDim2.new(1, -80, 0, 24),
    })

    buildPopup(background, 'PopupA', UDim2.new(0, 48, 0, 246), UDim2.new(0, 282, 0, 134), 'PAY NOW', 'Transfer 50 Robux to decrypt local office files.')
    buildPopup(background, 'PopupB', UDim2.new(0, 380, 0, 222), UDim2.new(0, 300, 0, 146), 'SPREADING', 'Additional systems are being encrypted while the attacker remains connected.')
    buildPopup(background, 'PopupC', UDim2.new(0, 704, 0, 254), UDim2.new(0, 260, 0, 122), 'STATUS', 'Encryption banner active. User access unavailable.')

    return gui
end

local function updateOverlay(entry)
    local contained = refreshContainedFlag()
    local gui = ensureOverlay(entry)
    local background = gui:FindFirstChild('Background')
    if not (background and background:IsA('Frame')) then
        return
    end

    local title = background:FindFirstChild('Title')
    local message = background:FindFirstChild('Message')
    local subtext = background:FindFirstChild('Subtext')
    local hostLabel = background:FindFirstChild('HostLabel')

    if contained then
        background.BackgroundColor3 = Color3.fromRGB(6, 26, 12)
        if title and title:IsA('TextLabel') then
            title.BackgroundColor3 = Color3.fromRGB(32, 128, 72)
            title.Text = 'SOURCE BLOCKED'
        end
        if message and message:IsA('TextLabel') then
            message.Text = 'INCIDENT CONTAINED'
            message.TextColor3 = Color3.fromRGB(228, 255, 235)
        end
        if subtext and subtext:IsA('TextLabel') then
            subtext.Text = 'Response controls are in place. Further spread has stopped.'
            subtext.TextColor3 = Color3.fromRGB(198, 240, 208)
        end
        if hostLabel and hostLabel:IsA('TextLabel') then
            hostLabel.Text = entry.label .. '  |  QUARANTINED'
            hostLabel.TextColor3 = Color3.fromRGB(134, 220, 156)
        end
    else
        background.BackgroundColor3 = Color3.fromRGB(18, 0, 0)
        if title and title:IsA('TextLabel') then
            title.BackgroundColor3 = Color3.fromRGB(198, 29, 29)
            title.Text = 'WANNAWAIL'
        end
        if message and message:IsA('TextLabel') then
            message.Text = 'FILES ENCRYPTED'
            message.TextColor3 = Color3.fromRGB(255, 235, 235)
        end
        if subtext and subtext:IsA('TextLabel') then
            subtext.Text = 'TRANSFER 50 ROBUX TO UNLOCK FILES'
            subtext.TextColor3 = Color3.fromRGB(255, 198, 198)
        end
        if hostLabel and hostLabel:IsA('TextLabel') then
            hostLabel.Text = entry.label
            hostLabel.TextColor3 = Color3.fromRGB(255, 112, 112)
        end
    end
end

local function refreshTelemetry(lastEntry)
    setAttr(ATTR_ACTIVE, outbreakRunning or #infectedEntries > 0)
    setAttr(ATTR_COUNT, #infectedEntries)
    if lastEntry then
        setAttr(ATTR_LAST_MACHINE, lastEntry.label)
    elseif #infectedEntries == 0 then
        setAttr(ATTR_LAST_MACHINE, '')
    end
    refreshContainedFlag()
end

local function removeOverlay(entry)
    for _, child in ipairs(entry.part:GetChildren()) do
        if child:IsA('SurfaceGui') and child.Name:sub(1, #OVERLAY_PREFIX) == OVERLAY_PREFIX then
            child:Destroy()
        end
    end
end

local function removeInfectedEntry(entry)
    if not entry.infected then
        return
    end

    entry.infected = false
    removeOverlay(entry)

    for index, infected in ipairs(infectedEntries) do
        if infected == entry then
            table.remove(infectedEntries, index)
            break
        end
    end

    if #infectedEntries == 0 then
        outbreakRunning = false
    end

    refreshTelemetry(nil)
end

local function infectEntry(entry)
    if entry.infected then
        return
    end
    entry.infected = true
    infectedEntries[#infectedEntries + 1] = entry
    playInfectionSound()
    updateOverlay(entry)
    refreshTelemetry(entry)
end

local function chooseSpreadOrder(entries)
    local chooser = Random.new(Player.UserId + os.time())
    local startIndex = chooser:NextInteger(1, #entries)
    local source = entries[startIndex]

    table.sort(entries, function(a, b)
        local distA = (a.part.Position - source.part.Position).Magnitude
        local distB = (b.part.Position - source.part.Position).Magnitude
        if distA == distB then
            return a.label < b.label
        end
        return distA < distB
    end)

    return entries
end

local function shouldPauseSpread()
    if refreshContainedFlag() then
        return true
    end

    return Player:GetAttribute(ATTR_SOURCE_BLOCKED) == true
        or Player:GetAttribute(ATTR_FIREWALL_BLOCKED) == true
        or Player:GetAttribute(ATTR_PROCESS_KILLED) == true
end

local function startContainmentCleanup()
    if containmentCleanupRunning then
        return
    end

    containmentCleanupRunning = true
    containmentClearToken = containmentClearToken + 1
    local token = containmentClearToken

    task.spawn(function()
        while token == containmentClearToken and isIncidentChapter() do
            if not refreshContainedFlag() then
                containmentCleanupRunning = false
                return
            end

            if #infectedEntries == 0 then
                outbreakRunning = false
                refreshTelemetry(nil)
                containmentCleanupRunning = false
                return
            end

            task.wait(CONTAINMENT_CLEAR_INTERVAL)

            if token ~= containmentClearToken or not isIncidentChapter() or not refreshContainedFlag() then
                containmentCleanupRunning = false
                return
            end

            local nextEntry = infectedEntries[1]
            if nextEntry then
                removeInfectedEntry(nextEntry)
            end
        end

        containmentCleanupRunning = false
    end)
end

local function beginOutbreak()
    local entries = collectEntries()
    if #entries == 0 then
        return false
    end

    outbreakToken = outbreakToken + 1
    outbreakRunning = true
    containmentClearToken = containmentClearToken + 1
    containmentCleanupRunning = false
    infectedEntries = {}
    entries = chooseSpreadOrder(entries)
    refreshTelemetry(nil)
    infectEntry(entries[1])

    local token = outbreakToken
    task.spawn(function()
        for index = 2, #entries do
            local waited = 0
            while waited < SPREAD_INTERVAL do
                if token ~= outbreakToken or not isIncidentChapter() then
                    return
                end
                if shouldPauseSpread() then
                    for _, infected in ipairs(infectedEntries) do
                        updateOverlay(infected)
                    end
                    return
                end
                task.wait(1)
                waited = waited + 1
            end

            if token ~= outbreakToken or not isIncidentChapter() or shouldPauseSpread() then
                return
            end

            infectEntry(entries[index])
        end
    end)

    return true
end

local function shutdownOutbreak(resetState)
    outbreakToken = outbreakToken + 1
    clearOverlays()
    if resetState then
        resetTelemetry()
    else
        refreshTelemetry(nil)
    end
end

for _, attr in ipairs({
    ATTR_SOURCE_BLOCKED,
    ATTR_FIREWALL_BLOCKED,
    ATTR_PROCESS_KILLED,
    ATTR_LOADER_REMOVED,
    ATTR_CONTAINED,
}) do
    Player:GetAttributeChangedSignal(attr):Connect(function()
        for _, entry in ipairs(infectedEntries) do
            updateOverlay(entry)
        end
        refreshTelemetry(nil)
        if refreshContainedFlag() then
            startContainmentCleanup()
        end
    end)
end

task.spawn(function()
    while true do
        local currentChapter = getCurrentChapter()
        local incidentChapter = currentChapter == 3 or currentChapter == 4
        local chapterChanged = currentChapter ~= lastChapterNumber

        if chapterChanged then
            if currentChapter == 3 then
                shutdownOutbreak(true)
            elseif currentChapter == 4 and lastChapterNumber ~= 3 and lastChapterNumber ~= 4 then
                shutdownOutbreak(true)
            elseif (lastChapterNumber == 3 or lastChapterNumber == 4) and not incidentChapter then
                shutdownOutbreak(true)
            end
        end

        if incidentChapter then
            if not outbreakRunning and canStartOutbreak() and not refreshContainedFlag() then
                beginOutbreak()
            else
                for _, entry in ipairs(infectedEntries) do
                    updateOverlay(entry)
                end
                refreshTelemetry(nil)
                if refreshContainedFlag() then
                    startContainmentCleanup()
                end
            end
        end

        lastChapterNumber = currentChapter
        task.wait(1)
    end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="73">
          <Properties>
            <string name="Name">MissionReviewUI</string>
            <string name="Source">local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local reviewEvent = ReplicatedStorage:WaitForChild("ShowMissionReview")

local feedbackDatabase = {
    ["ReportedPhish"] = { good = true, title = "PHISHING ESCAPED", practice = "BEST PRACTICE: You verified the sender domain." },
    ["ClickedPhish"] = { good = false, title = "SECURITY BREACH", practice = "VULNERABILITY: You clicked a malicious link." },
    
    -- Our new traps:
    ["FoundStickyNotePassword"] = { good = false, title = "PHYSICAL BREACH", practice = "VULNERABILITY: You found admin credentials left in the open. Never write passwords on sticky notes." },
    ["CaughtByCamera"] = { good = false, title = "SPOTTED", practice = "VULNERABILITY: You failed to evade the security cameras." },
	["ClonedKeycard"] = { good = true, title = "RFID CLONED", practice = "VULNERABILITY: You demonstrated how easily unsecured physical badges can be copied via proximity." },
}

-- === UI GENERATION ===
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "MissionReviewGui"
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.Enabled = false
screenGui.ResetOnSpawn = false 
screenGui.DisplayOrder = 100 

local background = Instance.new("Frame")
background.Size = UDim2.new(1, 0, 1, 0)
background.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
background.BackgroundTransparency = 0.05
background.Parent = screenGui

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 100)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "MISSION ETHICS REVIEW"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.TextSize = 40
titleLabel.Font = Enum.Font.Code
titleLabel.Parent = background

local scrollingFrame = Instance.new("ScrollingFrame")
scrollingFrame.Size = UDim2.new(0.6, 0, 0.6, 0)
scrollingFrame.Position = UDim2.new(0.2, 0, 0.15, 0)
scrollingFrame.BackgroundTransparency = 1
scrollingFrame.ScrollBarThickness = 8
scrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0) -- Resets default canvas
scrollingFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y -- Magic trick: Auto-scales the scrollbar!
scrollingFrame.Parent = background

-- THE FIX: Properly parenting the UIListLayout
local listLayout = Instance.new("UIListLayout")
listLayout.Padding = UDim.new(0, 15)
listLayout.Parent = scrollingFrame

local closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0.2, 0, 0, 50)
closeButton.Position = UDim2.new(0.4, 0, 0.85, 0)
closeButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
closeButton.Text = "ACKNOWLEDGE"
closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
closeButton.Font = Enum.Font.Code
closeButton.TextSize = 20
closeButton.Parent = background

closeButton.MouseButton1Click:Connect(function()
	screenGui.Enabled = false
end)

-- === TRIGGER LOGIC ===
reviewEvent.OnClientEvent:Connect(function(decisionLog)
	print("[UI SCRIPT] Received the final stats! Generating UI...")
	
	-- Wake up the UI
	screenGui.Enabled = true
	
	-- Clear old data
	for _, child in ipairs(scrollingFrame:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end
	
	-- Build new data
	for key, value in pairs(decisionLog) do
		if feedbackDatabase[key] and value == true then
			local entry = feedbackDatabase[key]
			
			local itemFrame = Instance.new("Frame")
			itemFrame.Size = UDim2.new(1, 0, 0, 80)
			itemFrame.BackgroundColor3 = entry.good and Color3.fromRGB(20, 50, 20) or Color3.fromRGB(50, 20, 20)
			itemFrame.Parent = scrollingFrame
			
			local textLabel = Instance.new("TextLabel")
			textLabel.Size = UDim2.new(0.9, 0, 1, 0)
			textLabel.Position = UDim2.new(0.05, 0, 0, 0)
			textLabel.BackgroundTransparency = 1
			textLabel.Text = entry.title .. "\n" .. entry.practice
			textLabel.TextColor3 = entry.good and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
			textLabel.TextWrapped = true
			textLabel.TextXAlignment = Enum.TextXAlignment.Left
			textLabel.Font = Enum.Font.Code
			textLabel.Parent = itemFrame
		end
	end
end)</string>
          </Properties>
