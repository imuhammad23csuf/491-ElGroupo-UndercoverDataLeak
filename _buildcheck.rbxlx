layout = mk("UIListLayout", {
Parent = logsFrame,
Name = "UIListLayout",
Padding = UDim.new(0, 6),
SortOrder = Enum.SortOrder.LayoutOrder,
})
end
local logs = {}
for _, entry in ipairs(AdminLogFeed.base) do
logs[#logs + 1] = entry
end
for _, entry in ipairs(getWannaWailIncidentLogs()) do
logs[#logs + 1] = entry
end
