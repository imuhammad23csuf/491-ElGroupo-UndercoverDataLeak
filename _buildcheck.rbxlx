WANNAWAIL_ATTACKER_IP = WANNAWAIL_ATTACKER_IP,
historyUp = historyUp,
historyDown = historyDown,
onTerminalTextChanged = function(text)
if historyIndex == nil then
currentDraft = text
end
end,
})
