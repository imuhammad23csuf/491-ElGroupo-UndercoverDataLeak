      <Item class="Script" referent="54">
        <Properties>
          <string name="Name">NewsCutsceneServer</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- ServerScriptService/NewsCutsceneServer

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Ensure RemoteEvent exists
local StartEvent = ReplicatedStorage:FindFirstChild("StartNewsCutscene")
if not StartEvent then
	StartEvent = Instance.new("RemoteEvent")
	StartEvent.Name = "StartNewsCutscene"
	StartEvent.Parent = ReplicatedStorage
end

local CompleteEvent = ReplicatedStorage:FindFirstChild("NewsCutsceneFinished")
if not CompleteEvent then
	CompleteEvent = Instance.new("RemoteEvent")
	CompleteEvent.Name = "NewsCutsceneFinished"
	CompleteEvent.Parent = ReplicatedStorage
end

-- Headlines (~60 seconds)
local HEADLINES = {
	{ text = "Good evening. We're coming to you with disturbing reports about the popular gaming platform Bloxplay.", duration = 4 },
	{ text = "Investigations reveal that Bloxplay has been sharing children's personal data with unauthorized third parties.", duration = 5 },
	{ text = "Security experts confirm that sensitive information including ages, locations, and gaming habits were compromised.", duration = 5 },
	{ text = "Parents express outrage as bad actors may have gained access to their children's private information.", duration = 4 },
	{ text = "Bloxplay officials have yet to comment on these serious allegations.", duration = 3 },
	{ text = "We'll continue to follow this developing story and bring you updates as they become available.", duration = 4 },
}

local NEWS_MUSIC_ID = "rbxassetid://137057705955446"
local STARTED_ATTRIBUTE = "NewsCutsceneStarted"
local COMPLETED_ATTRIBUTE = "NewsCutsceneCompleted"

-- Helper to get position from part/model
local function getPos(inst)
	if not inst then return nil end
	if inst:IsA("BasePart") then
		return inst.Position
	elseif inst:IsA("Model") then
		if inst.PrimaryPart then
			return inst.PrimaryPart.Position
		end
		return inst:GetPivot().Position
	end
	return nil
end

-- Face NewsAgent toward camera
local function faceRigTowardCamera()
	local rig = workspace:FindFirstChild("NewsAgent")
	if not rig then return end

	local folder = rig:FindFirstChild("CameraPath")
	if not folder then return end

	local node = folder:FindFirstChild("CamFront") or folder:FindFirstChild("Cam1")
	if not node then return end

	local root = rig:FindFirstChild("HumanoidRootPart", true)
	if not root then
		root = rig.PrimaryPart or rig:FindFirstChildWhichIsA("BasePart", true)
	end
	if not root then return end

	local rootPos = root.Position
	local camPos = getPos(node)
	if not camPos then return end

	local target = Vector3.new(camPos.X, rootPos.Y, camPos.Z)
	root.CFrame = CFrame.new(rootPos, target)
end

-- 🔥 START CUTSCENE AUTOMATICALLY
local function startCutscene(player)
	if player:GetAttribute(STARTED_ATTRIBUTE) == true or player:GetAttribute(COMPLETED_ATTRIBUTE) == true then
		return
	end

	player:SetAttribute(STARTED_ATTRIBUTE, true)
	player:SetAttribute(COMPLETED_ATTRIBUTE, false)

	StartEvent:FireClient(player, {
		headlines         = HEADLINES,
		totalTime         = 60,
		musicId           = NEWS_MUSIC_ID,
		useRigName        = "NewsAgent",
		showBroadcastHUD  = true,
		showCenterCard    = false,
		clockStart        = "15:26",
	})
end

StartEvent.OnServerEvent:Connect(function(player)
	if not player or player.Parent ~= Players then
		return
	end

	task.defer(faceRigTowardCamera)
	startCutscene(player)
end)

CompleteEvent.OnServerEvent:Connect(function(player)
	if not player or player.Parent ~= Players then
		return
	end
	if player:GetAttribute(STARTED_ATTRIBUTE) ~= true then
		return
	end

	player:SetAttribute(COMPLETED_ATTRIBUTE, true)
end)

Players.PlayerAdded:Connect(function()
	task.defer(faceRigTowardCamera)
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="55">
        <Properties>
          <string name="Name">OutGuard</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- GuardOutside (Patrol + State Machine Chase/Search/Return + Batched Suspicion + Distract)
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local sharedRoot = ReplicatedStorage:WaitForChild("Shared")
local SuspicionManager = require(sharedRoot:WaitForChild("SuspicionManager"))

local GUARD = Workspace:WaitForChild("GuardOutside")
local RIG = GUARD:WaitForChild("Rig")
local HUMANOID = RIG:WaitForChild("Humanoid")
local HRP = RIG:WaitForChild("HumanoidRootPart")

local State = {
    PATROL = "PATROL",
    CHASE = "CHASE",
    SEARCH = "SEARCH",
    RETURN = "RETURN",
}

local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes") or Instance.new("Folder")
remotesFolder.Name = "Remotes"
remotesFolder.Parent = ReplicatedStorage

local DistractRemote = remotesFolder:FindFirstChild("DistractOutGuard")
if DistractRemote and not DistractRemote:IsA("RemoteFunction") then
    DistractRemote:Destroy()
    DistractRemote = nil
end
DistractRemote = DistractRemote or Instance.new("RemoteFunction")
DistractRemote.Name = "DistractOutGuard"
DistractRemote.Parent = remotesFolder

local GuardDialogueRemote = remotesFolder:FindFirstChild("GuardDialogue") or Instance.new("RemoteEvent")
GuardDialogueRemote.Name = "GuardDialogue"
GuardDialogueRemote.Parent = remotesFolder

-- === SETTINGS ===
local HEARTBEAT_INTERVAL = 0.5
local PATROL_SPEED = 8
local CHASE_SPEED = 13
local VISION_RANGE = 60
local VISION_ANGLE = math.cos(math.rad(60))
local CHASE_TIMEOUT = 4
local SEARCH_DURATION = 2.5
local SEARCH_ROTATION_STEP = math.rad(35)
local CAPTURE_DISTANCE = 4
local RETURN_REACHED_DISTANCE = 4
local MOVE_TIMEOUT = 8
local PATROL_PAUSE_DURATION = 0
local MOVE_TARGET_EPSILON = 2

-- Suspicion tuning (Outside)
local SUSPICION_PER_TICK = 0.9
local SUSPICION_TICK_RATE = 0.35

-- Distraction tuning
local DISTRACT_DURATION = 15
local DISTRACT_COOLDOWN = 20
local DISTRACT_MAX_RANGE = 160
local HACK_TABLET_NAME = "HackTablet"
local PHONE_ANIM_ID = "rbxassetid://85133448172500"

local DISTRACT_LINES = {
    "I don't get paid enough for this.",
    "You gotta be kidding me.",
    "My paycheck supports this apparently.",
    "Man, this job is exhausting.",
    "Seriously?",
    "This better be worth it.",
    "Bro...",
    "Wohoo! I'm getting a promotion... SERIOUSLY?!",
    "If this is another false alarm, I'm clocking out emotionally.",
    "Who keeps pressing the chaos button around here?",
    "My back hurts and my patience has left the building.",
    "I signed up for security, not cardio and confusion.",
    "At this point I'm guarding my last nerve.",
    "If annoyance paid overtime, I'd be rich.",
    "Somebody better be in danger because I just spilled my coffee.",
    "I swear this place is haunted by bad decisions.",
    "One more prank and I'm filing a strongly worded report.",
    "Do I look like a one-man emergency hotline?"
}

local CHASE_LINES = {
    "Hey! You! Stop!",
    "Running just makes my shift longer.",
    "I have eyes on you!",
    "Get back here!",
    "Security breach outside!",
}

local GIVE_UP_LINES = {
    "Lost them. Returning to patrol.",
    "Must have been the wind.",
    "Area clear, I guess.",
    "I am too tired for false alarms.",
    "Back to my route.",
}

local function addLineOfSightSuspicion(player, amount)
    if not player or not player.UserId then
        return
    end

    SuspicionManager.AddLineOfSight(amount or 0, player)
end

-- === ANIMATIONS ===
local WALK_ANIM_ID = "http://www.roblox.com/asset/?id=913402848"
local Animator = HUMANOID:FindFirstChildOfClass("Animator") or Instance.new("Animator")
Animator.Parent = HUMANOID

local WalkTrack do
    local anim = Instance.new("Animation")
    anim.AnimationId = WALK_ANIM_ID
    WalkTrack = Animator:LoadAnimation(anim)
    WalkTrack.Priority = Enum.AnimationPriority.Movement
end

local PhoneTrack do
    local anim = Instance.new("Animation")
    anim.AnimationId = PHONE_ANIM_ID
    PhoneTrack = Animator:LoadAnimation(anim)
    PhoneTrack.Priority = Enum.AnimationPriority.Action
    PhoneTrack.Looped = false
end

local function playWalk()
    if WalkTrack then
        if not WalkTrack.IsPlaying then
            WalkTrack:Play(0.1)
        end
        WalkTrack:AdjustSpeed(1)
    end
end

local function stopWalk()
    if WalkTrack and WalkTrack.IsPlaying then
        WalkTrack:Stop(0.1)
    end
end

-- === DISTRACTION STATE ===
local isDistracted = false
local distractionEndsAt = 0
local distractCooldownByUserId = {}

local currentPoint = 1
local currentState = State.PATROL
local stateStartTime = os.clock()
local patrolHoldUntil = 0
local activeTarget = nil
local lastSeenPos = nil
local lostSightSince = nil
local returnTargetIndex = nil
local nextSuspicionTick = 0
local moveGoal = nil
local moveStartedAt = 0
local moveSerial = 0

local function safeAlive(h)
    return h and h.Health > 0 and h.Parent
end

local function clearMoveGoal()
    moveGoal = nil
    moveStartedAt = 0
    moveSerial = moveSerial + 1
end

local function issueMoveTo(position)
    if not position then
        return
    end

    if not moveGoal or (moveGoal - position).Magnitude > MOVE_TARGET_EPSILON then
        moveSerial = moveSerial + 1
        HUMANOID:MoveTo(position)
        moveGoal = position
        moveStartedAt = os.clock()
    end
end

local function clearActiveTarget(flushPending)
    activeTarget = nil
    lostSightSince = nil
    nextSuspicionTick = 0
end

local function setState(nextState)
    currentState = nextState
    stateStartTime = os.clock()
    clearMoveGoal()
end

local function showSpeechBubble(text)
    GuardDialogueRemote:FireAllClients(RIG, text)
end

local function sayRandomLine(lines)
    if not lines or #lines == 0 then
        return
    end

    showSpeechBubble(lines[math.random(1, #lines)])
end

local function startPatrol(holdDuration)
    clearActiveTarget(true)
    lastSeenPos = nil
    returnTargetIndex = nil
    patrolHoldUntil = (holdDuration and holdDuration > 0) and (os.clock() + holdDuration) or 0
    HUMANOID.WalkSpeed = PATROL_SPEED
    setState(State.PATROL)
end

local function startChase(player, playerRoot)
    activeTarget = player
    lastSeenPos = playerRoot and playerRoot.Position or lastSeenPos
    lostSightSince = nil
    nextSuspicionTick = 0
    HUMANOID.WalkSpeed = CHASE_SPEED
    playWalk()
    setState(State.CHASE)
    sayRandomLine(CHASE_LINES)
end

local function startSearch()
    clearActiveTarget(true)
    HUMANOID.WalkSpeed = CHASE_SPEED
    setState(State.SEARCH)
end

local function startReturn()
    clearActiveTarget(true)
    returnTargetIndex = nil
    HUMANOID.WalkSpeed = PATROL_SPEED
    playWalk()
    setState(State.RETURN)
    sayRandomLine(GIVE_UP_LINES)
end

local function beginDistraction()
    if isDistracted then
        return
    end

    isDistracted = true
    distractionEndsAt = os.clock() + DISTRACT_DURATION
    startPatrol(0)
    lastSeenPos = nil

    HUMANOID.WalkSpeed = 0
    HUMANOID:Move(Vector3.zero, false)
    HUMANOID:MoveTo(HRP.Position)

    stopWalk()

    if PhoneTrack then
        if PhoneTrack.IsPlaying then
            PhoneTrack:Stop()
        end

        PhoneTrack:Play(0.1, 1, 1)

        task.spawn(function()
            local freezeAfter = 0.35
            if PhoneTrack.Length and PhoneTrack.Length > 0 then
                freezeAfter = math.min(PhoneTrack.Length * 0.45, 0.6)
            end

            task.wait(freezeAfter)

            if isDistracted and PhoneTrack.IsPlaying then
                PhoneTrack:AdjustSpeed(0)
            end
        end)
    end

    local bubbleText = DISTRACT_LINES[math.random(1, #DISTRACT_LINES)]
    showSpeechBubble(bubbleText)

    task.delay(DISTRACT_DURATION, function()
        if PhoneTrack and PhoneTrack.IsPlaying then
            PhoneTrack:Stop()
            PhoneTrack.TimePosition = 0
        end

        isDistracted = false
        distractionEndsAt = 0
        HUMANOID.WalkSpeed = PATROL_SPEED
    end)
end

local function canRequestDistraction(player)
    if not player or player.Parent ~= Players then
        return false, "Invalid player request."
    end

    local hasEquippedTablet = player:GetAttribute("HackTabletEquipped") == true
    if not hasEquippedTablet then
        local character = player.Character
        local equippedTool = character and character:FindFirstChildOfClass("Tool")
        hasEquippedTablet = equippedTool ~= nil and equippedTool.Name == HACK_TABLET_NAME
    end

    if not hasEquippedTablet then
        return false, "Equip the HackTablet before requesting a guard distraction."
    end

    if isDistracted then
        return false, "Guard is already distracted."
    end

    local character = player.Character
    local playerRoot = character and character:FindFirstChild("HumanoidRootPart")
    if not playerRoot or (playerRoot.Position - HRP.Position).Magnitude > DISTRACT_MAX_RANGE then
        return false, "Move closer to the outside guard before sending the distraction."
    end

    local now = os.clock()
    local lastRequestedAt = distractCooldownByUserId[player.UserId] or 0
    if now - lastRequestedAt < DISTRACT_COOLDOWN then
        local remaining = math.ceil(DISTRACT_COOLDOWN - (now - lastRequestedAt))
        return false, string.format("Guard distraction is cooling down (%ds remaining).", math.max(remaining, 1))
    end

    distractCooldownByUserId[player.UserId] = now
    return true, "Outside guard distracted for 15 seconds."
end

DistractRemote.OnServerInvoke = function(player)
    local ok, message = canRequestDistraction(player)
    if not ok then
        return {
            success = false,
            message = message,
        }
    end

    beginDistraction()

    return {
        success = true,
        message = message,
        duration = DISTRACT_DURATION,
    }
end

Players.PlayerRemoving:Connect(function(player)
    distractCooldownByUserId[player.UserId] = nil
end)

-- === PATROL POINTS ===
local PatrolFolder = RIG:FindFirstChild("PatrolPoints") or GUARD:FindFirstChild("PatrolPoints")
local Waypoints = {}
if PatrolFolder then
    for _, part in ipairs(PatrolFolder:GetChildren()) do
        if part:IsA("BasePart") then
            table.insert(Waypoints, part)
        end
    end

    table.sort(Waypoints, function(a, b)
        local na = tonumber(a.Name:match("%d+")) or math.huge
        local nb = tonumber(b.Name:match("%d+")) or math.huge
        return na < nb
    end)
end

local function canSeePlayer(playerHRP)
    if not HRP or not playerHRP then
        return false
    end

    local eyePosition = HRP.Position + Vector3.new(0, 1.5, 0)
    local targetPosition = playerHRP.Position + Vector3.new(0, 1.5, 0)

    local diff = targetPosition - eyePosition
    local dist = diff.Magnitude
    if dist > VISION_RANGE then
        return false
    end

    local dir = diff.Unit
    if HRP.CFrame.LookVector:Dot(dir) < VISION_ANGLE then
        return false
    end

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = { GUARD }

    local ray = Workspace:Raycast(eyePosition, dir * dist, params)
    if not ray then
        return true
    end

    local hitModel = ray.Instance and ray.Instance:FindFirstAncestorOfClass("Model")
    return hitModel and hitModel == playerHRP.Parent
end

local function findTarget()
    local nearestPlayer, nearestHRP, minDist = nil, nil, VISION_RANGE + 1

    for _, player in ipairs(Players:GetPlayers()) do
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if hrp and safeAlive(hum) then
            local dist = (hrp.Position - HRP.Position).Magnitude
            if dist < minDist and canSeePlayer(hrp) then
                minDist = dist
                nearestPlayer = player
                nearestHRP = hrp
            end
        end
    end

    return nearestPlayer, nearestHRP
end

local function getNearestWaypointIndex(position)
    if #Waypoints == 0 then
        return nil
    end

    local nearestIndex = 1
    local nearestDistance = math.huge

    for index, waypoint in ipairs(Waypoints) do
        local distance = (waypoint.Position - position).Magnitude
        if distance < nearestDistance then
            nearestDistance = distance
            nearestIndex = index
        end
    end

    return nearestIndex
end

local function updatePatrolState(now, visiblePlayer, visibleHRP)
    if visiblePlayer and visibleHRP then
        startChase(visiblePlayer, visibleHRP)
        return
    end

    if #Waypoints == 0 then
        stopWalk()
        clearMoveGoal()
        return
    end

    if patrolHoldUntil > now then
        stopWalk()
        clearMoveGoal()
        return
    end

    local point = Waypoints[currentPoint]
    if not point then
        stopWalk()
        clearMoveGoal()
        return
    end

    local timedOut = moveStartedAt > 0 and now - moveStartedAt > MOVE_TIMEOUT
    if timedOut then
        clearMoveGoal()
        currentPoint = (currentPoint % #Waypoints) + 1

        local nextPoint = Waypoints[currentPoint]
        if nextPoint then
            HUMANOID.WalkSpeed = PATROL_SPEED
            playWalk()
            issueMoveTo(nextPoint.Position)
        end
        return
    end

    HUMANOID.WalkSpeed = PATROL_SPEED
    playWalk()
    issueMoveTo(point.Position)
end

local function updateChaseState(now)
    local target = activeTarget
    local char = target and target.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local targetHRP = char and char:FindFirstChild("HumanoidRootPart")

    if not target or not targetHRP or not safeAlive(hum) then
        startSearch()
        return
    end

    if (HRP.Position - targetHRP.Position).Magnitude <= CAPTURE_DISTANCE then
        stopWalk()
        clearMoveGoal()
        startPatrol(0)
        return
    end

    if not canSeePlayer(targetHRP) then
        lastSeenPos = lastSeenPos or targetHRP.Position
        lostSightSince = lostSightSince or now

        if now - lostSightSince >= CHASE_TIMEOUT then
            startReturn()
            return
        end

        HUMANOID.WalkSpeed = CHASE_SPEED
        playWalk()
        issueMoveTo(lastSeenPos)
        return
    end

    lostSightSince = nil

    lastSeenPos = targetHRP.Position
    HUMANOID.WalkSpeed = CHASE_SPEED
    playWalk()
    issueMoveTo(targetHRP.Position)

    if now >= nextSuspicionTick then
        addLineOfSightSuspicion(target, SUSPICION_PER_TICK)
        nextSuspicionTick = now + SUSPICION_TICK_RATE
    end
end

local function updateSearchState(now, visiblePlayer, visibleHRP)
    if visiblePlayer and visibleHRP then
        startChase(visiblePlayer, visibleHRP)
        return
    end

    if now - stateStartTime > SEARCH_DURATION then
        startReturn()
        return
    end

    HUMANOID.WalkSpeed = CHASE_SPEED
    if lastSeenPos and (HRP.Position - lastSeenPos).Magnitude > RETURN_REACHED_DISTANCE then
        playWalk()
        issueMoveTo(lastSeenPos)
        return
    end

    stopWalk()
    clearMoveGoal()
    HRP.CFrame = HRP.CFrame * CFrame.Angles(0, SEARCH_ROTATION_STEP, 0)
end

local function updateReturnState(now)
    if #Waypoints == 0 then
        startPatrol(0)
        return
    end

    if not returnTargetIndex or not Waypoints[returnTargetIndex] then
        returnTargetIndex = getNearestWaypointIndex(HRP.Position)
    end

    local point = returnTargetIndex and Waypoints[returnTargetIndex] or nil
    if not point then
        startPatrol(0)
        return
    end

    local timedOut = (now - stateStartTime > MOVE_TIMEOUT) or (moveStartedAt > 0 and now - moveStartedAt > MOVE_TIMEOUT)
    if timedOut then
        stopWalk()
        clearMoveGoal()
        currentPoint = returnTargetIndex
        startPatrol(0)
        return
    end

    HUMANOID.WalkSpeed = PATROL_SPEED
    playWalk()
    issueMoveTo(point.Position)
end

HUMANOID.MoveToFinished:Connect(function(reached)
    if not reached then
        return
    end

    if currentState == State.PATROL and #Waypoints > 0 then
        clearMoveGoal()
        currentPoint = (currentPoint % #Waypoints) + 1
        local nextPoint = Waypoints[currentPoint]
        if nextPoint then
            HUMANOID.WalkSpeed = PATROL_SPEED
            playWalk()
            issueMoveTo(nextPoint.Position)
        end
        return
    end

    if currentState == State.RETURN and returnTargetIndex and #Waypoints > 0 then
        clearMoveGoal()
        currentPoint = (returnTargetIndex % #Waypoints) + 1
        startPatrol(0)
        return
    end
end)

task.spawn(function()
    while task.wait(HEARTBEAT_INTERVAL) do
        if isDistracted then
            HUMANOID.WalkSpeed = 0
            HUMANOID:Move(Vector3.zero, false)
            stopWalk()
            clearMoveGoal()
        else
            local now = os.clock()
            local visiblePlayer, visibleHRP = findTarget()

            if currentState == State.PATROL then
                updatePatrolState(now, visiblePlayer, visibleHRP)
            elseif currentState == State.CHASE then
                updateChaseState(now)
            elseif currentState == State.SEARCH then
                updateSearchState(now, visiblePlayer, visibleHRP)
            elseif currentState == State.RETURN then
                updateReturnState(now)
            end
        end
    end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="56">
        <Properties>
          <string name="Name">PhoneInteraction</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local PHONE_NAME = "Phone"
local CLICK_DETECTOR_NAME = "PhoneClickDetector"
local REMOTE_NAME = "PhoneCallRequested"
local PHONE_INTRO_COMPLETED_ATTRIBUTE = "PhoneIntroCallCompleted"
local MAX_ACTIVATION_DISTANCE = 24
local PHONE_SEARCH_INTERVAL = 1

local phoneCallRequested = ReplicatedStorage:FindFirstChild(REMOTE_NAME)
if not phoneCallRequested then
	phoneCallRequested = Instance.new("RemoteEvent")
	phoneCallRequested.Name = REMOTE_NAME
	phoneCallRequested.Parent = ReplicatedStorage
end

phoneCallRequested.OnServerEvent:Connect(function(player, action)
	if action == "Complete" and player and player.Parent == Players then
		player:SetAttribute(PHONE_INTRO_COMPLETED_ATTRIBUTE, true)
	end
end)

local connectedDetectors = {}
local detectorPhones = {}
local watchedPhones = {}

local function isPhoneInstance(instance)
	return instance
		and instance.Name == PHONE_NAME
		and (instance:IsA("Model") or instance:IsA("BasePart"))
end

local function findPhones()
	local phones = {}

	local direct = Workspace:FindFirstChild(PHONE_NAME)
	if isPhoneInstance(direct) then
		table.insert(phones, direct)
	end

	for _, descendant in ipairs(Workspace:GetDescendants()) do
		if isPhoneInstance(descendant) and descendant ~= direct then
			table.insert(phones, descendant)
		end
	end

	return phones
end

local function isInPhone(instance, phone)
	return phone
		and phone.Parent
		and instance
		and (instance == phone or instance:IsDescendantOf(phone))
end

local function canReachDetector(player, detector)
	if not player or player.Parent ~= Players then
		return false
	end

	local part = detector.Parent
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")

	if not part or not part:IsA("BasePart") or not root then
		return false
	end

	return (root.Position - part.Position).Magnitude <= MAX_ACTIVATION_DISTANCE + 3
end

local function connectDetector(detector, phone)
	if connectedDetectors[detector] then
		detectorPhones[detector] = phone or detectorPhones[detector]
		return
	end

	connectedDetectors[detector] = true
	detectorPhones[detector] = phone
	detector.MaxActivationDistance = MAX_ACTIVATION_DISTANCE

	detector.MouseClick:Connect(function(player)
		local owningPhone = detectorPhones[detector]
		if not isInPhone(detector, owningPhone) or not canReachDetector(player, detector) then
			return
		end

		phoneCallRequested:FireClient(player)
	end)
end

local function attachClickDetector(part, phone)
	if not part:IsA("BasePart") then
		return
	end

	local hasClickDetector = false
	for _, child in ipairs(part:GetChildren()) do
		if child:IsA("ClickDetector") then
			hasClickDetector = true
			connectDetector(child, phone)
		end
	end

	if not hasClickDetector then
		local detector = Instance.new("ClickDetector")
		detector.Name = CLICK_DETECTOR_NAME
		detector.MaxActivationDistance = MAX_ACTIVATION_DISTANCE
		detector.Parent = part
		connectDetector(detector, phone)
	end
end

local function ensurePhoneDetectors(phone)
	if phone:IsA("BasePart") then
		attachClickDetector(phone, phone)
		return
	end

	for _, descendant in ipairs(phone:GetDescendants()) do
		if descendant:IsA("BasePart") then
			attachClickDetector(descendant, phone)
		elseif descendant:IsA("ClickDetector") then
			connectDetector(descendant, phone)
		end
	end
end

local function attachPhone(phone)
	ensurePhoneDetectors(phone)

	if watchedPhones[phone] then
		return
	end

	watchedPhones[phone] = true
	phone.DescendantAdded:Connect(function(descendant)
		if not isInPhone(descendant, phone) then
			return
		end

		if descendant:IsA("BasePart") then
			attachClickDetector(descendant, phone)
		elseif descendant:IsA("ClickDetector") then
			connectDetector(descendant, phone)
		end
	end)
end

for _, phone in ipairs(findPhones()) do
	attachPhone(phone)
end

Workspace.DescendantAdded:Connect(function(descendant)
	if isPhoneInstance(descendant) then
		attachPhone(descendant)
		return
	end

	for phone in pairs(watchedPhones) do
		if isInPhone(descendant, phone) then
			if descendant:IsA("BasePart") then
				attachClickDetector(descendant, phone)
			elseif descendant:IsA("ClickDetector") then
				connectDetector(descendant, phone)
			end
			return
		end
	end
end)

task.spawn(function()
	while true do
		for phone in pairs(watchedPhones) do
			if not phone.Parent then
				watchedPhones[phone] = nil
			end
		end

		for _, phone in ipairs(findPhones()) do
			attachPhone(phone)
		end

		task.wait(PHONE_SEARCH_INTERVAL)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="57">
        <Properties>
          <string name="Name">RepTrack</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- RepTrack module (shared)
-- Tracks reputation values RGood and Rbad. Server scripts own all mutations.

local RunService = game:GetService("RunService")

local RepTrack = {}

local GLOBAL_BUCKET_KEY = "__global"
local MAX_REPUTATION_ABS = 100000
local playerData = {
	[GLOBAL_BUCKET_KEY] = {
		RGood = 0,
		Rbad = 0,
	},
}

local function isPlayer(value)
	return typeof(value) == "Instance" and value:IsA("Player")
end

local function normalizeNumber(value)
	local n = tonumber(value)
	if not n or n ~= n or n == math.huge or n == -math.huge then
		return 0
	end
	return math.clamp(n, -MAX_REPUTATION_ABS, MAX_REPUTATION_ABS)
end

local function resolvePlayerAndValue(first, second)
	if isPlayer(first) then
		return first, normalizeNumber(second)
	end
	return nil, normalizeNumber(first)
end

local function resolveBucketKey(player)
	if isPlayer(player) then
		return tostring(player.UserId)
	end
	return GLOBAL_BUCKET_KEY
end

local function ensureBucket(player)
	local bucketKey = resolveBucketKey(player)
	local bucket = playerData[bucketKey]
	if not bucket then
		bucket = {
			RGood = 0,
			Rbad = 0,
		}
		playerData[bucketKey] = bucket
	end
	return bucket
end

local function rejectClientMutation(methodName)
	if RunService:IsClient() then
		warn(("[RepTrack] Client attempted to call %s directly; server authority required."):format(methodName))
		return true
	end
	return false
end

function RepTrack.GetRGood(player)
	return ensureBucket(player).RGood
end

function RepTrack.GetRbad(player)
	return ensureBucket(player).Rbad
end

function RepTrack.SetRGood(first, second)
	if rejectClientMutation("SetRGood") then
		return RepTrack.GetRGood(isPlayer(first) and first or nil)
	end
	local player, value = resolvePlayerAndValue(first, second)
	local bucket = ensureBucket(player)
	bucket.RGood = value
	return bucket.RGood
end

function RepTrack.SetRbad(first, second)
	if rejectClientMutation("SetRbad") then
		return RepTrack.GetRbad(isPlayer(first) and first or nil)
	end
	local player, value = resolvePlayerAndValue(first, second)
	local bucket = ensureBucket(player)
	bucket.Rbad = value
	return bucket.Rbad
end

function RepTrack.AddRGood(first, second)
	if rejectClientMutation("AddRGood") then
		return RepTrack.GetRGood(isPlayer(first) and first or nil)
	end
	local player, value = resolvePlayerAndValue(first, second)
	local bucket = ensureBucket(player)
	bucket.RGood = math.clamp(bucket.RGood + value, -MAX_REPUTATION_ABS, MAX_REPUTATION_ABS)
	return bucket.RGood
end

function RepTrack.AddRbad(first, second)
	if rejectClientMutation("AddRbad") then
		return RepTrack.GetRbad(isPlayer(first) and first or nil)
	end
	local player, value = resolvePlayerAndValue(first, second)
	local bucket = ensureBucket(player)
	bucket.Rbad = math.clamp(bucket.Rbad + value, -MAX_REPUTATION_ABS, MAX_REPUTATION_ABS)
	return bucket.Rbad
end

function RepTrack.GetAll(player)
	local bucket = ensureBucket(player)
	return {
		RGood = bucket.RGood,
		Rbad = bucket.Rbad,
	}
end

function RepTrack.Reset(player)
	if rejectClientMutation("Reset") then
		return RepTrack.GetAll(player)
	end
	local bucketKey = resolveBucketKey(player)
	playerData[bucketKey] = {
		RGood = 0,
		Rbad = 0,
	}
	return RepTrack.GetAll(player)
end

return RepTrack
]]></string>
        </Properties>
