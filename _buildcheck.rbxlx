      <Item class="ModuleScript" referent="50">
        <Properties>
          <string name="Name">LessonManager</string>
          <string name="Source"><![CDATA[local LessonManager = {}
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local popupCooldowns = {}

local function ensureRemote(name)
	local remote = ReplicatedStorage:FindFirstChild(name)
	if not remote then
		remote = Instance.new("RemoteEvent")
		remote.Name = name
		remote.Parent = ReplicatedStorage
	end
	return remote
end

local popupEvent = ensureRemote("ShowEducationalPopup")
local notificationEvent = ensureRemote("ShowEducationalNotification")

local lessonDatabase = {
	ClickedPhish = {
		title = "PHISHING DETECTED",
		message = "Always check the sender's email domain before clicking links. Hackers use urgent language to trick you into acting quickly.",
	},
	FoundStickyNotePassword = {
		title = "CREDENTIAL EXPOSURE",
		message = "Never write passwords on sticky notes attached to your monitor. Physical security is just as important as digital security!",
	},
	StickyNotePassword = {
		title = "CREDENTIAL EXPOSURE",
		message = "Never write passwords on sticky notes attached to your monitor. Physical security is just as important as digital security!",
	},
	PublicWifiOpsec = {
		title = "OPSEC WARNING",
		message = "Handling sensitive corporate tools in a public coffee shop exposes you to shoulder surfing and unsecured network snooping.",
	},
	CaughtByCamera = {
		title = "SPOTTED BY CAMERA",
		message = "Cameras leave a permanent digital audit trail. As a cybersecurity professional, you must minimize your digital footprint.",
	},
	CameraDetected = {
		title = "SPOTTED BY CAMERA",
		message = "Cameras leave a permanent digital audit trail. As a cybersecurity professional, you must minimize your digital footprint.",
	},
	DetectedBySecurity = {
		title = "SECURITY TRIGGERED",
		message = "You were spotted! Physical security personnel are your biggest threat during an on-site infiltration.",
	},
	ClonedKeycard = {
		title = "RFID CLONED",
		message = "You successfully cloned a badge. In the real world, unprotected RFID cards can be copied just by standing near someone.",
	},
}

local function shouldThrottlePopup(player, throttleKey, throttleWindow)
	if not player or type(throttleKey) ~= "string" or throttleKey == "" then
		return false
	end

	local window = tonumber(throttleWindow) or 0
	if window <= 0 then
		return false
	end

	local userId = player.UserId
	local now = os.clock()
	local playerCooldowns = popupCooldowns[userId]

	if not playerCooldowns then
		playerCooldowns = {}
		popupCooldowns[userId] = playerCooldowns
	end

	local lastSentAt = playerCooldowns[throttleKey]
	if lastSentAt and now - lastSentAt < window then
		return true
	end

	playerCooldowns[throttleKey] = now
	return false
end

local function sendPopup(player, title, message, options)
	if not player then
		return false
	end

	options = options or {}
	if shouldThrottlePopup(player, options.throttleKey, options.throttleWindow) then
		return false
	end

	popupEvent:FireClient(
		player,
		tostring(title or "SECURITY ALERT"),
		tostring(message or "No lesson available.")
	)

	return true
end

local function sendNotification(player, title, message, options)
	if not player then
		return false
	end

	options = options or {}
	if shouldThrottlePopup(player, options.throttleKey, options.throttleWindow) then
		return false
	end

	notificationEvent:FireClient(
		player,
		tostring(title or "SECURITY ALERT"),
		tostring(message or "No lesson available."),
		tonumber(options.duration) or 4
	)

	return true
end

function LessonManager.TriggerMistake(player, mistakeId, options)
	local lesson = lessonDatabase[mistakeId]
	if not lesson then
		warn("ERROR: Could not find an educational lesson for mistake: " .. tostring(mistakeId))
		return false
	end

	return sendPopup(player, lesson.title, lesson.message, options)
end

function LessonManager.TriggerCustomPopup(player, title, message, options)
	return sendPopup(player, title, message, options)
end

function LessonManager.TriggerNotification(player, title, message, options)
	return sendNotification(player, title, message, options)
end

Players.PlayerRemoving:Connect(function(player)
	popupCooldowns[player.UserId] = nil
end)

return LessonManager
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="51">
        <Properties>
          <string name="Name">MissionController</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local ObjectiveManager = require(Shared:WaitForChild("ObjectiveManager"))
local CyberScenarioManager = require(Shared:WaitForChild("CyberScenarioManager"))

local STATUS_COMPLETED = "Completed"
local STATUS_IN_PROGRESS = "In Progress"
local STATUS_NOT_STARTED = "Not Started"

local TASK_AGENT_RAY = 1
local TASK_INFILTRATE = 2
local TASK_KEY_CODE = 3
local TASK_SLIDING_DOOR = 4
local TASK_STICKY_NOTE = 5

local INFILTRATION_CHECK_INTERVAL = 0.5
local INFILTRATION_DISTANCE = 35
local INFILTRATION_TARGET_NAMES = {
	"OuterPerimeterCheckpoint",
	"PerimeterCheckpoint",
	"InfiltrationCheckpoint",
	"OuterPerimeter",
	"Panel",
	"S.S.R. Teknikk Door",
}

local defaultMission = {
	{ id = "task1", text = "Meet Agent Ray at the Cafe to receive your tools.", status = STATUS_IN_PROGRESS },
	{ id = "task2", text = "Infiltrate the outer perimeter.", status = STATUS_NOT_STARTED },
	{ id = "task3", text = "Copy the Guard's Key Code.", status = STATUS_NOT_STARTED },
	{ id = "task4", text = "Unlock the sliding door.", status = STATUS_NOT_STARTED },
	{ id = "task5", text = "Find the Chapter 2 sticky note.", status = STATUS_NOT_STARTED },
}

local playerMissions = {}
local playerConnectionsByUserId = {}

local function cloneMission()
	local missionCopy = table.create(#defaultMission)
	for index, taskInfo in ipairs(defaultMission) do
		missionCopy[index] = {
			id = taskInfo.id,
			text = taskInfo.text,
			status = taskInfo.status,
		}
	end
	return missionCopy
end

local function getMission(player)
	if not player or player.Parent ~= Players then
		return nil
	end

	local mission = playerMissions[player]
	if not mission then
		mission = cloneMission()
		playerMissions[player] = mission
	end

	return mission
end

local function syncPlayerObjectives(player, mission)
	if not player or player.Parent ~= Players then
		return
	end

	mission = mission or getMission(player)
	if not mission then
		return
	end

	ObjectiveManager.SetPlayerObjectives(player, mission)
	CyberScenarioManager.SyncObjectives(player)
end

local function missionStage(mission)
	if mission[TASK_STICKY_NOTE].status == STATUS_COMPLETED then
		return 6
	end
	if mission[TASK_SLIDING_DOOR].status == STATUS_COMPLETED then
		return 5
	end
	if mission[TASK_KEY_CODE].status == STATUS_COMPLETED then
		return 4
	end
	if mission[TASK_INFILTRATE].status == STATUS_COMPLETED then
		return 3
	end
	if mission[TASK_AGENT_RAY].status == STATUS_COMPLETED then
		return 2
	end
	return 1
end

local function setMissionStage(player, stage)
	local mission = getMission(player)
	if not mission then
		return
	end

	local nextStage = math.max(missionStage(mission), stage)
	local before = table.concat({
		mission[TASK_AGENT_RAY].status,
		mission[TASK_INFILTRATE].status,
		mission[TASK_KEY_CODE].status,
		mission[TASK_SLIDING_DOOR].status,
		mission[TASK_STICKY_NOTE].status,
	}, "|")

	mission[TASK_AGENT_RAY].status = nextStage >= 2 and STATUS_COMPLETED or STATUS_IN_PROGRESS
	mission[TASK_INFILTRATE].status = nextStage >= 3 and STATUS_COMPLETED
		or (nextStage >= 2 and STATUS_IN_PROGRESS or STATUS_NOT_STARTED)
	mission[TASK_KEY_CODE].status = nextStage >= 4 and STATUS_COMPLETED
		or (nextStage >= 3 and STATUS_IN_PROGRESS or STATUS_NOT_STARTED)
	mission[TASK_SLIDING_DOOR].status = nextStage >= 5 and STATUS_COMPLETED
		or (nextStage >= 4 and STATUS_IN_PROGRESS or STATUS_NOT_STARTED)
	mission[TASK_STICKY_NOTE].status = nextStage >= 6 and STATUS_COMPLETED
		or (nextStage >= 5 and STATUS_IN_PROGRESS or STATUS_NOT_STARTED)

	local after = table.concat({
		mission[TASK_AGENT_RAY].status,
		mission[TASK_INFILTRATE].status,
		mission[TASK_KEY_CODE].status,
		mission[TASK_SLIDING_DOOR].status,
		mission[TASK_STICKY_NOTE].status,
	}, "|")

	if after ~= before then
		syncPlayerObjectives(player, mission)
	end
end

local function refreshMissionFromState(player)
	if not player or player.Parent ~= Players then
		return
	end

	if player:GetAttribute("RecoveredAdminCredentials") == true then
		setMissionStage(player, 6)
	elseif player:GetAttribute("UnlockedSlidingDoor") == true then
		setMissionStage(player, 5)
	elseif player:GetAttribute("HasKeycardData") == true then
		setMissionStage(player, 4)
	elseif player:GetAttribute("HasSpokenToAgentRay") == true then
		setMissionStage(player, 2)
	else
		syncPlayerObjectives(player)
	end
end

local function resetMission(player)
	if not player or player.Parent ~= Players then
		return
	end

	playerMissions[player] = cloneMission()
	syncPlayerObjectives(player, playerMissions[player])
end

local function getWorldPosition(instance)
	if not instance then
		return nil
	end

	if instance:IsA("BasePart") then
		return instance.Position
	end

	if instance:IsA("Model") then
		return instance:GetPivot().Position
	end

	if instance:IsA("Attachment") then
		return instance.WorldPosition
	end

	return nil
end

local function getInfiltrationTargetPosition()
	for _, targetName in ipairs(INFILTRATION_TARGET_NAMES) do
		local target = Workspace:FindFirstChild(targetName, true)
		local position = getWorldPosition(target)
		if position then
			return position
		end
	end

	return nil
end

local function isNearInfiltrationTarget(player, targetPosition)
	local character = player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root then
		return false
	end

	return (root.Position - targetPosition).Magnitude <= INFILTRATION_DISTANCE
end

local function connectPlayer(player)
	playerMissions[player] = cloneMission()

	local connections = {}
	playerConnectionsByUserId[player.UserId] = connections

	table.insert(connections, player:GetAttributeChangedSignal("HasKeycardData"):Connect(function()
		refreshMissionFromState(player)
	end))
	table.insert(connections, player:GetAttributeChangedSignal("HasSpokenToAgentRay"):Connect(function()
		refreshMissionFromState(player)
	end))
	table.insert(connections, player:GetAttributeChangedSignal("UnlockedSlidingDoor"):Connect(function()
		refreshMissionFromState(player)
	end))
	table.insert(connections, player:GetAttributeChangedSignal("RecoveredAdminCredentials"):Connect(function()
		refreshMissionFromState(player)
	end))

	task.delay(2, function()
		refreshMissionFromState(player)
	end)
end

local function disconnectPlayer(player)
	local connections = playerConnectionsByUserId[player.UserId]
	if connections then
		for _, connection in ipairs(connections) do
			connection:Disconnect()
		end
	end

	playerConnectionsByUserId[player.UserId] = nil
	playerMissions[player] = nil
end

local MissionController = {
	ResetMission = resetMission,
	MarkAgentRayVisited = function(player)
		setMissionStage(player, 2)
	end,
	MarkInfiltratedOuterPerimeter = function(player)
		setMissionStage(player, 3)
	end,
	MarkKeyCodeCopied = function(player)
		setMissionStage(player, 4)
	end,
	MarkSlidingDoorUnlocked = function(player)
		setMissionStage(player, 5)
	end,
	MarkStickyNoteFound = function(player)
		setMissionStage(player, 6)
	end,
	RefreshMission = refreshMissionFromState,
}

_G.MissionController = MissionController

local StartNewsCutscene = ReplicatedStorage:WaitForChild("StartNewsCutscene", 10)
if StartNewsCutscene then
	StartNewsCutscene.OnServerEvent:Connect(function(player)
		-- Eligibility check: player must exist, have a mission, and not already be in one
		if not player or not player.Parent then return end
		if not playerMissions[player] then return end
		if not CyberScenarioManager.hasActiveScenario(player) then return end
		if _G.MissionTimer then
			_G.MissionTimer.startMission(player)
		end
	end)
end

for _, player in ipairs(Players:GetPlayers()) do
	connectPlayer(player)
	refreshMissionFromState(player)
end

Players.PlayerAdded:Connect(connectPlayer)
Players.PlayerRemoving:Connect(disconnectPlayer)

task.spawn(function()
	while task.wait(INFILTRATION_CHECK_INTERVAL) do
		local targetPosition = getInfiltrationTargetPosition()
		if targetPosition then
			for _, player in ipairs(Players:GetPlayers()) do
				local mission = getMission(player)
				if mission and missionStage(mission) == 2 and isNearInfiltrationTarget(player, targetPosition) then
					setMissionStage(player, 3)
				end
			end
		end
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="52">
        <Properties>
          <string name="Name">MissionTimer</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[-- MissionTimer.server.luau
-- Tracks mission completion times, saves best times to DataStore,
-- and exposes RemoteEvents for client HUD and leaderboard updates.

local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ─── DataStore ───────────────────────────────────────────────────────────────
local BestTimesStore = DataStoreService:GetDataStore("MissionBestTimes_v1")

-- ─── RemoteEvents (create folder if needed) ──────────────────────────────────
local Remotes = ReplicatedStorage:FindFirstChild("MissionTimerRemotes")
if not Remotes then
	Remotes = Instance.new("Folder")
	Remotes.Name = "MissionTimerRemotes"
	Remotes.Parent = ReplicatedStorage
end

local function getOrMakeRemote(class, name)
	local existing = Remotes:FindFirstChild(name)
	if existing then return existing end
	local obj = Instance.new(class)
	obj.Name = name
	obj.Parent = Remotes
	return obj
end

-- Server → Client
local EvStartTimer   = getOrMakeRemote("RemoteEvent",    "StartTimer")   -- fires when mission begins
local EvStopTimer    = getOrMakeRemote("RemoteEvent",    "StopTimer")    -- fires with elapsed seconds
local EvNewBestTime  = getOrMakeRemote("RemoteEvent",    "NewBestTime")  -- fires when player sets new best
-- Client → Server (optional manual trigger fallback)
local EvMissionStart = getOrMakeRemote("RemoteEvent",    "MissionStart")
local EvMissionEnd   = getOrMakeRemote("RemoteEvent",    "MissionEnd")
-- Server → All clients (leaderboard refresh)
local EvLeaderboard  = getOrMakeRemote("RemoteEvent",    "LeaderboardUpdate")
-- Server → Client (send personal best on join)
local FnGetBestTime  = getOrMakeRemote("RemoteFunction", "GetMyBestTime")
local FnGetTimerState = getOrMakeRemote("RemoteFunction", "GetTimerState")

EvStartTimer.Name   = "StartTimer"
EvStopTimer.Name    = "StopTimer"
EvNewBestTime.Name  = "NewBestTime"
EvMissionStart.Name = "MissionStart"
EvMissionEnd.Name   = "MissionEnd"
EvLeaderboard.Name  = "LeaderboardUpdate"
FnGetBestTime.Name  = "GetMyBestTime"
FnGetTimerState.Name = "GetTimerState"

-- ─── State ───────────────────────────────────────────────────────────────────
-- activeMissions[player] = { startTick: number }
local activeMissions = {}
local bestTimeCache = {}
local bestTimeLoaded = {}
local requestWarnings = {}
local MAX_BEST_TIME = 60 * 60 * 24

local function sanitizeElapsedTime(value)
	local n = tonumber(value)
	if not n or n ~= n or n == math.huge or n == -math.huge or n < 0 or n > MAX_BEST_TIME then
		return nil
	end

	return math.floor(n * 100 + 0.5) / 100
end

local function warnRejectedClientRemote(player, remoteName)
	local userId = player.UserId
	requestWarnings[userId] = requestWarnings[userId] or {}

	local now = os.clock()
	local last = requestWarnings[userId][remoteName] or 0
	if now - last < 1 then
		return
	end

	requestWarnings[userId][remoteName] = now
	warn(("[MissionTimer] Ignored client-authored %s request from %s"):format(remoteName, player.Name))
end

-- ─── Helpers ─────────────────────────────────────────────────────────────────
local function datastoreKey(player)
	return "player_" .. player.UserId
end

local function loadBestTime(player)
	if bestTimeLoaded[player] then
		return bestTimeCache[player]
	end

	local ok, result = pcall(function()
		return BestTimesStore:GetAsync(datastoreKey(player))
	end)
	if ok then
		local sanitized = sanitizeElapsedTime(result)
		bestTimeCache[player] = sanitized
		bestTimeLoaded[player] = true
		return sanitized
	end

	warn("[MissionTimer] Failed to load best time for", player.Name, result)
	return nil
end

local function saveBestTime(player, elapsed)
	local sanitizedElapsed = sanitizeElapsedTime(elapsed)
	if not sanitizedElapsed then
		return bestTimeCache[player]
	end

	local ok, result = pcall(function()
		return BestTimesStore:UpdateAsync(datastoreKey(player), function(oldValue)
			local currentBest = sanitizeElapsedTime(oldValue)
			if currentBest and currentBest <= sanitizedElapsed then
				return currentBest
			end
			return sanitizedElapsed
		end)
	end)
	if not ok then
		warn("[MissionTimer] Failed to save best time for", player.Name, result)
		return bestTimeCache[player]
	end

	local saved = sanitizeElapsedTime(result) or sanitizedElapsed
	bestTimeCache[player] = saved
	bestTimeLoaded[player] = true
	return saved
end

-- Returns top-N best times as { {name, time} } sorted ascending
local TOP_N = 10
local function buildLeaderboardData()
	-- We read from a sorted DataStore for efficiency in production;
	-- here we use an OrderedDataStore pattern via a second store.
	-- For simplicity this version collects from connected players only
	-- and is easily swappable with an OrderedDataStore.
	local rows = {}
	for _, player in Players:GetPlayers() do
		local best = bestTimeCache[player]
		if best then
			table.insert(rows, { name = player.Name, time = best })
		end
	end
	table.sort(rows, function(a, b) return a.time < b.time end)
	local trimmed = {}
	for i = 1, math.min(TOP_N, #rows) do
		table.insert(trimmed, rows[i])
	end
	return trimmed
end

local function broadcastLeaderboard()
	local data = buildLeaderboardData()
	EvLeaderboard:FireAllClients(data)
end

-- ─── Core API ────────────────────────────────────────────────────────────────

local function getMissionElapsed(player)
	local mission = activeMissions[player]
	if not mission then
		return 0
	end

	return sanitizeElapsedTime(tick() - mission.startTick) or 0
end

--- Call this from MissionController (or any server script) when a mission begins.
local function startMission(player, initialElapsed)
	if activeMissions[player] then
		EvStartTimer:FireClient(player, getMissionElapsed(player))
		return
	end

	local elapsed = sanitizeElapsedTime(initialElapsed) or 0
	activeMissions[player] = { startTick = tick() - elapsed }
	EvStartTimer:FireClient(player, elapsed)
	print(("[MissionTimer] Mission started for %s at %.2fs"):format(player.Name, elapsed))
end

--- Call this when the mission ends (caught OR escaped).
--- outcome: "escaped" | "caught" | "completed" | "reset"
--- Returns elapsed seconds.
local function endMission(player, outcome)
	local mission = activeMissions[player]
	if not mission then
		warn("[MissionTimer] No active mission for", player.Name)
		return nil
	end

	if outcome ~= "escaped" and outcome ~= "caught" and outcome ~= "completed" and outcome ~= "reset" then
		outcome = "caught"
	end

	local elapsed = getMissionElapsed(player)
	activeMissions[player] = nil

	-- Always send elapsed to client regardless of outcome
	EvStopTimer:FireClient(player, elapsed, outcome)

	-- Only save/compare best time on successful mission completion.
	if outcome == "escaped" or outcome == "completed" then
		local previous = loadBestTime(player)
		local newBest = saveBestTime(player, elapsed)
		if newBest and (previous == nil or newBest < previous) then
			EvNewBestTime:FireClient(player, newBest, previous)
			print(("[MissionTimer] NEW BEST for %s: %.2fs (was %s)"):format(
				player.Name, newBest, previous and ("%.2fs"):format(previous) or "none"))
		end
		broadcastLeaderboard()
	end

	print(("[MissionTimer] Mission ended for %s | outcome=%s | time=%.2fs"):format(
		player.Name, outcome, elapsed))
	return elapsed
end

-- ─── Expose functions via _G for other server scripts ────────────────────────
-- Usage from MissionController:
--   _G.MissionTimer.startMission(player)
--   _G.MissionTimer.endMission(player, "escaped")
_G.MissionTimer = {
	startMission = startMission,
	endMission   = endMission,
	getElapsed = getMissionElapsed,
	isMissionActive = function(player)
		return activeMissions[player] ~= nil
	end,
	completeMission = function(player)
		return endMission(player, "completed")
	end,
	resetMission = function(player)
		return endMission(player, "reset")
	end,
}

-- ─── Optional: listen to RemoteEvents from client (fallback / debug) ─────────
EvMissionStart.OnServerEvent:Connect(function(player)
	warnRejectedClientRemote(player, "MissionStart")
end)

EvMissionEnd.OnServerEvent:Connect(function(player)
	warnRejectedClientRemote(player, "MissionEnd")
end)

-- ─── Serve personal best on request ─────────────────────────────────────────
FnGetBestTime.OnServerInvoke = function(player)
	return loadBestTime(player)
end

FnGetTimerState.OnServerInvoke = function(player)
	local mission = activeMissions[player]
	if not mission then
		return {
			running = false,
			elapsed = 0,
		}
	end

	return {
		running = true,
		elapsed = getMissionElapsed(player),
	}
end

-- ─── Cleanup on leave ────────────────────────────────────────────────────────
Players.PlayerRemoving:Connect(function(player)
	if activeMissions[player] then
		-- Mission abandoned — don't save time
		activeMissions[player] = nil
		print("[MissionTimer] Cleaned up abandoned mission for", player.Name)
	end
	bestTimeCache[player] = nil
	bestTimeLoaded[player] = nil
	requestWarnings[player.UserId] = nil
end)

Players.PlayerAdded:Connect(function(player)
	task.spawn(function()
		loadBestTime(player)
		broadcastLeaderboard()
	end)
end)

for _, player in Players:GetPlayers() do
	task.spawn(function()
		loadBestTime(player)
	end)
end

-- ─── Refresh leaderboard every 60s for late-joining players ──────────────────
task.spawn(function()
	while true do
		task.wait(60)
		broadcastLeaderboard()
	end
end)

print("[MissionTimer] Server module loaded.")
]]></string>
        </Properties>
      </Item>
      <Item class="Script" referent="53">
        <Properties>
          <string name="Name">NarrativeManager</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DialogueData = require(ReplicatedStorage.Shared.DialogueData)
local IntegrityService = require(ReplicatedStorage.Shared.IntegrityService)

local NarrativeManager = {}

local activeSessions = {}

local function getDialogue(dialogueId)
	return DialogueData[dialogueId]
end

local function getSession(player)
	if not player or not player.UserId then
		return nil
	end

	return activeSessions[player.UserId]
end

local function setSession(player, sessionData)
	if not player or not player.UserId then
		return
	end

	activeSessions[player.UserId] = sessionData
end

local function clearSession(player)
	if not player or not player.UserId then
		return
	end

	activeSessions[player.UserId] = nil
end

function NarrativeManager.startDialogue(player, dialogueId)
	local dialogue = getDialogue(dialogueId)
	if not dialogue then
		return nil, "Dialogue not found"
	end

	local startNodeId = dialogue.start
	local startNode = dialogue.nodes[startNodeId]

	if not startNode then
		return nil, "Start node not found"
	end

	setSession(player, {
		dialogueId = dialogueId,
		currentNodeId = startNodeId,
	})

	return {
		dialogueId = dialogueId,
		nodeId = startNodeId,
		text = startNode.text,
		choices = startNode.choices,
		isEnd = startNode.isEnd or false,
		integrity = IntegrityService.getIntegrity(player),
	}
end

function NarrativeManager.getCurrentNode(player)
	local session = getSession(player)
	if not session then
		return nil, "No active dialogue"
	end

	local dialogue = getDialogue(session.dialogueId)
	if not dialogue then
		return nil, "Dialogue data missing"
	end

	local node = dialogue.nodes[session.currentNodeId]
	if not node then
		return nil, "Current node missing"
	end

	return {
		dialogueId = session.dialogueId,
		nodeId = session.currentNodeId,
		text = node.text,
		choices = node.choices,
		isEnd = node.isEnd or false,
		integrity = IntegrityService.getIntegrity(player),
	}
end

function NarrativeManager.chooseOption(player, choiceIndex)
	local session = getSession(player)
	if not session then
		return nil, "No active dialogue"
	end

	local dialogue = getDialogue(session.dialogueId)
	if not dialogue then
		return nil, "Dialogue data missing"
	end

	local currentNode = dialogue.nodes[session.currentNodeId]
	if not currentNode then
		return nil, "Current node missing"
	end

	local choices = currentNode.choices or {}
	local choice = choices[choiceIndex]

	if not choice then
		return nil, "Invalid choice"
	end

	if choice.integrity then
		IntegrityService.addIntegrity(player, choice.integrity)
	end

	if not choice.next then
		clearSession(player)
		return {
			dialogueId = session.dialogueId,
			nodeId = nil,
			text = nil,
			choices = {},
			isEnd = true,
			integrity = IntegrityService.getIntegrity(player),
		}
	end

	local nextNode = dialogue.nodes[choice.next]
	if not nextNode then
		clearSession(player)
		return nil, "Next node missing"
	end

	session.currentNodeId = choice.next
	setSession(player, session)

	local response = {
		dialogueId = session.dialogueId,
		nodeId = choice.next,
		text = nextNode.text,
		choices = nextNode.choices,
		isEnd = nextNode.isEnd or false,
		integrity = IntegrityService.getIntegrity(player),
	}

	if nextNode.isEnd then
		clearSession(player)
	end

	return response
end

function NarrativeManager.endDialogue(player)
	clearSession(player)
end

function NarrativeManager.hasActiveDialogue(player)
	return getSession(player) ~= nil
end

return NarrativeManager
]]></string>
        </Properties>
