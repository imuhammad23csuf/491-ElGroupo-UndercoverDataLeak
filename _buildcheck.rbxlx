return TabletIncidentLogs.getWannaWailIncidentLogs(Player, {
WANNAWAIL_ATTR_COUNT = WANNAWAIL_ATTR_COUNT,
WANNAWAIL_ATTR_ACTIVE = WANNAWAIL_ATTR_ACTIVE,
