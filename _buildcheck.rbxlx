Name = "DoneButton",
AutoButtonColor = true,
Text = "NOT NOW",
Font = Enum.Font.GothamBold,
TextSize = 15,
TextColor3 = Color3.fromRGB(220, 231, 248),
BackgroundColor3 = Color3.fromRGB(46, 57, 79),
BorderSizePixel = 0,
Size = UDim2.new(0, 170, 0, 42),
Position = UDim2.new(0.5, 12, 1, -62),
})
round(doneBtn, 12)
ReplayPromptGUI = gui
return gui
