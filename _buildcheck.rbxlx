        <Item class="LocalScript" referent="49">
          <Properties>
            <string name="Name">camscreen</string>
            <string name="Source">local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local gameCamera = workspace.CurrentCamera

local openEvent = ReplicatedStorage:WaitForChild("OpenCameraMonitor")

local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

local monitorOpen = false
local currentIndex = 1
local renderConnection = nil

local cameraPoints = {}

local screenGui
local mainFrame
local titleLabel
local leftButton
local rightButton
local closeButton

local function refreshCharacter(newCharacter)
	character = newCharacter or player.Character or player.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid")

	if not monitorOpen then
		gameCamera.CameraSubject = humanoid
	end
end

player.CharacterAdded:Connect(refreshCharacter)

local function collectCameras()
	cameraPoints = {}

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and obj.Name == "Camera" then
			local lens = obj:FindFirstChild("Lens", true)

			if lens and lens:IsA("BasePart") then
				table.insert(cameraPoints, {
					cameraModel = obj,
					viewPart = lens
				})
			else
				warn("[Monitor] No valid Lens found in", obj:GetFullName())
			end
		end
	end
end

local function updateTitle()
	if #cameraPoints == 0 then
		titleLabel.Text = "NO CAMERAS"
	else
		titleLabel.Text = "CAMERA " .. currentIndex .. " / " .. #cameraPoints
	end
end

local function applyCurrentCamera()
	local data = cameraPoints[currentIndex]
	if not data or not data.viewPart or not data.viewPart.Parent then
		return
	end

	gameCamera.CameraType = Enum.CameraType.Scriptable
	gameCamera.CFrame = data.viewPart.CFrame
	updateTitle()
end

local function nextCamera()
	if #cameraPoints == 0 then
		return
	end

	currentIndex += 1
	if currentIndex &gt; #cameraPoints then
		currentIndex = 1
	end

	applyCurrentCamera()
end

local function previousCamera()
	if #cameraPoints == 0 then
		return
	end

	currentIndex -= 1
	if currentIndex &lt; 1 then
		currentIndex = #cameraPoints
	end

	applyCurrentCamera()
end

local function closeMonitor()
	monitorOpen = false

	if renderConnection then
		renderConnection:Disconnect()
		renderConnection = nil
	end

	screenGui.Enabled = false
	gameCamera.CameraType = Enum.CameraType.Custom

	if humanoid then
		gameCamera.CameraSubject = humanoid
	end
end

local function openMonitor()
	collectCameras()

	if #cameraPoints == 0 then
		warn("No cameras found. Expected a model named Camera containing a part named Lens.")
		return
	end

	if currentIndex &gt; #cameraPoints then
		currentIndex = 1
	end

	monitorOpen = true
	screenGui.Enabled = true

	applyCurrentCamera()

	if renderConnection then
		renderConnection:Disconnect()
	end

	renderConnection = RunService.RenderStepped:Connect(function()
		if not monitorOpen then
			return
		end

		local data = cameraPoints[currentIndex]
		if data and data.viewPart and data.viewPart.Parent then
			gameCamera.CFrame = data.viewPart.CFrame
		end
	end)
end

screenGui = Instance.new("ScreenGui")
screenGui.Name = "CameraMonitorGui"
screenGui.ResetOnSpawn = false
screenGui.Enabled = false
screenGui.Parent = playerGui

mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 420, 0, 110)
mainFrame.Position = UDim2.new(0.5, -210, 1, -130)
mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
mainFrame.BackgroundTransparency = 0.15
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, -120, 0, 40)
titleLabel.Position = UDim2.new(0, 60, 0, 10)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "CAMERA"
titleLabel.TextColor3 = Color3.new(1, 1, 1)
titleLabel.TextScaled = true
titleLabel.Font = Enum.Font.SourceSansBold
titleLabel.Parent = mainFrame

leftButton = Instance.new("TextButton")
leftButton.Size = UDim2.new(0, 80, 0, 40)
leftButton.Position = UDim2.new(0, 10, 0, 55)
leftButton.Text = "&lt;"
leftButton.TextScaled = true
leftButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
leftButton.TextColor3 = Color3.new(1, 1, 1)
leftButton.Parent = mainFrame

rightButton = Instance.new("TextButton")
rightButton.Size = UDim2.new(0, 80, 0, 40)
rightButton.Position = UDim2.new(1, -90, 0, 55)
rightButton.Text = "&gt;"
rightButton.TextScaled = true
rightButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
rightButton.TextColor3 = Color3.new(1, 1, 1)
rightButton.Parent = mainFrame

closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0, 40, 0, 40)
closeButton.Position = UDim2.new(1, -50, 0, 10)
closeButton.Text = "X"
closeButton.TextScaled = true
closeButton.BackgroundColor3 = Color3.fromRGB(120, 40, 40)
closeButton.TextColor3 = Color3.new(1, 1, 1)
closeButton.Parent = mainFrame

leftButton.MouseButton1Click:Connect(previousCamera)
rightButton.MouseButton1Click:Connect(nextCamera)
closeButton.MouseButton1Click:Connect(closeMonitor)

openEvent.OnClientEvent:Connect(function()
	if monitorOpen then
		closeMonitor()
	else
		openMonitor()
	end
end)</string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="50">
          <Properties>
            <string name="Name">start</string>
            <string name="Source"><![CDATA[-- FULLSCREEN AUTO-BUILT TITLE SCREEN
-- Just drop this LocalScript into StarterPlayerScripts or StarterGui

-- Rewrite this entire thing

local Players = game:GetService("Players")
local SoundService = game:GetService("SoundService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

---------------------------------------------------------
-- CREATE SCREEN GUI
---------------------------------------------------------
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "TitleScreen"
screenGui.IgnoreGuiInset = true
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

---------------------------------------------------------
-- HELPER: CREATE A CENTERED PANEL
---------------------------------------------------------
local function createPanel(name)
	local frame = Instance.new("Frame")
	frame.Name = name
	frame.Size = UDim2.new(0.5, 0, 0.55, 0)
	frame.Position = UDim2.new(0.5, 0, 0.5, 0)
	frame.AnchorPoint = Vector2.new(0.5, 0.5)
	frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
	frame.BackgroundTransparency = 0.1
	frame.Visible = false
	frame.Parent = screenGui

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 16)
	corner.Parent = frame

	return frame
end

---------------------------------------------------------
-- MAIN MENU PANEL
---------------------------------------------------------
local mainFrame = createPanel("MainFrame")
mainFrame.Visible = true

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 70)
title.Position = UDim2.new(0, 0, 0, 10)
title.BackgroundTransparency = 1
title.Text = "Undercover: Data Compromised"
title.TextColor3 = Color3.new(1, 1, 1)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

local buttonHolder = Instance.new("Frame")
buttonHolder.Size = UDim2.new(1, -40, 0, 160)
buttonHolder.Position = UDim2.new(0.5, 0, 0.45, 0)
buttonHolder.AnchorPoint = Vector2.new(0.5, 0)
buttonHolder.BackgroundTransparency = 1
buttonHolder.Parent = mainFrame

local list = Instance.new("UIListLayout")
list.Padding = UDim.new(0, 10)
list.HorizontalAlignment = Enum.HorizontalAlignment.Center
list.Parent = buttonHolder

local function makeButton(text)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1, 0, 0, 45)
	button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	button.Text = text
	button.TextColor3 = Color3.new(1, 1, 1)
	button.TextScaled = true
	button.Font = Enum.Font.GothamSemibold
	button.Parent = buttonHolder

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = button

	return button
end

local startButton   = makeButton("Start Mission")
local settingsButton = makeButton("Settings")
local helpButton    = makeButton("Help")

---------------------------------------------------------
-- SETTINGS PANEL
---------------------------------------------------------
local settingsFrame = createPanel("SettingsFrame")

local stitle = Instance.new("TextLabel")
stitle.Size = UDim2.new(1, 0, 0, 50)
stitle.Position = UDim2.new(0, 0, 0, 10)
stitle.BackgroundTransparency = 1
stitle.Text = "Settings"
stitle.TextColor3 = Color3.new(1, 1, 1)
stitle.TextScaled = true
stitle.Font = Enum.Font.GothamBold
stitle.Parent = settingsFrame

local function makeVolumeRow(labelText)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(0.85, 0, 0, 50)
	row.BackgroundTransparency = 1
	row.Parent = settingsFrame

	local layout = settingsFrame:FindFirstChild("UIListLayout")
	if not layout then
		layout = Instance.new("UIListLayout")
		layout.Padding = UDim.new(0, 10)
		layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
		layout.VerticalAlignment = Enum.VerticalAlignment.Center
		layout.Parent = settingsFrame
	end

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(0.6, 0, 1, 0)
	lbl.Position = UDim2.new(0, 0, 0, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = labelText .. " (0–100)"
	lbl.TextColor3 = Color3.new(1, 1, 1)
	lbl.TextScaled = true
	lbl.Font = Enum.Font.Gotham
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = row

	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0.35, 0, 1, 0)
	box.Position = UDim2.new(0.65, 0, 0, 0)
	box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	box.Text = "50"
	box.TextScaled = true
	box.Font = Enum.Font.Gotham
	box.TextColor3 = Color3.new(1, 1, 1)
	box.Parent = row

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = box

	return box
end

local masterBox = makeVolumeRow("Master Volume")
local sfxBox = makeVolumeRow("SFX Volume")

local settingsBack = Instance.new("TextButton")
settingsBack.Size = UDim2.new(0.5, 0, 0, 40)
settingsBack.AnchorPoint = Vector2.new(0.5, 1)
settingsBack.Position = UDim2.new(0.5, 0, 0.95, 0)
settingsBack.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
settingsBack.Text = "Back"
settingsBack.TextColor3 = Color3.new(1, 1, 1)
settingsBack.TextScaled = true
settingsBack.Font = Enum.Font.GothamSemibold
settingsBack.Parent = settingsFrame
do
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = settingsBack
end

---------------------------------------------------------
-- HELP PANEL
---------------------------------------------------------
local helpFrame = createPanel("HelpFrame")

local htitle = Instance.new("TextLabel")
htitle.Size = UDim2.new(1, 0, 0, 50)
htitle.Position = UDim2.new(0, 0, 0, 10)
htitle.BackgroundTransparency = 1
htitle.Text = "Mission Briefing"
htitle.TextColor3 = Color3.new(1, 1, 1)
htitle.TextScaled = true
htitle.Font = Enum.Font.GothamBold
htitle.Parent = helpFrame

local body = Instance.new("TextLabel")
body.Size = UDim2.new(0.9, 0, 0.65, 0)
body.Position = UDim2.new(0.5, 0, 0.55, 0)
body.AnchorPoint = Vector2.new(0.5, 0.5)
body.BackgroundTransparency = 1
body.TextColor3 = Color3.new(1, 1, 1)
body.TextWrapped = true
body.TextYAlignment = Enum.TextYAlignment.Top
body.Font = Enum.Font.Gotham
body.Text = [[
You are contacted by an undercover cybersecurity professional.

Their agency is under heavy controversy. Someone inside the organization
is leaking confidential data, repeatedly and intentionally.

Your objectives:
• Identify WHO is leaking the data
• Determine WHAT they leaked
• Figure out HOW they are doing it

Use your in-game tablet to hack systems, analyze logs, and uncover the truth.
]]
body.TextScaled = false
body.TextSize = 18
body.Parent = helpFrame

local helpBack = Instance.new("TextButton")
helpBack.Size = UDim2.new(0.5, 0, 0, 40)
helpBack.AnchorPoint = Vector2.new(0.5, 1)
helpBack.Position = UDim2.new(0.5, 0, 0.95, 0)
helpBack.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
helpBack.Text = "Back"
helpBack.TextColor3 = Color3.new(1, 1, 1)
helpBack.TextScaled = true
helpBack.Font = Enum.Font.GothamSemibold
helpBack.Parent = helpFrame
do
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = helpBack
end

---------------------------------------------------------
-- MENU SWITCHING
---------------------------------------------------------
local function showMain()
	mainFrame.Visible = true
	settingsFrame.Visible = false
	helpFrame.Visible = false
end

local function showSettings()
	mainFrame.Visible = false
	settingsFrame.Visible = true
	helpFrame.Visible = false
end

local function showHelp()
	mainFrame.Visible = false
	settingsFrame.Visible = false
	helpFrame.Visible = true
end

---------------------------------------------------------
-- SOUND CONTROL
---------------------------------------------------------
local function applyVolume()
	local m = tonumber(masterBox.Text) or 50
	local s = tonumber(sfxBox.Text) or 50
	SoundService.Volume = math.clamp(m / 100, 0, 1)
	SoundService:SetAttribute("SFXVolume", math.clamp(s / 100, 0, 1))
end

masterBox.FocusLost:Connect(applyVolume)
sfxBox.FocusLost:Connect(applyVolume)

---------------------------------------------------------
-- CUTSCENE CALL
---------------------------------------------------------
local function startCutscene()
	local evt = ReplicatedStorage:FindFirstChild("StartNewsCutscene")
	if evt then
		evt:FireServer()
	else
		warn("StartNewsCutscene RemoteEvent missing in ReplicatedStorage!")
	end
end

---------------------------------------------------------
-- BUTTON CONNECTIONS
---------------------------------------------------------
startButton.MouseButton1Click:Connect(function()
	screenGui.Enabled = false
	startCutscene()
end)

settingsButton.MouseButton1Click:Connect(showSettings)
helpButton.MouseButton1Click:Connect(showHelp)
settingsBack.MouseButton1Click:Connect(showMain)
helpBack.MouseButton1Click:Connect(showMain)

showMain()
]]></string>
