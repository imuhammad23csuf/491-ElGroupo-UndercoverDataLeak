          <string name="Name">Sound</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")

local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
if not remotesFolder then
	remotesFolder = Instance.new("Folder")
	remotesFolder.Name = "Remotes"
	remotesFolder.Parent = ReplicatedStorage
end

local disclaimerCompletedRemote = remotesFolder:FindFirstChild("DisclaimerCompleted")
if not disclaimerCompletedRemote then
	disclaimerCompletedRemote = Instance.new("RemoteEvent")
	disclaimerCompletedRemote.Name = "DisclaimerCompleted"
	disclaimerCompletedRemote.Parent = remotesFolder
end

local soundtrack = SoundService:FindFirstChild("BackgroundMusic")
if not soundtrack then
	soundtrack = Instance.new("Sound")
	soundtrack.Name = "BackgroundMusic"
	soundtrack.Parent = SoundService
end

soundtrack.SoundId = "rbxassetid://95221077593481"
soundtrack.Volume = 0.35
soundtrack.Looped = true

local soundtrackStarted = soundtrack.IsPlaying

local function startSoundtrack()
	if soundtrackStarted then
		return
	end
	soundtrackStarted = true
	if not soundtrack.IsPlaying then
		soundtrack:Play()
	end
end

disclaimerCompletedRemote.OnServerEvent:Connect(function()
	startSoundtrack()
end)
]]></string>
