BodyLabel.TextYAlignment = Enum.TextYAlignment.Top
BodyLabel.Position = UDim2.fromOffset(0, 66)
BodyLabel.Size = UDim2.new(1, 0, 1, -104)
BodyLabel.Parent = Panel

local HintLabel = Instance.new("TextLabel")
HintLabel.Name = "HintLabel"
HintLabel.AnchorPoint = Vector2.new(1, 1)
HintLabel.BackgroundTransparency = 1
HintLabel.Text = "E / SPACE TO CONTINUE"
HintLabel.TextColor3 = Color3.fromRGB(150, 188, 212)
HintLabel.Font = Enum.Font.GothamSemibold
HintLabel.TextSize = 12
HintLabel.TextXAlignment = Enum.TextXAlignment.Right
HintLabel.Position = UDim2.new(1, 0, 1, 0)
HintLabel.Size = UDim2.new(0.55, 0, 0, 22)
HintLabel.Parent = Panel

local Scale = Instance.new("UIScale")
Scale.Scale = 1
Scale.Parent = Panel

local function clearLegacyAgentDialogueGuis()
	for _, child in ipairs(PlayerGui:GetChildren()) do
		if child ~= Gui and child:IsA("ScreenGui") then
			local name = string.lower(child.Name)
			local isLegacyDialogue = name == "dialoguegui"
				or name == "npcdialoguegui"
				or (string.find(name, "dialogue") and (string.find(name, "agent") or string.find(name, "cafe")))

			if isLegacyDialogue then
				child:Destroy()
			end
		end
	end
end

local function updateScale()
	local camera = workspace.CurrentCamera
	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
	Scale.Scale = math.clamp(viewport.Y / 820, 0.82, 1.05)
end

updateScale()
if workspace.CurrentCamera then
	workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateScale)
end

local function showGui()
	clearLegacyAgentDialogueGuis()
	Gui.Enabled = true
	Shade.BackgroundTransparency = 1
	Panel.BackgroundTransparency = 1
	Panel.Position = UDim2.fromScale(0.5, 1.04)

	TweenService:Create(
		Shade,
		TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 0.48 }
	):Play()
	TweenService:Create(
		Panel,
		TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Position = UDim2.fromScale(0.5, 0.965), BackgroundTransparency = 0.02 }
	):Play()
end

local function hideGui()
	TweenService:Create(
		Shade,
		TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ BackgroundTransparency = 1 }
	):Play()
	local tween = TweenService:Create(
		Panel,
		TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Position = UDim2.fromScale(0.5, 1.04), BackgroundTransparency = 1 }
	)
	tween:Play()
	tween.Completed:Wait()
	Gui.Enabled = false
end

local function typeLine(text)
	isTyping = true
	currentFullText = tostring(text or "")
	BodyLabel.Text = ""

	for index = 1, #currentFullText do
		if not isTyping then
			BodyLabel.Text = currentFullText
			return
		end

		BodyLabel.Text = string.sub(currentFullText, 1, index)
		task.wait(0.014)
	end

	isTyping = false
end

local function completeDialogue()
	local token = activeToken
	activeToken = nil
	activeLines = {}
	currentIndex = 1
	isTyping = false
	hideGui()

	if token then
		DialogueRemote:FireServer("Complete", token)
	end
end

local function showCurrentLine()
	if not activeToken then
		return
	end

	local line = activeLines[currentIndex]
	if line == nil then
		completeDialogue()
		return
	end

	task.spawn(typeLine, line)
end

local function advanceDialogue()
	if not activeToken then
		return
	end

	if isTyping then
		isTyping = false
		BodyLabel.Text = currentFullText
		return
	end

	currentIndex = currentIndex + 1
	showCurrentLine()
end

local function startDialogue(token, lines)
	if activeToken then
		DialogueRemote:FireServer("Cancel", activeToken)
	end

	clearLegacyAgentDialogueGuis()
	activeToken = token
	activeLines = {}
	currentIndex = 1

	if type(lines) == "table" then
		for _, line in ipairs(lines) do
			table.insert(activeLines, tostring(line))
		end
	end

	if #activeLines == 0 then
		table.insert(activeLines, "Special Agent Ray has no briefing available.")
	end

	showGui()
	showCurrentLine()
end

DialogueRemote.OnClientEvent:Connect(function(action, token, lines)
	if action == "Start" then
		startDialogue(token, lines)
	end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed or not activeToken then
		return
	end

	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		advanceDialogue()
		return
	end

	for _, keyCode in ipairs(AdvanceKeys) do
		if input.KeyCode == keyCode then
			advanceDialogue()
			return
		end
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="67">
          <Properties>
            <string name="Name">CaughtOverlay</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local remotesFolder = ReplicatedStorage:WaitForChild("CaughtRemotes")
local showCaughtEvent = remotesFolder:WaitForChild("ShowCaught")
local CAUGHT_SOUND_ID = "rbxassetid://92076037937225"

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "CaughtOverlayGui"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.Enabled = false
screenGui.Parent = playerGui

local background = Instance.new("Frame")
background.Name = "Background"
background.Size = UDim2.fromScale(1, 1)
background.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
background.BackgroundTransparency = 0.35
background.Parent = screenGui

local label = Instance.new("TextLabel")
label.Name = "CaughtLabel"
label.AnchorPoint = Vector2.new(0.5, 0.5)
label.Position = UDim2.fromScale(0.5, 0.5)
label.Size = UDim2.fromScale(0.45, 0.15)
label.BackgroundTransparency = 1
label.Text = "CAUGHT"
label.TextScaled = true
label.Font = Enum.Font.GothamBold
label.TextColor3 = Color3.fromRGB(255, 80, 80)
label.Parent = background

local textConstraint = Instance.new("UITextSizeConstraint")
textConstraint.MaxTextSize = 72
textConstraint.MinTextSize = 24
textConstraint.Parent = label

local subLabel = Instance.new("TextLabel")
subLabel.Name = "CaughtSubLabel"
subLabel.AnchorPoint = Vector2.new(0.5, 0.5)
subLabel.Position = UDim2.fromScale(0.5, 0.6)
subLabel.Size = UDim2.fromScale(0.4, 0.08)
subLabel.BackgroundTransparency = 1
subLabel.Text = "Busted. Rolling the scene back..."
subLabel.TextScaled = true
subLabel.Font = Enum.Font.GothamMedium
subLabel.TextColor3 = Color3.fromRGB(2, 9, 108)
subLabel.Parent = background

local subTextConstraint = Instance.new("UITextSizeConstraint")
subTextConstraint.MaxTextSize = 36
subTextConstraint.MinTextSize = 16
subTextConstraint.Parent = subLabel

local caughtSound = Instance.new("Sound")
caughtSound.Name = "CaughtOverlaySound"
caughtSound.SoundId = CAUGHT_SOUND_ID
caughtSound.Volume = 0.28
caughtSound.Looped = false

-- Chaotic randomness
caughtSound.PlaybackSpeed = math.random(96, 108) / 100

-- Optional: slight time offset for unpredictability
caughtSound.TimePosition = 0

-- Parent it
caughtSound.Parent = SoundService


showCaughtEvent.OnClientEvent:Connect(function(isVisible)
	screenGui.Enabled = isVisible

	if isVisible then
		caughtSound:Stop()
		caughtSound.TimePosition = 0
		caughtSound:Play()
	else
		caughtSound:Stop()
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="68">
          <Properties>
            <string name="Name">EducationalNotification</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")

local notificationEvent = ReplicatedStorage:WaitForChild("ShowEducationalNotification")

local function showNotification(title, message, duration)
	task.spawn(function()
		for _ = 1, 6 do
			local ok = pcall(function()
				StarterGui:SetCore("SendNotification", {
					Title = tostring(title or "SECURITY ALERT"),
					Text = tostring(message or "No details available."),
					Duration = tonumber(duration) or 4,
				})
			end)

			if ok then
				return
			end

			task.wait(0.5)
		end
	end)
end

notificationEvent.OnClientEvent:Connect(showNotification)
]]></string>
