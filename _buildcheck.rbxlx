      <Item class="ModuleScript" referent="7">
        <Properties>
          <string name="Name">IntegrityService</string>
          <string name="Source">local IntegrityService = {}

local integrityScores = {}

function IntegrityService.getIntegrity(player)
	if not player or not player.UserId then
		return 0
	end

	return integrityScores[player.UserId] or 0
end

function IntegrityService.setIntegrity(player, value)
	if not player or not player.UserId then
		return 0
	end

	integrityScores[player.UserId] = value
	return value
end

function IntegrityService.addIntegrity(player, amount)
	if not player or not player.UserId then
		return 0
	end

	local current = IntegrityService.getIntegrity(player)
	local updated = current + amount
	integrityScores[player.UserId] = updated

	return updated
end

function IntegrityService.resetIntegrity(player)
	if not player or not player.UserId then
		return
	end

	integrityScores[player.UserId] = 0
end

return IntegrityService</string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="8">
        <Properties>
          <string name="Name">KeycardCopier</string>
          <string name="Source"><![CDATA[-- Shared fallback for KeycardCopier so tests can run in client or server
local ok, serverMod = pcall(function()
    return require(game.ServerScriptService.Server.KeycardCopier)
end)

if ok and type(serverMod) == "table" then
    return serverMod
end

local KeycardCopier = {}

local function hasOwnedKeycard(player, tool)
    if player == nil or tool == nil then
        return false
    end

    if tool.ClassName ~= "Tool" then
        return false
    end

    local ownerValue = tool:FindFirstChild("OwnerUserId")
    if ownerValue and ownerValue.ClassName == "IntValue" then
        return ownerValue.Value == player.UserId
    end

    return tool.Name == "GhostKey" and tool.Parent == (player.Character)
end

function KeycardCopier.canUnlock(player, tool)
    return hasOwnedKeycard(player, tool)
end

function KeycardCopier.tryUnlock(player, tool, unlockCallback)
    if KeycardCopier.canUnlock(player, tool) then
        if type(unlockCallback) == "function" then
            unlockCallback()
        end
        return true
    end
    return false
end

return KeycardCopier
]]></string>
