        <Item class="LocalScript" referent="74">
          <Properties>
            <string name="Name">MissionTimer</string>
            <string name="Source"><![CDATA[-- MissionTimer.client.luau
-- Original lightweight HUD for the server-authored mission timer.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local remotes = ReplicatedStorage:WaitForChild("MissionTimerRemotes", 15)
if not remotes then
	warn("[MissionTimer] MissionTimerRemotes not found.")
	return
end

local EvStartTimer = remotes:WaitForChild("StartTimer")
local EvStopTimer = remotes:WaitForChild("StopTimer")
local EvNewBestTime = remotes:WaitForChild("NewBestTime")
local FnGetTimerState = remotes:WaitForChild("GetTimerState")

local running = false
local startClock = 0
local displayedElapsed = 0

local function formatTime(seconds)
	seconds = math.max(0, tonumber(seconds) or 0)
	local minutes = math.floor(seconds / 60)
	local wholeSeconds = math.floor(seconds % 60)
	local centiseconds = math.floor((seconds % 1) * 100)
	return ("%02d:%02d.%02d"):format(minutes, wholeSeconds, centiseconds)
end

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "MissionTimerGui"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Name = "TimerFrame"
frame.AnchorPoint = Vector2.new(0.5, 0)
frame.Position = UDim2.new(0.5, 0, 0, 18)
frame.Size = UDim2.new(0, 220, 0, 46)
frame.BackgroundColor3 = Color3.fromRGB(10, 10, 18)
frame.BackgroundTransparency = 0.12
frame.BorderSizePixel = 0
frame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(20, 100, 200)
stroke.Thickness = 1.5
stroke.Transparency = 0.35
stroke.Parent = frame

local title = Instance.new("TextLabel")
title.Name = "Title"
title.Position = UDim2.new(0, 12, 0, 5)
title.Size = UDim2.new(1, -24, 0, 14)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.Text = "MISSION TIMER"
title.TextColor3 = Color3.fromRGB(180, 205, 255)
title.TextSize = 11
title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = frame

local timeLabel = Instance.new("TextLabel")
timeLabel.Name = "TimeLabel"
timeLabel.Position = UDim2.new(0, 12, 0, 17)
timeLabel.Size = UDim2.new(1, -24, 0, 24)
timeLabel.BackgroundTransparency = 1
timeLabel.Font = Enum.Font.GothamBlack
timeLabel.Text = formatTime(0)
timeLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
timeLabel.TextSize = 22
timeLabel.TextXAlignment = Enum.TextXAlignment.Left
timeLabel.Parent = frame

local function setElapsed(seconds)
	displayedElapsed = math.max(0, tonumber(seconds) or 0)
	timeLabel.Text = formatTime(displayedElapsed)
end

local function startTimer(initialElapsed)
	local elapsed = math.max(0, tonumber(initialElapsed) or 0)
	running = true
	startClock = os.clock() - elapsed
	setElapsed(elapsed)
end

local function stopTimer(elapsed, outcome)
	running = false

	if outcome == "caught" or outcome == "reset" then
		setElapsed(0)
	else
		setElapsed(elapsed)
	end
end

EvStartTimer.OnClientEvent:Connect(function(initialElapsed)
	startTimer(initialElapsed)
end)

EvStopTimer.OnClientEvent:Connect(stopTimer)

EvNewBestTime.OnClientEvent:Connect(function(newBest)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = "Mission Timer",
			Text = "New best time: " .. formatTime(newBest),
			Duration = 4,
		})
	end)
end)

RunService.RenderStepped:Connect(function()
	if running then
		setElapsed(os.clock() - startClock)
	end
end)

task.spawn(function()
	local ok, state = pcall(function()
		return FnGetTimerState:InvokeServer()
	end)

	if ok and type(state) == "table" then
		if state.running then
			startTimer(state.elapsed)
		else
			stopTimer(state.elapsed, "reset")
		end
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="75">
          <Properties>
            <string name="Name">NarrativeClient</string>
            <string name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local remotesFolder = ReplicatedStorage:WaitForChild("NarrativeRemotes")
local chooseOptionEvent = remotesFolder:WaitForChild("ChooseOption")
local dialogueUpdateEvent = remotesFolder:WaitForChild("DialogueUpdate")

local function displayNode(nodeData)
	if type(nodeData) ~= "table" then
		return
	end

	if nodeData.error then
		warn("Narrative error:", nodeData.error)
		return
	end

	print("----- DIALOGUE UPDATE -----")
	print("Node:", nodeData.nodeId or "none")
	print("Text:", nodeData.text or "none")

	if nodeData.choices and #nodeData.choices > 0 then
		for index, choice in ipairs(nodeData.choices) do
			print(index .. ". " .. choice.text)
		end
	else
		print("No choices available.")
	end

	if nodeData.isEnd then
		print("Dialogue ended.")
	end
end

dialogueUpdateEvent.OnClientEvent:Connect(displayNode)

-- chooseOptionEvent is kept so dialogue UI can hook into it later.
local _unusedChooseOptionEvent = chooseOptionEvent
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="76">
          <Properties>
            <string name="Name">NewsCutsceneClient</string>
            <string name="Source"><![CDATA[-- StarterPlayerScripts/NewsCutsceneClient (LocalScript)

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local StartEvent = ReplicatedStorage:WaitForChild("StartNewsCutscene")
local CompleteEvent = ReplicatedStorage:WaitForChild("NewsCutsceneFinished", 10)
local Shared = ReplicatedStorage:WaitForChild("Shared")

local ok, Cutscene = pcall(function()
	return require(Shared:WaitForChild("NewsCutscene"))
end)

if not ok or type(Cutscene) ~= "table" or type(Cutscene.Play) ~= "function" then
	warn("[NewsCutsceneClient] NewsCutscene module missing/invalid.")
	return
end

local playing = false
local STARTED_ATTRIBUTE = "NewsCutsceneStarted"
local COMPLETED_ATTRIBUTE = "NewsCutsceneCompleted"

StartEvent.OnClientEvent:Connect(function(payload)
	if playing then return end
	if player:GetAttribute(COMPLETED_ATTRIBUTE) == true then return end
	if not payload or not payload.headlines then
		warn("[NewsCutsceneClient] Missing payload/headlines.")
		return
	end

	playing = true
	player:SetAttribute(STARTED_ATTRIBUTE, true)
	local okPlay, playErr = pcall(function()
		Cutscene.Play(player, payload)
	end)
	if not okPlay then
		warn("[NewsCutsceneClient] News cutscene failed: " .. tostring(playErr))
	end
	player:SetAttribute(COMPLETED_ATTRIBUTE, true)
	if CompleteEvent and CompleteEvent:IsA("RemoteEvent") then
		CompleteEvent:FireServer()
	end
	playing = false
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="77">
          <Properties>
            <string name="Name">PhoneCutscene</string>
            <string name="Source"><![CDATA[-- Phone cutscene: conversation between the agent and player.

local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local ContextActionService = game:GetService("ContextActionService")

local Player = Players.LocalPlayer
local PlayerName = Player.Name
local PlayerGui = Player:WaitForChild("PlayerGui")
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local Camera = Workspace.CurrentCamera

local TypingSpeed = 0.018
local FadeUI = 0.2
local PHONE_CALL_REMOTE_NAME = "PhoneCallRequested"
local PHONE_INTRO_COMPLETED_ATTRIBUTE = "PhoneIntroCallCompleted"
local AdvanceKeys = { Enum.KeyCode.E, Enum.KeyCode.Space, Enum.KeyCode.Return, Enum.KeyCode.ButtonA }
local INTRO_COMPLETE_ATTRIBUTES = {
	PHONE_INTRO_COMPLETED_ATTRIBUTE,
	"HasSpokenToAgentRay",
	"AgentRayToolsReceived",
	"AgentRayDialogueSeen",
}

local NewsReady = false
local maybeStartRinging

local function updateNewsReady()
	NewsReady = Player:GetAttribute("NewsCutsceneCompleted") == true
end

updateNewsReady()

Player:GetAttributeChangedSignal("NewsCutsceneCompleted"):Connect(function()
	updateNewsReady()
	if NewsReady and maybeStartRinging then
		maybeStartRinging()
	end
end)

local function hasNewsFinished()
	return NewsReady
end

local function hasPhoneIntroFinished()
	for _, attributeName in ipairs(INTRO_COMPLETE_ATTRIBUTES) do
		if Player:GetAttribute(attributeName) == true then
			return true
		end
	end

	return false
end

local function shouldPhoneIntroPlay()
	return hasNewsFinished() and not hasPhoneIntroFinished()
end

local SpawnCF
local function captureSpawnCF(char)
	local hrp = char:WaitForChild("HumanoidRootPart", 5)
	if hrp then
		SpawnCF = hrp.CFrame
	end
end

captureSpawnCF(Character)

Player.CharacterAdded:Connect(function(char)
	Character = char
	Humanoid = char:WaitForChild("Humanoid")
	captureSpawnCF(char)
end)

local Conversation = {
	{ speaker = "Unknown Caller", text = "Hello. Am I speaking with " .. PlayerName .. "?" },
	{ speaker = PlayerName, text = "This is " .. PlayerName .. ". Identify yourself." },
	{ speaker = "Special Agent Ray", text = "This is Special Agent Ray. I am coordinating a federal inquiry into Bloxplay involving internal policy violations and possible exposure of sensitive material." },
	{ speaker = PlayerName, text = "Understood. What is my objective?" },
	{ speaker = "Special Agent Ray", text = "Meet me at the Cafe to get these tools. Once you have them, investigate discreetly and document any evidence you find." },
	{ speaker = "Special Agent Ray", text = "If security identifies you, the operation is compromised. Keep a low profile and move deliberately." },
	{ speaker = PlayerName, text = "Copy that. I will meet you at the Cafe before moving on the objective." },
	{ speaker = "Special Agent Ray", text = "Good. Maintain radio silence unless the channel is clear. You have two days before the situation escalates beyond containment." },
	{ speaker = PlayerName, text = "Acknowledged. Beginning the investigation." },
}

