Name = "IPBlockerStatus",
BackgroundTransparency = 1,
Text = "Enter a hostile source from the investigation feed.",
Font = Enum.Font.Gotham,
TextSize = 11,
TextColor3 = Color3.fromRGB(88, 98, 114),
TextXAlignment = Enum.TextXAlignment.Left,
Position = UDim2.new(0, 10, 0, 98),
Size = UDim2.new(1, -20, 0, 16),
})
local ipBlockerHistoryFrame = mk("ScrollingFrame", {
Parent = ipBlockerPage,
Name = "IPBlockerHistoryFrame",
BackgroundColor3 = Color3.fromRGB(238, 242, 248),
BorderSizePixel = 0,
ScrollBarThickness = 6,
Position = UDim2.new(0, 10, 0, 120),
Size = UDim2.new(1, -20, 1, -128),
})
round(ipBlockerHistoryFrame, 8)
mk("UIListLayout", {
Parent = ipBlockerHistoryFrame,
Name = "UIListLayout",
Padding = UDim.new(0, 6),
SortOrder = Enum.SortOrder.LayoutOrder,
})
goBtn.MouseButton1Click:Connect(function()
navigateTo(UrlBox.Text)
end)
local function tryAdminLogin()
local u = tostring((AdminUserBox.Text or ""):lower())
local p = tostring(AdminPassBox:GetAttribute("RealPassword") or "")
if u == "bloxplay-admin" and p == "blox123" then
local result = submitScenarioAction("browser_admin_login bloxplay.com/admin", { "ch2_admin_login" })
getBrowserState().adminLoggedIn = true
getBrowserState().adminTab = "database"
AdminLoginStatus.Text = "Login successful (sim)"
AdminPassBox.Text = ""
AdminPassBox:SetAttribute("RealPassword", "")
navigateTo("bloxplay.com/admin")
if result and result.success then
setBrowserStatus("Admin login accepted. Mission step complete.")
end
else
AdminLoginStatus.Text = "Access denied (sim)"
AdminPassBox.Text = ""
AdminPassBox:SetAttribute("RealPassword", "")
end
end
adminLoginBtn.MouseButton1Click:Connect(tryAdminLogin)
adminDatabaseTabBtn.MouseButton1Click:Connect(function()
getBrowserState().adminTab = "database"
showAdminDashboard("bloxplay.com/admin")
setBrowserStatus("Database records open (sim).")
end)
adminLogsTabBtn.MouseButton1Click:Connect(function()
local result = submitScenarioAction("browser_admin_tab logs", { "ch3_admin_logs" })
getBrowserState().adminTab = "logs"
getBrowserState().logsLastRender = 0
showAdminDashboard("bloxplay.com/admin")
if result and result.success then
setBrowserStatus("Security logs opened. Mission step complete.")
else
setBrowserStatus("Security logs open (live feed).")
end
end)
AdminSearchBox:GetPropertyChangedSignal("Text"):Connect(function()
if getBrowserState().adminTab ~= "logs" then
renderAdminResults(AdminSearchBox.Text)
end
end)
ipBlockerBlockBtn.MouseButton1Click:Connect(function()
local ip = tostring(ipBlockerInputBox.Text or ""):gsub("^%s+", ""):gsub("%s+$", "")
if ip == "" then
ipBlockerStatus.Text = "Enter a hostile source first."
setBrowserStatus("RBXIPBlocker needs a source IP.")
return
end
local alreadyBlocked = false
if type(getBrowserState().blockedIPs) ~= "table" then
getBrowserState().blockedIPs = {}
end
for _, existing in ipairs(getBrowserState().blockedIPs) do
if existing == ip then
alreadyBlocked = true
break
end
end
if not alreadyBlocked then
table.insert(getBrowserState().blockedIPs, ip)
table.sort(getBrowserState().blockedIPs)
end
renderIPBlockerHistory()
local result = submitScenarioAction(("browser_ipblocker_block %s"):format(ip), { "ch4_block_source" })
ipBlockerInputBox.Text = ""
ipBlockerStatus.Text = alreadyBlocked and ("Source %s was already blocked."):format(ip) or (("Source %s blocked (sim)."):format(ip))
if result and result.success then
if ip == WANNAWAIL_ATTACKER_IP then
if getBrowserState()._markWannaWailFlag then
		getBrowserState()._markWannaWailFlag(WANNAWAIL_ATTR_SOURCE_BLOCKED, true)
	end
end
setBrowserStatus(("RBXIPBlocker blocked %s. Mission step complete."):format(ip))
else
setBrowserStatus(("RBXIPBlocker blocked %s (sim)"):format(ip))
end
end)
PacketApplyBtn.MouseButton1Click:Connect(function()
local ip = tostring(PacketIPBox.Text or ""):gsub("^%s+", ""):gsub("%s+$", "")
local result = submitScenarioAction(("browser_capture %s"):format(ip ~= "" and ip or "unknown"), { "ch1_packets" })
if startPacketCaptureForIP(ip) then
populatePacketRows()
local host = getHostByIP(ip)
if result and result.success then
setBrowserStatus(("Capture verified for %s [%s]. Mission step complete."):format(host.label, host.ip))
else
setBrowserStatus(("Capturing packets for %s [%s] (authorized sim)"):format(host.label, host.ip))
end
else
populatePacketRows()
setBrowserStatus("Unknown IP. No simulated capture available.")
end
end)
PacketClearBtn.MouseButton1Click:Connect(function()
if PacketIPBox then PacketIPBox.Text = "" end
if PacketDNSBox then PacketDNSBox.Text = "" end
ActivePacketCapture.targetIP = ""
ActivePacketCapture.targetLabel = ""
ActivePacketCapture.rows = {}
populatePacketRows()
setBrowserStatus("RBXPacketAnalyzer filters cleared (sim)")
end)
PacketFollowBtn.MouseButton1Click:Connect(function()
if PacketIPBox.Text == "" then
PacketIPBox.Text = "192.168.32.12"
end
startPacketCaptureForIP(PacketIPBox.Text)
if PacketDNSBox.Text == "" then
PacketDNSBox.Text = "admin"
end
populatePacketRows()
setBrowserStatus("Following simulated traffic stream.")
end)
UIS.InputBegan:Connect(function(input, gameProcessed)
	if MainGUI and MainGUI.Enabled then
		getBrowserState()._markInteraction()
	end
if gameProcessed then return end
if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
if input.KeyCode == Enum.KeyCode.Up then
local focused = nil
pcall(function() focused = UIS:GetFocusedTextBox() end)
if focused == TermInput then
historyUp()
end
return
elseif input.KeyCode == Enum.KeyCode.Down then
local focused = nil
pcall(function() focused = UIS:GetFocusedTextBox() end)
if focused == TermInput then
historyDown()
end
return
end
if input.KeyCode ~= Enum.KeyCode.Return and input.KeyCode ~= Enum.KeyCode.KeypadEnter then
return
end
local focused = nil
pcall(function() focused = UIS:GetFocusedTextBox() end)
if focused == UrlBox then
navigateTo(UrlBox.Text)
elseif focused == AdminPassBox or focused == AdminUserBox then
if AdminLoginPage and AdminLoginPage.Visible then
tryAdminLogin()
end
elseif focused == PacketIPBox or focused == PacketDNSBox then
if PacketPage and PacketPage.Visible then
if PacketIPBox.Text ~= "" then
startPacketCaptureForIP(PacketIPBox.Text)
end
populatePacketRows()
end
end
end)
UrlBox.FocusLost:Connect(function(enterPressed)
	if MainGUI and MainGUI.Enabled then
		getBrowserState()._markInteraction()
	end
if enterPressed then
navigateTo(UrlBox.Text)
end
end)
local function canRefocusTerminal()
if not (MainGUI and MainGUI.Enabled) then return false end
if not (TermFrame and TermFrame.Visible) then return false end
if not (TermInput and TermInput.Parent) then return false end
if not (isToolEquipped() and ctx.isStarted()) then return false end
local focused = nil
pcall(function() focused = UIS:GetFocusedTextBox() end)
return focused == nil or focused == TermInput
end
TermInput:GetPropertyChangedSignal("Text"):Connect(function()
if onTerminalTextChanged then
onTerminalTextChanged(TermInput.Text)
end
end)
TermInput.FocusLost:Connect(function(enter)
	if MainGUI and MainGUI.Enabled then
		getBrowserState()._markInteraction()
	end
if enter then
local c = TermInput.Text
TermInput.Text = ""
pushHistory(c)
handle(c)
end
task.defer(function()
if canRefocusTerminal() then
TermInput:CaptureFocus()
end
end)
end)
bTerm.MouseButton1Click:Connect(function()
setVisiblePanel("terminal")
end)
bBrowser.MouseButton1Click:Connect(function()
setVisiblePanel("browser")
end)
bMissions.MouseButton1Click:Connect(function()
setVisiblePanel("missions", { navigate = false, captureFocus = false })
end)
bJam.MouseButton1Click:Connect(function()
requestCameraJamFromTablet({ echoTerminal = TermFrame and TermFrame.Visible })
end)
bDistract.MouseButton1Click:Connect(function()
if requestGuardDistractFromTablet then
requestGuardDistractFromTablet({ echoTerminal = TermFrame and TermFrame.Visible })
end
end)
bSave.MouseButton1Click:Connect(function()
getBrowserState()._markInteraction()
saveNow({ force = true })
end)
task.defer(function()
if getBrowserState()._renderMailPage then
getBrowserState()._renderMailPage()
end
end)
return {
MainGUI = MainGUI,
TermFrame = TermFrame,
BrowserFrame = BrowserFrame,
TermOut = TermOut,
TermInput = TermInput,
UrlBox = UrlBox,
PageLabel = PageLabel,
ClockLabel = ClockLabel,
MissionsFrame = MissionsFrame,
MissionsList = MissionsList,
ObjectivesList = ObjectivesList,
BrowserStatusLabel = BrowserStatusLabel,
BrowserContent = BrowserContent,
LinkBar = LinkBar,
AdminLoginPage = AdminLoginPage,
AdminDashboardPage = AdminDashboardPage,
AdminUserBox = AdminUserBox,
AdminPassBox = AdminPassBox,
AdminLoginStatus = AdminLoginStatus,
AdminSearchBox = AdminSearchBox,
AdminResultsFrame = AdminResultsFrame,
PacketPage = PacketPage,
PacketToolbar = PacketToolbar,
PacketListFrame = PacketListFrame,
PacketIPBox = PacketIPBox,
PacketDNSBox = PacketDNSBox,
PacketApplyBtn = PacketApplyBtn,
PacketClearBtn = PacketClearBtn,
PacketFollowBtn = PacketFollowBtn,
}
end

return buildMainUI()
end

return TabletMainUI
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="83">
          <Properties>
            <string name="Name">TabletMissionUI</string>
            <string name="Source"><![CDATA[local TabletMissionUI = {}

local TextService = game:GetService("TextService")

local function clearRenderedFrames(parent)
    for _, child in ipairs(parent:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then
            child:Destroy()
        end
    end
end

local function addStrikeThrough(mk, target, color)
    mk("Frame", {
        Parent = target,
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 0.5, -1),
    })
end

local function measureWrappedHeight(text, font, textSize, width, minHeight)
    local safeWidth = math.max(40, math.floor(width or 40))
    local ok, bounds = pcall(function()
        return TextService:GetTextSize(tostring(text or ""), textSize, font, Vector2.new(safeWidth, 4096))
    end)
    local height = ok and bounds.Y or textSize
    return math.max(minHeight or 0, height)
end

local function getUsableWidth(guiObject, fallback)
    local width = 0
    if guiObject then
        width = guiObject.AbsoluteSize.X
    end
    if width <= 0 then
        width = fallback or 340
    end
    return width
end

local function refreshAncestorScroller(guiObject)
    local function applyLayoutSize(target)
        if not target then
            return
        end
        local layout = target:FindFirstChild("UIListLayout")
        if not layout or not layout:IsA("UIListLayout") then
            return
        end
        local paddingTop = 0
        local paddingBottom = 0
        local padding = target:FindFirstChildOfClass("UIPadding")
        if padding then
            paddingTop = padding.PaddingTop.Offset
            paddingBottom = padding.PaddingBottom.Offset
        end
        local height = layout.AbsoluteContentSize.Y + paddingTop + paddingBottom
        if target:IsA("ScrollingFrame") then
            target.CanvasSize = UDim2.new(0, 0, 0, height)
        else
            target.Size = UDim2.new(target.Size.X.Scale, target.Size.X.Offset, 0, height)
        end
    end

    local function update()
        applyLayoutSize(guiObject)
        local node = guiObject
        while node do
            if node:IsA("ScrollingFrame") then
                applyLayoutSize(node)
                break
            end
            node = node.Parent
        end
    end

    task.defer(function()
        update()
        task.defer(update)
        task.delay(0.03, update)
    end)
end

local function createStatusPill(mk, parent, text, color, props)
    local data = {
        Parent = parent,
        BackgroundColor3 = Color3.fromRGB(13, 16, 24),
        BorderSizePixel = 0,
        Text = string.upper(tostring(text or "")),
        Font = Enum.Font.GothamBold,
        TextSize = 8,
        TextColor3 = color,
        AutomaticSize = Enum.AutomaticSize.XY,
    }
    for key, value in pairs(props or {}) do
        data[key] = value
    end
    local pill = mk("TextLabel", data)
    mk("UIPadding", {
        Parent = pill,
        PaddingLeft = UDim.new(0, 8),
        PaddingRight = UDim.new(0, 8),
        PaddingTop = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 4),
    })
    return pill
end

function TabletMissionUI.renderMissionCards(missionsList, objectivesList, mk, round)
    if not missionsList then
        return
    end

    objectivesList = type(objectivesList) == "table" and objectivesList or {}
    clearRenderedFrames(missionsList)

    local listWidth = getUsableWidth(missionsList, 360)
    local cardWidthOffset = 4
    local cardInnerWidth = math.max(120, listWidth - cardWidthOffset - 20)

    for _, taskInfo in ipairs(objectivesList) do
        local isCompleted = taskInfo.status == "Completed"
        local titleColor = isCompleted and Color3.fromRGB(160, 160, 160) or Color3.new(1, 1, 1)
        local statusColor = Color3.fromRGB(150, 150, 150)
        if taskInfo.status == "Completed" then
            statusColor = Color3.fromRGB(0, 255, 100)
        elseif taskInfo.status == "In Progress" then
            statusColor = Color3.fromRGB(255, 200, 0)
        elseif taskInfo.status == "Locked" then
            statusColor = Color3.fromRGB(140, 140, 140)
        end

        local labelHeight = measureWrappedHeight(taskInfo.text, Enum.Font.GothamSemibold, 10, cardInnerWidth, 14)
        local statusY = 8 + labelHeight + 8
        local cardHeight = math.max(54, statusY + 24)

        local taskRow = mk("Frame", {
            Parent = missionsList,
            BackgroundColor3 = Color3.fromRGB(20, 26, 38),
            BorderSizePixel = 0,
            Size = UDim2.new(1, -cardWidthOffset, 0, cardHeight),
            ClipsDescendants = true,
        })
        round(taskRow, 8)

        local label = mk("TextLabel", {
            Parent = taskRow,
            BackgroundTransparency = 1,
            Text = tostring(taskInfo.text or ""),
            Font = Enum.Font.GothamSemibold,
            TextSize = 10,
            TextColor3 = titleColor,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
            TextWrapped = true,
            TextTruncate = Enum.TextTruncate.None,
            Position = UDim2.new(0, 10, 0, 8),
            Size = UDim2.new(1, -20, 0, labelHeight),
        })
        if isCompleted then
            addStrikeThrough(mk, label, Color3.fromRGB(160, 160, 160))
        end

        local pill = createStatusPill(mk, taskRow, tostring(taskInfo.status or ""), statusColor, {
            Position = UDim2.new(0, 10, 0, statusY),
        })
        round(pill, 999)
    end

    refreshAncestorScroller(missionsList)
end

function TabletMissionUI.getObjectiveStatusText(status)
    if status == "Locked" then
        return "Locked"
    elseif status == "Completed" then
        return "Completed"
    elseif status == "In Progress" then
        return "In Progress"
    end
    return "Unlocked"
end

function TabletMissionUI.getObjectiveStatusColor(status)
    if status == "Locked" then
        return Color3.fromRGB(140, 140, 140)
    elseif status == "Completed" then
        return Color3.fromRGB(0, 255, 100)
    elseif status == "In Progress" then
        return Color3.fromRGB(255, 200, 0)
    end
    return Color3.new(1, 1, 1)
end

function TabletMissionUI.normalizeChapterObjectives(rawObjectives)
    if type(rawObjectives) ~= "table" or #rawObjectives == 0 then
        return {}
    end

    local normalized = {}
    for _, chapter in ipairs(rawObjectives) do
        if type(chapter) == "table" and chapter.title then
            table.insert(normalized, chapter)
        end
    end
    return normalized
end

function TabletMissionUI.renderObjectiveCards(objectivesListGui, objectivesList, chapterExpanded, mk, round, onStartChapter, onToggleChapter)
    if not objectivesListGui then
        return
    end

    objectivesList = TabletMissionUI.normalizeChapterObjectives(objectivesList)
    clearRenderedFrames(objectivesListGui)

    local listWidth = getUsableWidth(objectivesListGui, 360)
    local cardWidthOffset = 4
    local cardInnerWidth = math.max(140, listWidth - cardWidthOffset - 20)

    for _, chapter in ipairs(objectivesList) do
        local chapterCompleted = chapter.status == "Completed"
        local canStart = chapter.status == "Not Started" and chapter.unlocked
        local expanded = chapterExpanded[chapter.id] == true
        local titleColor = chapterCompleted and Color3.fromRGB(160, 160, 160) or Color3.new(1, 1, 1)
        local titleHeight = measureWrappedHeight(chapter.title, Enum.Font.GothamSemibold, 10, cardInnerWidth - 18, 14)
        local metaY = 10 + titleHeight + 8
        local headerHeight = metaY + 22
        local totalHeight = headerHeight + 20

        local stepHeights = {}
        if expanded and type(chapter.steps) == "table" and #chapter.steps > 0 then
            for _, step in ipairs(chapter.steps) do
                local stepTextHeight = measureWrappedHeight(step.text, Enum.Font.Gotham, 9, cardInnerWidth - 16, 13)
                local stepStatusY = 8 + stepTextHeight + 6
                local stepHeight = math.max(48, stepStatusY + 22)
                table.insert(stepHeights, stepHeight)
                totalHeight = totalHeight + stepHeight + 6
            end
            totalHeight = totalHeight + 2
        end

        local card = mk("Frame", {
            Parent = objectivesListGui,
            BackgroundColor3 = Color3.fromRGB(20, 26, 38),
            BorderSizePixel = 0,
            Size = UDim2.new(1, -cardWidthOffset, 0, totalHeight),
            ClipsDescendants = true,
        })
        round(card, 10)

        local header = mk("TextButton", {
            Parent = card,
            BackgroundTransparency = 1,
            AutoButtonColor = false,
            Text = "",
            Position = UDim2.new(0, 10, 0, 10),
            Size = UDim2.new(1, -20, 0, headerHeight),
        })

        mk("TextLabel", {
            Parent = header,
            BackgroundTransparency = 1,
            Text = expanded and "v" or ">",
            Font = Enum.Font.GothamBold,
            TextSize = 12,
            TextColor3 = Color3.fromRGB(180, 180, 180),
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.fromOffset(14, 14),
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
        })

        local titleLabel = mk("TextLabel", {
            Parent = header,
            BackgroundTransparency = 1,
            Text = tostring(chapter.title or ""),
            Font = Enum.Font.GothamSemibold,
            TextSize = 10,
            TextColor3 = titleColor,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
            TextWrapped = true,
            TextTruncate = Enum.TextTruncate.None,
            Position = UDim2.new(0, 18, 0, 0),
            Size = UDim2.new(1, -18, 0, titleHeight),
        })
        if chapterCompleted then
            addStrikeThrough(mk, titleLabel, Color3.fromRGB(160, 160, 160))
        end

        local statusPill = createStatusPill(mk, header, TabletMissionUI.getObjectiveStatusText(chapter.status), TabletMissionUI.getObjectiveStatusColor(chapter.status), {
            Position = UDim2.new(0, 0, 0, metaY),
        })
        round(statusPill, 999)

        if canStart then
            local startBtn = mk("TextButton", {
                Parent = header,
                Text = "START",
                Font = Enum.Font.GothamBold,
                TextSize = 8,
                TextColor3 = Color3.new(1, 1, 1),
                BackgroundColor3 = Color3.fromRGB(79, 131, 255),
                BorderSizePixel = 0,
                Size = UDim2.fromOffset(56, 20),
                Position = UDim2.new(1, -56, 0, metaY - 1),
            })
            round(startBtn, 999)
            startBtn.MouseButton1Click:Connect(function()
                if onStartChapter then
                    onStartChapter(chapter)
                end
            end)
        end

        header.MouseButton1Click:Connect(function()
            if onToggleChapter then
                onToggleChapter(chapter)
            end
        end)

        if expanded and type(chapter.steps) == "table" and #chapter.steps > 0 then
            local y = headerHeight + 18
            for index, step in ipairs(chapter.steps) do
                local stepHeight = stepHeights[index]
                local stepCompleted = step.status == "Completed"
                local stepTextColor = stepCompleted and Color3.fromRGB(160, 160, 160) or Color3.new(1, 1, 1)
                local stepTextHeight = measureWrappedHeight(step.text, Enum.Font.Gotham, 9, cardInnerWidth - 16, 13)
                local stepStatusY = 8 + stepTextHeight + 6

                local stepCard = mk("Frame", {
                    Parent = card,
                    BackgroundColor3 = Color3.fromRGB(13, 16, 24),
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 10, 0, y),
                    Size = UDim2.new(1, -20, 0, stepHeight),
                    ClipsDescendants = true,
                })
                round(stepCard, 8)

                local stepLabel = mk("TextLabel", {
                    Parent = stepCard,
                    BackgroundTransparency = 1,
                    Text = tostring(step.text or ""),
                    Font = Enum.Font.Gotham,
                    TextSize = 9,
                    TextColor3 = stepTextColor,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                    TextWrapped = true,
                    TextTruncate = Enum.TextTruncate.None,
                    Position = UDim2.new(0, 8, 0, 8),
                    Size = UDim2.new(1, -16, 0, stepTextHeight),
                })
                if stepCompleted then
                    addStrikeThrough(mk, stepLabel, Color3.fromRGB(160, 160, 160))
                end

                local pill = createStatusPill(mk, stepCard, TabletMissionUI.getObjectiveStatusText(step.status), TabletMissionUI.getObjectiveStatusColor(step.status), {
                    Position = UDim2.new(0, 8, 0, stepStatusY),
                })
                round(pill, 999)

                y = y + stepHeight + 6
            end
        end
    end

    refreshAncestorScroller(objectivesListGui)
end

return TabletMissionUI
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="84">
          <Properties>
            <string name="Name">TabletSimOps</string>
            <string name="Source"><![CDATA[local TabletSimOps = {}

function TabletSimOps.install(ctx)
local browserState = ctx.browserState
local terminalState = ctx.terminalState
local ActivePacketCapture = ctx.ActivePacketCapture
local OpenFiles = ctx.OpenFiles
local Player = ctx.Player
local addLine = ctx.addLine
local getRemote = ctx.getRemote
local CAMERA_JAM_REMOTE_NAME = ctx.CAMERA_JAM_REMOTE_NAME
local WANNAWAIL_ATTR_SOURCE_BLOCKED = ctx.WANNAWAIL_ATTR_SOURCE_BLOCKED
local WANNAWAIL_ATTR_FIREWALL_BLOCKED = ctx.WANNAWAIL_ATTR_FIREWALL_BLOCKED
local WANNAWAIL_ATTR_PROCESS_KILLED = ctx.WANNAWAIL_ATTR_PROCESS_KILLED
local WANNAWAIL_ATTR_LOADER_REMOVED = ctx.WANNAWAIL_ATTR_LOADER_REMOVED
local WANNAWAIL_ATTR_CONTAINED = ctx.WANNAWAIL_ATTR_CONTAINED
local WANNAWAIL_ATTACKER_IP = ctx.WANNAWAIL_ATTACKER_IP
local SimFSByHost = ctx.SimFSByHost
local SimFileContentsByHost = ctx.SimFileContentsByHost
local SimMetadataByHost = ctx.SimMetadataByHost
local SimProcessesByHost = ctx.SimProcessesByHost
local getAllHostsList = ctx.getAllHostsList
local getHostByIP = ctx.getHostByIP
local startPacketCaptureForIP = ctx.startPacketCaptureForIP
local setBrowserStatus = ctx.setBrowserStatus

local simOps = browserState._simOps or {}
browserState._simOps = simOps

local function getHostKey()
if terminalState.currentHost == "PlayerData_Vault" then
return "playerdata_vault"
end
return terminalState.currentHost == "local" and "localhost" or "localhost"
end
local function getFS()
local host = getHostKey()
return SimFSByHost[host] or SimFSByHost.localhost
end
local function getContents()
    local host = getHostKey()
    return SimFileContentsByHost[host] or SimFileContentsByHost.localhost
end
local function getMetadata()
    local host = getHostKey()
    return SimMetadataByHost[host] or SimMetadataByHost.localhost
end
local function getProcesses()
    local host = getHostKey()
    return SimProcessesByHost[host] or SimProcessesByHost.localhost
end
local function refreshWannaWailContainmentState()
local sourceBlocked = Player:GetAttribute(WANNAWAIL_ATTR_SOURCE_BLOCKED) == true
local firewallBlocked = Player:GetAttribute(WANNAWAIL_ATTR_FIREWALL_BLOCKED) == true
local processKilled = Player:GetAttribute(WANNAWAIL_ATTR_PROCESS_KILLED) == true
local loaderRemoved = Player:GetAttribute(WANNAWAIL_ATTR_LOADER_REMOVED) == true
Player:SetAttribute(WANNAWAIL_ATTR_CONTAINED, sourceBlocked and firewallBlocked and processKilled and loaderRemoved)
end
local function markWannaWailFlag(attributeName, value)
Player:SetAttribute(attributeName, value == true)
refreshWannaWailContainmentState()
end
local function splitPath(path)
    local parts = {}
    for part in tostring(path or ""):gmatch("[^/]+") do
        parts[#parts + 1] = part
    end
    return parts
end
local function pathJoin(base, name)
    if base == "/" then
        return "/" .. tostring(name or "")
    end
    return tostring(base or "/") .. "/" .. tostring(name or "")
end
local function pathParent(path)
    local resolved = tostring(path or "/")
    if resolved == "/" then
        return nil
    end
    local parts = splitPath(resolved)
    table.remove(parts)
    if #parts == 0 then
        return "/"
    end
    return "/" .. table.concat(parts, "/")
end
local function normalizePath(path)
    local raw = tostring(path or ""):gsub("^%s+", ""):gsub("%s+$", "")
    if raw == "" then
        return terminalState.currentDir
    end
    local parts = {}
    if raw:sub(1, 1) ~= "/" then
        for _, part in ipairs(splitPath(terminalState.currentDir)) do
            parts[#parts + 1] = part
        end
    end
    for _, part in ipairs(splitPath(raw)) do
        if part == "." or part == "" then
        elseif part == ".." then
            if #parts > 0 then
                table.remove(parts)
            end
        else
            parts[#parts + 1] = part
        end
    end
    if #parts == 0 then
        return "/"
    end
    return "/" .. table.concat(parts, "/")
end
local function pathLeaf(path)
    local resolved = normalizePath(path)
    if resolved == "/" then
        return "/"
    end
    local parts = splitPath(resolved)
    return parts[#parts] or resolved
end
local function isDirectoryPath(path)
    return getFS()[normalizePath(path)] ~= nil
end
local function isFilePath(path)
    return getContents()[normalizePath(path)] ~= nil
end
local function getEntryMetadata(path)
    return getMetadata()[normalizePath(path)]
end
local function getEntrySize(path)
    local resolved = normalizePath(path)
    if isDirectoryPath(resolved) then
        local entries = getFS()[resolved] or {}
        return ("%d item(s)"):format(#entries)
    end
    local content = getContents()[resolved]
    if content == nil then
        return "unknown"
    end
    return ("%d B"):format(#tostring(content))
end
local function formatListingLine(path)
    local resolved = normalizePath(path)
    local meta = getEntryMetadata(resolved)
    local name = pathLeaf(resolved)
    if meta and meta.type == "directory" and name ~= "/" then
        name = name .. "/"
    end
    if not meta then
        return " " .. name
    end
    return ("%s %-14s %-10s %-10s %s"):format(
        meta.permissions or "----------",
        meta.owner or "unknown",
        meta.group or "unknown",
        getEntrySize(resolved),
        name
    )
end
local function listPath(path)
    local target = ""
    local longFormat = false
    for token in tostring(path or ""):gmatch("%S+") do
        if token == "-l" or token == "--long" then
            longFormat = true
        else
            target = token
        end
    end
    local p = normalizePath(target)
    local fs = getFS()
    if isFilePath(p) then
        addLine(formatListingLine(p))
        return
    end
    local list = fs[p]
    if not list then
        addLine(("ls: cannot access '%s': No such file or directory (sim)"):format(p))
        return
    end
    addLine(("Listing %s on %s (sim)"):format(p, terminalState.currentHost))
    for _, name in ipairs(list) do
        local childPath = pathJoin(p, name)
        if longFormat then
            addLine(formatListingLine(childPath))
        else
            local meta = getEntryMetadata(childPath)
            local suffix = meta and meta.type == "directory" and "/" or ""
            addLine(" " .. name .. suffix)
        end
    end
end
local function catFile(path)
    local resolved = normalizePath(path)
    local name = pathLeaf(resolved)
    local contents = getContents()
    local content = contents[resolved]
    if not content then
        if isDirectoryPath(resolved) then
            addLine(("cat: %s: Is a directory (sim)"):format(resolved))
        else
            addLine(("cat: %s: No such file (sim)"):format(tostring(path)))
        end
        return
    end
    addLine(("--- %s ---"):format(name))
    for line in tostring(content):gmatch("[^\n]+") do
        addLine(line)
    end
end
local function openFile(path)
    local resolved = normalizePath(path)
    local name = pathLeaf(resolved)
    local contents = getContents()
    if not contents[resolved] then
        addLine(("openfile: %s not found (sim)"):format(tostring(path)))
        return
    end
    OpenFiles[resolved] = true
    addLine(("Opened %s (sim)"):format(name))
end
local function closeFile(path)
    local resolved = normalizePath(path)
    local name = pathLeaf(resolved)
    if OpenFiles[resolved] then
        OpenFiles[resolved] = nil
        addLine(("Closed %s (sim)"):format(name))
    else
        addLine(("closefile: %s is not open (sim)"):format(name))
    end
end
local function removeFile(path)
    local resolved = normalizePath(path)
    local name = pathLeaf(resolved)
    local contents = getContents()
    local fs = getFS()
    local metadata = getMetadata()
    if contents[resolved] then
        contents[resolved] = nil
        metadata[resolved] = nil
        OpenFiles[resolved] = nil
        local parent = pathParent(resolved)
        local items = parent and fs[parent]
        if items then
            for i = #items, 1, -1 do
                if items[i] == name then
                    table.remove(items, i)
                end
            end
        end
        addLine(("Removed %s (sim)"):format(name))
        if resolved == "/sync_jobs.sh" then
            markWannaWailFlag(WANNAWAIL_ATTR_LOADER_REMOVED, true)
        end
    else
        addLine(("rm: cannot remove '%s': No such file (sim)"):format(tostring(path)))
    end
end
local function changeDirectory(path)
    local target = tostring(path or "")
    if target:gsub("%s", "") == "" then
        terminalState.currentDir = "/"
        addLine("Current directory reset to /")
        return
    end
    local resolved = normalizePath(target)
    if not isDirectoryPath(resolved) then
        if isFilePath(resolved) then
            addLine(("cd: %s: Not a directory (sim)"):format(resolved))
        else
            addLine(("cd: %s: No such directory (sim)"):format(resolved))
        end
        return
    end
    terminalState.currentDir = resolved
    addLine(("Current directory: %s"):format(terminalState.currentDir))
end
local function showWorkingDirectory()
    addLine(("%s:%s"):format(terminalState.currentHost, terminalState.currentDir))
end
local function showStat(path)
    local target = tostring(path or "")
    if target:gsub("%s", "") == "" then
        addLine("Try: stat <path>")
        return
    end
    local resolved = normalizePath(target)
    local meta = getEntryMetadata(resolved)
    if not meta then
        addLine(("stat: %s: No such file or directory (sim)"):format(resolved))
        return
    end
    addLine(("File: %s"):format(resolved))
    addLine(("Type: %s"):format(meta.type or "unknown"))
    addLine(("Size: %s"):format(getEntrySize(resolved)))
    addLine(("Owner: %s:%s"):format(meta.owner or "unknown", meta.group or "unknown"))
    addLine(("Access: %s"):format(meta.permissions or "----------"))
    addLine(("Modified: %s"):format(meta.modified or "unknown"))
    if meta.summary then
        addLine(("Summary: %s"):format(meta.summary))
    end
end
local function findEntries(rawInput)
    local trimmed = tostring(rawInput or ""):gsub("^%s+", ""):gsub("%s+$", "")
    if trimmed == "" then
        addLine("Try: find <path> <name>")
        return
    end
    local tokens = {}
    for token in trimmed:gmatch("%S+") do
        tokens[#tokens + 1] = token
    end
    local rootPath, query
    if #tokens == 1 then
        rootPath = terminalState.currentDir
        query = tokens[1]
    else
        rootPath = tokens[1]
        query = table.concat(tokens, " ", 2)
    end
    local resolvedRoot = normalizePath(rootPath)
    if not isDirectoryPath(resolvedRoot) then
        addLine(("find: %s: No such directory (sim)"):format(resolvedRoot))
        return
    end
    local fs = getFS()
    local matches = {}
    local needle = query:lower()
    local function scanDir(dirPath)
        for _, name in ipairs(fs[dirPath] or {}) do
            local childPath = pathJoin(dirPath, name)
            if childPath:lower():find(needle, 1, true) or name:lower():find(needle, 1, true) then
                matches[#matches + 1] = childPath
            end
            if fs[childPath] then
                scanDir(childPath)
            end
        end
    end
    scanDir(resolvedRoot)
    if #matches == 0 then
        addLine(("No matches for '%s' under %s (sim)"):format(query, resolvedRoot))
        return
    end
    addLine(("Matches for '%s' under %s (sim)"):format(query, resolvedRoot))
    for _, match in ipairs(matches) do
        addLine(" " .. match)
    end
end
local function showScan(target)
target = target ~= "" and target:lower() or "nearby"
addLine(("Scan target: %s (sim)"):format(target))
if target == "nearby" then
for _, info in ipairs(getAllHostsList()) do
addLine(("%s [%s] open:%s role:%s"):format(
info.label,
info.ip,
table.concat(info.ports, ", "),
info.role
))
end
addLine("Hint: inspect the employee workstation or a sensitive internal host next (sim)")
terminalState.scanCache = "192.168.32.12"
return
end
local host = getHostByIP(target)
if not host then
addLine("No host found in scan range (sim).")
return
end
addLine(("Host: %s"):format(host.label))
addLine(("IP: %s"):format(host.ip))
addLine(("Ports: %s"):format(table.concat(host.ports, ", ")))
addLine(("Service Family: %s"):format(host.server))
addLine(("Role: %s"):format(host.role))
end
local function showSniff(target)
target = target ~= "" and target or "192.168.32.12"
local host = getHostByIP(target)
if not host then
addLine("sniff: unknown target ip (sim)")
return
end
startPacketCaptureForIP(target)
addLine(("Sniffing %s (%s) ... (sim)"):format(host.label, host.ip))
for i = 1, math.min(5, #ActivePacketCapture.rows) do
local r = ActivePacketCapture.rows[i]
addLine(("[%d] %s %s -> %s dns=%s port=%s server=%s"):format(
i, r.protocol, r.src, r.dst, r.dns, r.port, r.server
))
end
addLine("Capture complete: targeted lab packets generated (sim)")
terminalState.sniffCache = {
host = host.label,
ip = host.ip,
server = "PlayerData_Vault",
attackerIP = terminalState.lastAttackerIP,
}
end
local function showPackets(target)
target = target ~= "" and target or (terminalState.sniffCache and terminalState.sniffCache.ip or "192.168.32.12")
local host = getHostByIP(target)
if not host then
addLine("packets: unknown target ip (sim)")
return
end
startPacketCaptureForIP(target)
addLine(("Packet Analyzer: %s (%s) (sim)"):format(host.label, host.ip))
addLine(("Generated rows: %d"):format(#ActivePacketCapture.rows))
addLine("Browser view: visit RBXPacketAnalyzer.com")
end
local function fakeConnect(target)
target = target ~= "" and target or "192.168.43.20"
local host = getHostByIP(target)
if not host then
addLine(("connect: cannot resolve %s (sim)"):format(target))
return
end
addLine(("Resolving %s ... (sim)"):format(target))
addLine(("Connected to %s [%s] (sim)"):format(host.label, host.ip))
terminalState.connectedHost = host.label
end
local function fakeSSH(dest)
dest = tostring(dest or "")
if dest == "" then
addLine("Try: ssh bloxplay-admin@192.168.43.20")
return
end
local user, hostInput = dest:match("^([^@]+)@(.+)$")
if not user or not hostInput then
addLine("ssh: invalid destination. Try user@host")
return
end
local host = getHostByIP(hostInput)
if not host or host.label ~= "PlayerData_Vault" then
addLine(("ssh: %s not available in simulation"):format(hostInput))
return
end
addLine(("ssh: connecting to %s ... (sim)"):format(dest))
if terminalState.sniffCache then
addLine("Using credentials previously observed in traffic capture (sim)")
end
addLine("Host key fingerprint verified (sim)")
addLine("Password accepted (sim)")
addLine(("Welcome %s, connected to %s"):format(user, host.label))
terminalState.currentHost = host.label
terminalState.currentDir = "/"
terminalState.sshSession = true
end
local function fakeExit()
if terminalState.sshSession then
addLine(("Connection to %s closed."):format(terminalState.currentHost))
terminalState.currentHost = "local"
terminalState.currentDir = "/"
terminalState.sshSession = false
else
addLine("No remote session active.")
end
end
local function fakeNetstat()
addLine(("Active connections on %s (sim)"):format(terminalState.currentHost))
if terminalState.currentHost == "PlayerData_Vault" then
addLine("tcp 0 0 192.168.43.20:22 192.168.32.12:49822 ESTABLISHED")
addLine("tcp 0 0 192.168.43.20:443 203.44.18.77:8080 ESTABLISHED")
addLine("tcp 0 0 192.168.43.20:3306 192.168.43.25:54011 TIME_WAIT")
addLine("Finding: suspicious outbound connection to 203.44.18.77")
else
addLine("tcp 0 0 192.168.32.12:49210 192.168.43.20:443 ESTABLISHED")
addLine("udp 0 0 192.168.32.10:5353 224.0.0.251:5353 LISTEN")
end
end
local function fakePsrep()
addLine(("PID NAME STATUS HOST=%s"):format(terminalState.currentHost))
for _, p in ipairs(getProcesses()) do
addLine(("%-5d %-19s %s"):format(p.pid, p.name, p.status))
end
if terminalState.currentHost == "PlayerData_Vault" then
addLine("Finding: PID 1337 looks like WannaWail activity (fictional sim)")
end
end
local function fakeKill(pidText)
local pid = tonumber(pidText)
if not pid then
addLine("Try: kill <pid>")
return
end
local processes = getProcesses()
for i, p in ipairs(processes) do
if p.pid == pid then
addLine(("Terminated PID %d (%s) (sim)"):format(pid, p.name))
table.remove(processes, i)
if pid == 1337 then
markWannaWailFlag(WANNAWAIL_ATTR_PROCESS_KILLED, true)
end
return
end
end
addLine(("kill: %d: no such process (sim)"):format(pid))
end
local function fakeFirewall(rawInput)
local trimmed = tostring(rawInput or ""):gsub("^%s+", ""):gsub("%s+$", "")
if trimmed == "" then
addLine("Try: firewall add deny 203.44.18.77")
return
end
local tokens = {}
for token in trimmed:gmatch("%S+") do
tokens[#tokens + 1] = token:lower()
end
local ip = nil
if tokens[1] == "add" and (tokens[2] == "deny" or tokens[2] == "block") then
ip = tokens[3]
elseif tokens[1] == "deny" or tokens[1] == "block" then
ip = tokens[2]
end
if not ip or ip == "" then
addLine("Try: firewall add deny 203.44.18.77")
return
end
addLine(("Firewall deny rule staged for %s (sim)"):format(ip))
if ip == WANNAWAIL_ATTACKER_IP then
markWannaWailFlag(WANNAWAIL_ATTR_FIREWALL_BLOCKED, true)
addLine("Hostile source deny rule mirrored on PlayerData_Vault.")
end
end
local function fakeJamCam(rawInput)
local target = tostring(rawInput or ""):gsub("^%s+", ""):gsub("%s+$", "")
if target == "" then
addLine("Try: jamcam 192.168.32.31 (jams all cameras for 60 seconds)")
return
end
local jamRemote = getRemote(CAMERA_JAM_REMOTE_NAME)
if not jamRemote or not jamRemote:IsA("RemoteFunction") then
addLine("jamcam: camera service unavailable.")
return
end
local ok, result = pcall(function()
return jamRemote:InvokeServer(target)
end)
if not ok or type(result) ~= "table" then
addLine("jamcam: request failed.")
return
end
addLine(tostring(result.message or "Camera jam request sent."))
end
local function fakePasswd(pw)
local s = tostring(pw or "")
if s == "" then
addLine("Try: passwd NewStrongPass123!")
return
end
local score = 0
if #s >= 12 then score = score + 2 elseif #s >= 8 then score = score + 1 end
if s:match("%d") then score = score + 1 end
if s:match("%l") and s:match("%u") then score = score + 1 end
if s:match("[%p%W_]") then score = score + 1 end
if score <= 1 then
addLine("passwd (sim): weak password rejected")
elseif score <= 3 then
addLine("passwd (sim): acceptable, but could be stronger")
else
addLine("passwd (sim): password updated successfully")
end
end
local function fakeGrep(pattern, file)
pattern = tostring(pattern or "")
file = tostring(file or "")
if pattern == "" or file == "" then
addLine('Try: grep "Failed login" auth.log')
return
end
local contents = getContents()
local resolved = normalizePath(file)
local text = contents[resolved]
if not text then
addLine(("grep: %s: No such file (sim)"):format(file))
return
end
local found = false
for line in tostring(text):gmatch("[^\n]+") do
if line:lower():find(pattern:lower(), 1, true) then
addLine(line)
found = true
end
end
if not found then
addLine("No matches found (sim)")
end
end
local function fakeMalwareScan()
addLine(("Malware scanner on %s (sim)"):format(terminalState.currentHost))
if terminalState.currentHost == "PlayerData_Vault" then
addLine("Alert: sync_jobs.sh flagged as WannaWail (fictional ransomware-style sample)")
addLine("IOC: outbound endpoint 203.44.18.77")
addLine("Recommended actions: kill 1337, rm sync_jobs.sh, passwd <new>")
else
addLine("No malware indicators found on local tablet (sim)")
end
end
local function showDevices()
addLine("Known devices (SIM):")
for _, host in ipairs(getAllHostsList()) do
addLine(("%s ip=%s mac=%s role=%s service=%s"):format(
host.label, host.ip, host.mac, host.role, host.server
))
end
end
local function showMac(target)
target = tostring(target or "")
if target == "" then
addLine("Try: mac <ip>")
return
end
local host = getHostByIP(target)
if not host then
addLine("mac: unknown ip (sim)")
return
end
addLine(("%s ip=%s mac=%s"):format(host.label, host.ip, host.mac))
end
local function analyzePhishingText(text)
local t = (text or ""):lower()
local flags = 0
local clues = {}
local function flag(clue)
flags = flags + 1
table.insert(clues, clue)
end
if t:find("urgent") or t:find("immediately") then flag("It tries to rush you.") end
if t:find("password") or t:find("verify") then flag("It asks for credentials or account verification.") end
if t:find("free") or t:find("winner") or t:find("prize") then flag("It offers a too-good-to-be-true reward.") end
if t:find("gift card") then flag("Gift card request is a common scam sign.") end
if t:find("click") and (t:find("link") or t:find("http")) then flag("It pushes you to click a link.") end
return flags, clues
end
local function phishCheck(text)
local raw = tostring(text or "")
local targetText = raw
local targetLower = raw:lower()
if targetLower == "inbox" or targetLower == "email" then
if browserState.currentUrl ~= "mail.bloxplay.com" and browserState.currentUrl ~= "www.mail.bloxplay.com" then
addLine("baitcheck (sim): open mail.bloxplay.com first.")
return
end
local selectedMail = browserState._resolveSelectedMail and browserState._resolveSelectedMail() or nil
if not selectedMail then
addLine("baitcheck (sim): select an inbox message first.")
return
end
targetText = tostring(selectedMail.body or "")
addLine(('baitcheck (sim): analyzing "%s" from %s'):format(
 tostring(selectedMail.subject or "Untitled message"),
 tostring(selectedMail.sender or "unknown sender")
))
end
local flags, clues = analyzePhishingText(targetText)
if flags == 0 then
addLine("baitcheck (sim): message looks calmer, but still verify the sender.")
else
addLine(("baitcheck (sim): %d suspicious clue(s) found:"):format(flags))
for _, clue in ipairs(clues) do
addLine("- " .. clue)
end
end
if targetLower == "inbox" or targetLower == "email" then
setBrowserStatus("BaitCheck reviewed the selected email. Use Report or Pass Through in BloxMail.")
end
end
local function decoyMail(text)
local t = (text or ""):lower()
addLine("decoymail (sim): message tone analysis")
if t == "" then
addLine('Try: decoymail "URGENT verify your account now"')
return
end
if t:find("urgent") or t:find("verify") or t:find("reset") then
addLine("- Pressure language detected")
addLine("- Credential harvest risk elevated")
else
addLine("- No strong pressure wording detected")
end
if t:find("admin") or t:find("security") then
addLine("- Impersonation of authority possible")
end
end
local function fakeCrackNG(target)
target = tostring(target or "")
if target == "" then
addLine("Try: crack-ng 192.168.32.10")
return
end
addLine(("crack-ng audit target=%s (sim only)"):format(target))
if target == "192.168.32.10" or target == "192.168.43.2" then
addLine("- weak segmentation policy found")
addLine("- offline audit result: admin traffic overlaps with user network patterns")
addLine("- recommendation: rotate credentials and separate wireless domains")
else
addLine("- no weak password policy found in simulation")
end
end
local function showHelp()
addLine("HackOS authorized lab commands:")
addLine("help - show this list")
addLine("hint - show a clue for the current objective")
addLine("apps - list apps")
addLine("open <terminal|browser|notes> - switch screens")
addLine("visit <url|home|tips|apps|mail|rbxpacketanalyzer> - open a browser page")
addLine("scan [nearby|ip] - scan nearby devices/host (sim)")
addLine("sniff [ip] - capture simulated lab packet traffic")
addLine("packets [ip] - packet analyzer terminal summary (browser: RBXPacketAnalyzer)")
addLine("devices - list devices + MACs (terminal only)")
addLine("mac <ip> - show MAC for device")
addLine("connect <ip> - simulate network access (sim)")
addLine("ssh <user@ip> - simulate SSH login")
addLine("exit - leave simulated SSH session")
addLine("pwd - show current simulated working directory")
addLine("cd <path> - move through simulated folders")
addLine("ls [-l] [path] - list folders and files")
addLine("stat <path> - inspect simulated file metadata")
addLine("find <path> <name> - search the simulated filesystem")
addLine("cat <file> - read simulated file")
addLine('grep "<term>" <file> - search inside simulated logs')
addLine("openfile <file> - open simulated file")
addLine("closefile <file> - close simulated file")
addLine("rm <file> - remove simulated file")
addLine("netstat - show fake network sessions")
addLine("psrep / ps aux - list simulated processes")
addLine("malwarescan - simulate malware scan")
addLine("firewall add deny <ip> - add a deny rule on the vault")
addLine("firewall deny <ip> - shorthand deny rule")
addLine("kill <pid> - terminate simulated process")
addLine("echo <text> - print text")
addLine("passwd <text> - password set/check (sim)")
addLine("baitcheck <text> - detect phishing clues (sim)")
addLine("Admin portal: open the Security Logs tab during Chapter 3")
addLine("decoymail <text> - inspect suspicious email tone (sim)")
addLine("crack-ng <target> - password policy audit (sim)")
addLine("admin <on|off> - toggle admin mode (sim)")
addLine("save - save progress manually")
addLine("clear - clear terminal")
addLine("time - show time")
end

simOps.showHelp = showHelp
simOps.showScan = showScan
simOps.showSniff = showSniff
simOps.showPackets = showPackets
simOps.showDevices = showDevices
simOps.showMac = showMac
simOps.fakeConnect = fakeConnect
simOps.fakeSSH = fakeSSH
simOps.fakeExit = fakeExit
simOps.fakeNetstat = fakeNetstat
simOps.showWorkingDirectory = showWorkingDirectory
simOps.changeDirectory = changeDirectory
simOps.fakePsrep = fakePsrep
simOps.fakeGrep = fakeGrep
simOps.fakeMalwareScan = fakeMalwareScan
simOps.fakeFirewall = fakeFirewall
simOps.fakeJamCam = fakeJamCam
simOps.fakeKill = fakeKill
simOps.listPath = listPath
simOps.showStat = showStat
simOps.findEntries = findEntries
simOps.catFile = catFile
simOps.openFile = openFile
simOps.closeFile = closeFile
simOps.removeFile = removeFile
simOps.fakePasswd = fakePasswd
simOps.phishCheck = phishCheck
simOps.decoyMail = decoyMail
simOps.fakeCrackNG = fakeCrackNG
browserState._markWannaWailFlag = markWannaWailFlag

end

return TabletSimOps
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="85">
          <Properties>
            <string name="Name">TimeLeaderboard</string>
            <string name="Source"><![CDATA[-- TimeLeaderboard.client.luau
-- Shows a top-right on-screen leaderboard of fastest mission times.
-- Press L to toggle open/closed.

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")
local UserInputService  = game:GetService("UserInputService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ─── Wait for Remotes ────────────────────────────────────────────────────────
local Remotes       = ReplicatedStorage:WaitForChild("MissionTimerRemotes", 10)
local EvLeaderboard = Remotes:WaitForChild("LeaderboardUpdate")
local FnGetBestTime = Remotes:WaitForChild("GetMyBestTime")

-- ─── Constants ───────────────────────────────────────────────────────────────
local PANEL_WIDTH   = 260
local ROW_HEIGHT    = 36
local HEADER_HEIGHT = 48
local MAX_ROWS      = 10
local TOGGLE_KEY    = Enum.KeyCode.L

-- ─── Colors (matching suspicion meter dark style) ────────────────────────────
local COLOR_BG        = Color3.fromRGB(10, 10, 18)
local COLOR_HEADER    = Color3.fromRGB(20, 100, 200)
local COLOR_ROW_ODD   = Color3.fromRGB(14, 18, 36)
local COLOR_ROW_EVEN  = Color3.fromRGB(18, 24, 48)
local COLOR_TEXT      = Color3.fromRGB(220, 230, 255)
local COLOR_TIME      = Color3.fromRGB(80, 210, 255)
local COLOR_DIM       = Color3.fromRGB(100, 120, 160)
local COLOR_GOLD      = Color3.fromRGB(255, 210, 50)
local MEDAL           = {"🥇", "🥈", "🥉"}

-- ─── Build ScreenGui ─────────────────────────────────────────────────────────
local screenGui = Instance.new("ScreenGui")
screenGui.Name           = "TimeLeaderboardGui"
screenGui.ResetOnSpawn   = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent         = playerGui

-- Outer panel (slides in/out from the right)
local panel = Instance.new("Frame")
panel.Name              = "Panel"
panel.Size              = UDim2.new(0, PANEL_WIDTH, 0, HEADER_HEIGHT) -- grows with rows
panel.AnchorPoint       = Vector2.new(1, 0)
panel.Position          = UDim2.new(1, 16, 0, 80) -- 80px from top, starts off-screen (+16)
panel.BackgroundColor3  = COLOR_BG
panel.BackgroundTransparency = 0.15
panel.BorderSizePixel   = 0
panel.ClipsDescendants  = true
panel.Parent            = screenGui

local panelCorner = Instance.new("UICorner", panel)
panelCorner.CornerRadius = UDim.new(0, 12)

local panelStroke = Instance.new("UIStroke", panel)
panelStroke.Color     = COLOR_HEADER
panelStroke.Thickness = 1.5
panelStroke.Transparency = 0.4

-- Header
local header = Instance.new("Frame")
header.Size            = UDim2.new(1, 0, 0, HEADER_HEIGHT)
header.BackgroundColor3 = COLOR_HEADER
header.BorderSizePixel = 0
header.Parent          = panel

local headerCorner = Instance.new("UICorner", header)
headerCorner.CornerRadius = UDim.new(0, 12)

-- Fix header bottom corners
local headerFix = Instance.new("Frame")
headerFix.Size             = UDim2.new(1, 0, 0.5, 0)
headerFix.Position         = UDim2.new(0, 0, 0.5, 0)
headerFix.BackgroundColor3 = COLOR_HEADER
headerFix.BorderSizePixel  = 0
headerFix.Parent           = header

local titleLabel = Instance.new("TextLabel")
titleLabel.Size                 = UDim2.new(1, -12, 1, 0)
titleLabel.Position             = UDim2.new(0, 12, 0, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Font                 = Enum.Font.GothamBlack
titleLabel.TextSize             = 16
titleLabel.TextColor3           = Color3.fromRGB(255, 255, 255)
titleLabel.TextXAlignment       = Enum.TextXAlignment.Left
titleLabel.Text                 = "🏆  FASTEST TIMES"
titleLabel.Parent               = header

-- Toggle hint label (top-right of header)
local hintLabel = Instance.new("TextLabel")
hintLabel.Size                  = UDim2.new(0, 60, 1, 0)
hintLabel.Position              = UDim2.new(1, -64, 0, 0)
hintLabel.BackgroundTransparency = 1
hintLabel.Font                  = Enum.Font.GothamMedium
hintLabel.TextSize              = 11
hintLabel.TextColor3            = Color3.fromRGB(200, 220, 255)
hintLabel.TextTransparency      = 0.3
hintLabel.Text                  = "[L]"
hintLabel.Parent                = header

-- Row container
local rowList = Instance.new("Frame")
rowList.Name                  = "RowList"
rowList.Size                  = UDim2.new(1, 0, 1, -HEADER_HEIGHT)
rowList.Position              = UDim2.new(0, 0, 0, HEADER_HEIGHT)
rowList.BackgroundTransparency = 1
rowList.BorderSizePixel       = 0
rowList.Parent                = panel

local listLayout = Instance.new("UIListLayout", rowList)
listLayout.SortOrder = Enum.SortOrder.LayoutOrder
listLayout.Padding   = UDim.new(0, 2)

local listPadding = Instance.new("UIPadding", rowList)
listPadding.PaddingLeft   = UDim.new(0, 6)
listPadding.PaddingRight  = UDim.new(0, 6)
listPadding.PaddingTop    = UDim.new(0, 6)
listPadding.PaddingBottom = UDim.new(0, 6)

-- Empty state label
local emptyLabel = Instance.new("TextLabel")
emptyLabel.Name                 = "EmptyLabel"
emptyLabel.Size                 = UDim2.new(1, 0, 0, ROW_HEIGHT)
emptyLabel.BackgroundTransparency = 1
emptyLabel.Font                 = Enum.Font.GothamMedium
emptyLabel.TextSize             = 13
emptyLabel.TextColor3           = COLOR_DIM
emptyLabel.Text                 = "No records yet — be the first!"
emptyLabel.LayoutOrder          = 999
emptyLabel.Parent               = rowList

-- ─── Helpers ─────────────────────────────────────────────────────────────────
local function formatTime(seconds: number): string
	local mins  = math.floor(seconds / 60)
	local secs  = math.floor(seconds % 60)
	local cents = math.floor((seconds % 1) * 100)
	return ("%02d:%02d.%02d"):format(mins, secs, cents)
end

local function updatePanelHeight(rowCount: number)
	local contentHeight = HEADER_HEIGHT
		+ 12 -- top+bottom padding
		+ math.max(1, rowCount) * ROW_HEIGHT
		+ math.max(0, rowCount - 1) * 2 -- gaps
	TweenService:Create(panel,
		TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Size = UDim2.new(0, PANEL_WIDTH, 0, contentHeight) }
	):Play()
end

local function makeRow(rank: number, name: string, timeStr: string, isMe: boolean)
	local row = Instance.new("Frame")
	row.Name             = "Row_" .. rank
	row.Size             = UDim2.new(1, 0, 0, ROW_HEIGHT)
	row.BackgroundColor3 = rank % 2 == 0 and COLOR_ROW_EVEN or COLOR_ROW_ODD
	row.BorderSizePixel  = 0
	row.LayoutOrder      = rank

	local rowCorner = Instance.new("UICorner", row)
	rowCorner.CornerRadius = UDim.new(0, 6)

	-- Highlight own row
	if isMe then
		local highlight = Instance.new("UIStroke", row)
		highlight.Color     = COLOR_TIME
		highlight.Thickness = 1
		highlight.Transparency = 0.4
	end

	-- Rank / medal
	local rankLabel = Instance.new("TextLabel")
	rankLabel.Size                  = UDim2.new(0, 36, 1, 0)
	rankLabel.Position              = UDim2.new(0, 4, 0, 0)
	rankLabel.BackgroundTransparency = 1
	rankLabel.Font                  = Enum.Font.GothamBold
	rankLabel.TextSize              = 15
	rankLabel.TextColor3            = rank <= 3 and COLOR_GOLD or COLOR_DIM
	rankLabel.Text                  = MEDAL[rank] or ("#" .. rank)
	rankLabel.Parent                = row

	-- Player name
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size                  = UDim2.new(1, -120, 1, 0)
	nameLabel.Position              = UDim2.new(0, 42, 0, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Font                  = isMe and Enum.Font.GothamBold or Enum.Font.GothamMedium
	nameLabel.TextSize              = 13
	nameLabel.TextColor3            = isMe and Color3.fromRGB(255, 255, 255) or COLOR_TEXT
	nameLabel.TextXAlignment        = Enum.TextXAlignment.Left
	nameLabel.TextTruncate          = Enum.TextTruncate.AtEnd
	nameLabel.Text                  = name .. (isMe and "  ◀" or "")
	nameLabel.Parent                = row

	-- Time
	local timeLabel = Instance.new("TextLabel")
	timeLabel.Size                  = UDim2.new(0, 74, 1, 0)
	timeLabel.Position              = UDim2.new(1, -76, 0, 0)
	timeLabel.BackgroundTransparency = 1
	timeLabel.Font                  = Enum.Font.GothamBold
	timeLabel.TextSize              = 13
	timeLabel.TextColor3            = COLOR_TIME
	timeLabel.TextXAlignment        = Enum.TextXAlignment.Right
	timeLabel.Text                  = timeStr
	timeLabel.Parent                = row

	return row
end

-- ─── Populate ─────────────────────────────────────────────────────────────────
local function populateBoard(data: {{name: string, time: number}})
	-- Clear old rows
	for _, child in rowList:GetChildren() do
		if child:IsA("Frame") then child:Destroy() end
	end

	if #data == 0 then
		emptyLabel.Visible = true
		updatePanelHeight(0)
		return
	end

	emptyLabel.Visible = false
	for i, entry in ipairs(data) do
		local isMe = entry.name == player.Name
		local row  = makeRow(i, entry.name, formatTime(entry.time), isMe)
		row.Parent = rowList
	end
	updatePanelHeight(#data)
end

-- ─── Toggle logic ─────────────────────────────────────────────────────────────
local isOpen   = false
local OPEN_X   = UDim2.new(1, -10, 0, 80)  -- fully on screen
local CLOSED_X = UDim2.new(1, PANEL_WIDTH + 10, 0, 80) -- off-screen right

-- Start hidden (off-screen)
panel.Position = CLOSED_X

local function setOpen(open: boolean)
	isOpen = open
	TweenService:Create(panel,
		TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
		{ Position = open and OPEN_X or CLOSED_X }
	):Play()
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == TOGGLE_KEY then
		setOpen(not isOpen)
	end
end)

-- ─── Remote wiring ────────────────────────────────────────────────────────────
EvLeaderboard.OnClientEvent:Connect(function(data)
	populateBoard(data)
	-- If panel is open, data refreshes live
end)

-- Request initial data on join
task.spawn(function()
	-- Give server a moment to set up
	task.wait(2)
	-- Personal best fetch also triggers a leaderboard broadcast from the server
	FnGetBestTime:InvokeServer()
end)

-- ─── Tab hint (always visible, slides with panel) ────────────────────────────
-- Small collapsed tab sticking out even when panel is hidden
local tabHint = Instance.new("TextButton")
tabHint.Name              = "TabHint"
tabHint.Size              = UDim2.new(0, 28, 0, 72)
tabHint.AnchorPoint       = Vector2.new(1, 0)
tabHint.Position          = UDim2.new(1, 0, 0, 80)
tabHint.BackgroundColor3  = COLOR_HEADER
tabHint.BorderSizePixel   = 0
tabHint.Text              = ""
tabHint.Parent            = screenGui

local tabCorner = Instance.new("UICorner", tabHint)
tabCorner.CornerRadius = UDim.new(0, 6)

local tabIcon = Instance.new("TextLabel")
tabIcon.Size                 = UDim2.new(1, 0, 1, 0)
tabIcon.BackgroundTransparency = 1
tabIcon.Font                 = Enum.Font.GothamBlack
tabIcon.TextSize             = 12
tabIcon.TextColor3           = Color3.fromRGB(255, 255, 255)
tabIcon.Text                 = "🏆\nL"
tabIcon.Parent               = tabHint

tabHint.MouseButton1Click:Connect(function()
	setOpen(not isOpen)
end)

print("[TimeLeaderboard] Client leaderboard loaded. Press L to toggle.")
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="86">
          <Properties>
            <string name="Name">camscreen</string>
            <string name="Source"><![CDATA[local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local CameraMetadata = require(Shared:WaitForChild("CameraMetadata"))

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local gameCamera = Workspace.CurrentCamera

local openEvent = ReplicatedStorage:WaitForChild("OpenCameraMonitor")
local JAM_STATE_ATTRIBUTE = "CameraNetworkJamUntil"

local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

local monitorOpen = false
local currentIndex = 1
local renderConnection = nil

local cameraPoints = {}

local screenGui
local mainFrame
local titleLabel
local locationLabel
local leftButton
local rightButton
local closeButton
local jamOverlayFrame
local jamOverlayLabel

local function getServerNow()
	local ok, value = pcall(function()
		return Workspace:GetServerTimeNow()
	end)
	if ok and typeof(value) == "number" then
		return value
	end
	return os.clock()
end

local function getJamUntil()
	local value = ReplicatedStorage:GetAttribute(JAM_STATE_ATTRIBUTE)
	if typeof(value) == "number" then
		return value
	end
	return 0
end

local function isJamActive()
	return getJamUntil() > getServerNow()
end

local function updateJamUi()
	if not jamOverlayFrame or not jamOverlayLabel then
		return
	end

	local jamActive = isJamActive()
	jamOverlayFrame.Visible = jamActive
	if not jamActive then
		return
	end

	local location = "Unknown Location"
	if #cameraPoints > 0 then
		local data = cameraPoints[currentIndex]
		location = string.upper((data and data.location) or location)
	end

	local blinkOn = math.floor(getServerNow() * 3) % 2 == 0
	jamOverlayLabel.Text = string.format("%s\n%s", location, blinkOn and "SIGNAL JAMMED" or "FEED LOST")
	jamOverlayLabel.TextColor3 = blinkOn and Color3.fromRGB(255, 140, 140) or Color3.fromRGB(255, 200, 135)
end

local function refreshCharacter(newCharacter)
	character = newCharacter or player.Character or player.CharacterAdded:Wait()
	humanoid = character:WaitForChild("Humanoid")

	if not monitorOpen then
		gameCamera.CameraSubject = humanoid
	end
end

player.CharacterAdded:Connect(refreshCharacter)

local function collectCameras()
	cameraPoints = {}

	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and obj.Name == "Camera" then
			local lens = obj:FindFirstChild("Lens", true)

			if lens and lens:IsA("BasePart") then
				table.insert(cameraPoints, {
					cameraModel = obj,
					viewPart = lens,
					location = CameraMetadata.GetLocationLabel(obj),
				})
			else
				warn("[Monitor] No valid Lens found in", obj:GetFullName())
			end
		end
	end

	table.sort(cameraPoints, function(a, b)
		if a.location == b.location then
			return a.cameraModel:GetFullName() < b.cameraModel:GetFullName()
		end

		return a.location < b.location
	end)
end

local function updateLabels()
	if #cameraPoints == 0 then
		titleLabel.Text = "NO CAMERAS"
		locationLabel.Text = "LOCATION UNAVAILABLE"
		updateJamUi()
		return
	end

	local data = cameraPoints[currentIndex]
	titleLabel.Text = "CAMERA " .. currentIndex .. " / " .. #cameraPoints
	locationLabel.Text = string.upper((data and data.location) or "Unknown Location")
	updateJamUi()
end

local function applyCurrentCamera()
	local data = cameraPoints[currentIndex]
	if not data or not data.viewPart or not data.viewPart.Parent then
		return
	end

	gameCamera.CameraType = Enum.CameraType.Scriptable
	gameCamera.CFrame = data.viewPart.CFrame
	updateLabels()
end

local function nextCamera()
	if #cameraPoints == 0 then
		return
	end

	currentIndex = currentIndex + 1
	if currentIndex > #cameraPoints then
		currentIndex = 1
	end

	applyCurrentCamera()
end

local function previousCamera()
	if #cameraPoints == 0 then
		return
	end

	currentIndex = currentIndex - 1
	if currentIndex < 1 then
		currentIndex = #cameraPoints
	end

	applyCurrentCamera()
end

local function closeMonitor()
	monitorOpen = false

	if renderConnection then
		renderConnection:Disconnect()
		renderConnection = nil
	end

	screenGui.Enabled = false
	gameCamera.CameraType = Enum.CameraType.Custom

	if humanoid then
		gameCamera.CameraSubject = humanoid
	end
end

local function openMonitor()
	collectCameras()

	if #cameraPoints == 0 then
		warn("No cameras found. Expected a model named Camera containing a part named Lens.")
		return
	end

	if currentIndex > #cameraPoints then
		currentIndex = 1
	end

	monitorOpen = true
	screenGui.Enabled = true

	applyCurrentCamera()

	if renderConnection then
		renderConnection:Disconnect()
	end

	updateJamUi()
	renderConnection = RunService.RenderStepped:Connect(function()
		if not monitorOpen then
			return
		end

		updateJamUi()
		local data = cameraPoints[currentIndex]
		if data and data.viewPart and data.viewPart.Parent then
			gameCamera.CFrame = data.viewPart.CFrame
		end
	end)
end

screenGui = Instance.new("ScreenGui")
screenGui.Name = "CameraMonitorGui"
screenGui.ResetOnSpawn = false
screenGui.Enabled = false
screenGui.Parent = playerGui

mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 420, 0, 132)
mainFrame.Position = UDim2.new(0.5, -210, 1, -150)
mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
mainFrame.BackgroundTransparency = 0.15
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

jamOverlayFrame = Instance.new("Frame")
jamOverlayFrame.Size = UDim2.new(1, -24, 0, 64)
jamOverlayFrame.Position = UDim2.new(0, 12, 0, 56)
jamOverlayFrame.BackgroundColor3 = Color3.fromRGB(36, 12, 16)
jamOverlayFrame.BackgroundTransparency = 0.12
jamOverlayFrame.BorderSizePixel = 0
jamOverlayFrame.Visible = false
jamOverlayFrame.Parent = mainFrame

local jamCorner = Instance.new("UICorner")
jamCorner.CornerRadius = UDim.new(0, 12)
jamCorner.Parent = jamOverlayFrame

jamOverlayLabel = Instance.new("TextLabel")
jamOverlayLabel.Size = UDim2.new(1, -16, 1, -12)
jamOverlayLabel.Position = UDim2.new(0, 8, 0, 6)
jamOverlayLabel.BackgroundTransparency = 1
jamOverlayLabel.Text = "SIGNAL JAMMED"
jamOverlayLabel.TextColor3 = Color3.fromRGB(255, 140, 140)
jamOverlayLabel.TextScaled = true
jamOverlayLabel.TextWrapped = true
jamOverlayLabel.Font = Enum.Font.SourceSansBold
jamOverlayLabel.Parent = jamOverlayFrame

ReplicatedStorage:GetAttributeChangedSignal(JAM_STATE_ATTRIBUTE):Connect(updateJamUi)

titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, -120, 0, 40)
titleLabel.Position = UDim2.new(0, 60, 0, 10)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "CAMERA"
titleLabel.TextColor3 = Color3.new(1, 1, 1)
titleLabel.TextScaled = true
titleLabel.Font = Enum.Font.SourceSansBold
titleLabel.Parent = mainFrame

locationLabel = Instance.new("TextLabel")
locationLabel.Size = UDim2.new(1, -120, 0, 22)
locationLabel.Position = UDim2.new(0, 60, 0, 44)
locationLabel.BackgroundTransparency = 1
locationLabel.Text = "LOCATION"
locationLabel.TextColor3 = Color3.fromRGB(180, 225, 255)
locationLabel.TextScaled = true
locationLabel.Font = Enum.Font.SourceSansSemibold
locationLabel.Parent = mainFrame

leftButton = Instance.new("TextButton")
leftButton.Size = UDim2.new(0, 80, 0, 40)
leftButton.Position = UDim2.new(0, 10, 0, 80)
leftButton.Text = "<"
leftButton.TextScaled = true
leftButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
leftButton.TextColor3 = Color3.new(1, 1, 1)
leftButton.Parent = mainFrame

rightButton = Instance.new("TextButton")
rightButton.Size = UDim2.new(0, 80, 0, 40)
rightButton.Position = UDim2.new(1, -90, 0, 80)
rightButton.Text = ">"
rightButton.TextScaled = true
rightButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
rightButton.TextColor3 = Color3.new(1, 1, 1)
rightButton.Parent = mainFrame

closeButton = Instance.new("TextButton")
closeButton.Size = UDim2.new(0, 40, 0, 40)
closeButton.Position = UDim2.new(1, -50, 0, 10)
closeButton.Text = "X"
closeButton.TextScaled = true
closeButton.BackgroundColor3 = Color3.fromRGB(120, 40, 40)
closeButton.TextColor3 = Color3.new(1, 1, 1)
closeButton.Parent = mainFrame

leftButton.MouseButton1Click:Connect(previousCamera)
rightButton.MouseButton1Click:Connect(nextCamera)
closeButton.MouseButton1Click:Connect(closeMonitor)

openEvent.OnClientEvent:Connect(function()
	if monitorOpen then
		closeMonitor()
	else
		openMonitor()
	end
end)
]]></string>
          </Properties>
        </Item>
        <Item class="LocalScript" referent="87">
          <Properties>
            <string name="Name">start</string>
            <string name="Source"><![CDATA[-- MODERN TITLE SCREEN - Full responsive design with working popup modals
-- Drop into StarterPlayerScripts or StarterGui

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local SoundService = game:GetService("SoundService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Attempt to load ObjectiveManager for chapters
local ObjectiveManager
pcall(function()
	local Shared = ReplicatedStorage:WaitForChild("Shared")
	ObjectiveManager = require(Shared:WaitForChild("ObjectiveManager"))
end)

local activePopup = nil
local RESTORE_STATE_ATTRIBUTE = "HackTabletRestoreBlob"
local LOAD_SCENARIO_REMOTE_NAME = "LoadScenario"
local LOAD_REMOTE_NAME = "LoadSavedProgress"
local FLUSH_PROGRESS_REMOTE_NAME = "FlushProgress"
local GET_SESSION_INFO_REMOTE_NAME = "GetSessionInfo"
local SAVE_STATUS_REMOTE_NAME = "GetSavedProgressStatus"
local CLEAR_SAVE_REMOTE_NAME = "ClearSavedProgress"
local START_OVER_REMOTE_NAME = "StartOverProgress"
local CLEANUP_REMOTE_NAME = "Cleanup"
local NEWS_CUTSCENE_REMOTE_NAME = "StartNewsCutscene"
local NEWS_CUTSCENE_STARTED_ATTRIBUTE = "NewsCutsceneStarted"
local NEWS_CUTSCENE_COMPLETED_ATTRIBUTE = "NewsCutsceneCompleted"
local PHONE_INTRO_COMPLETED_ATTRIBUTE = "PhoneIntroCallCompleted"
local NEWS_CUTSCENE_TIMEOUT = 75
local MISSION_TIMER_REMOTES_NAME = "MissionTimerRemotes"
local GET_TIMER_STATE_REMOTE_NAME = "GetTimerState"
local DISCLAIMER_REMOTE_NAME = "DisclaimerCompleted"
local SCENARIO_ORDER = {
	"Chapter1_Recon",
	"Chapter2_SSH",
	"Chapter3_Malware",
	"Chapter4_IncidentResponse",
}
local CHAPTER_DESCRIPTIONS = {
	Chapter1_Recon = "Look around a pretend network, spot safe clues, and learn how investigators find where data travels.",
	Chapter2_SSH = "Use a training login to read server files and learn how logs can explain what happened.",
	Chapter3_Malware = "Study clues from a pretend harmful program and learn how defenders figure out what changed.",
	Chapter4_IncidentResponse = "Block the problem, clean up safely, and write a clear report about what you found.",
}

---------------------------------------------------------
-- COLOR & DESIGN TOKENS
---------------------------------------------------------
local COLORS = {
	PRIMARY = Color3.fromRGB(14, 165, 233),
	ACCENT = Color3.fromRGB(168, 85, 247),
	DARK_BG = Color3.fromRGB(8, 12, 20),
	CARD_BG = Color3.fromRGB(15, 23, 35),
	TEXT_PRIMARY = Color3.fromRGB(240, 246, 255),
	TEXT_SECONDARY = Color3.fromRGB(148, 163, 184),
	SUCCESS = Color3.fromRGB(34, 197, 94),
	WARNING = Color3.fromRGB(250, 204, 21),
	DANGER = Color3.fromRGB(239, 68, 68),
	DISABLED = Color3.fromRGB(64, 64, 64),
}

---------------------------------------------------------
-- AUDIO SETTINGS
-- Optional tagging:
-- sound:SetAttribute("AudioCategory", "Music") --> affected by Master only
-- sound:SetAttribute("AudioCategory", "SFX")   --> affected by Master + SFX
---------------------------------------------------------
local MASTER_VOLUME_ATTRIBUTE = "MasterVolume"
local SFX_VOLUME_ATTRIBUTE = "SFXVolume"
local BASE_VOLUME_ATTRIBUTE = "BaseVolume"
local AUDIO_CATEGORY_ATTRIBUTE = "AudioCategory"

local managedSounds = {}
local managedSoundConnections = {}
local lastAppliedVolumes = {}

local function normalizePercentValue(value, fallback)
	if typeof(value) ~= "number" then
		return fallback
	end

	if value <= 1 then
		return math.clamp(math.floor(value * 100 + 0.5), 0, 100)
	end

	return math.clamp(math.floor(value + 0.5), 0, 100)
end

local function readPercentAttribute(attributeName, fallback)
	return normalizePercentValue(SoundService:GetAttribute(attributeName), fallback)
end

local function writePercentAttribute(attributeName, value)
	SoundService:SetAttribute(attributeName, math.clamp(math.floor(value + 0.5), 0, 100))
end

local function contains(text, fragment)
	return string.find(text, fragment, 1, true) ~= nil
end

local function getSoundCategory(sound)
	local explicit = sound:GetAttribute(AUDIO_CATEGORY_ATTRIBUTE)
	if typeof(explicit) == "string" then
		local lowered = string.lower(explicit)

		if lowered == "music" or lowered == "bgm" or lowered == "ambient" or lowered == "ambience" then
			return "GENERAL"
		end

		if lowered == "sfx" or lowered == "fx" or lowered == "soundeffect" then
			return "SFX"
		end
	end

	if sound.SoundGroup then
		local groupName = string.lower(sound.SoundGroup.Name)
		if contains(groupName, "music") or contains(groupName, "bgm") or contains(groupName, "ambient") then
			return "GENERAL"
		end
	end

	local name = string.lower(sound.Name)
	local parentName = sound.Parent and string.lower(sound.Parent.Name) or ""
	local combined = name .. " " .. parentName

	if contains(combined, "music")
		or contains(combined, "theme")
		or contains(combined, "bgm")
		or contains(combined, "ambient")
		or contains(combined, "ambience")
		or contains(combined, "radio")
		or contains(combined, "song")
	then
		return "GENERAL"
	end

	if sound.Looped then
		return "GENERAL"
	end

	return "SFX"
end

local function getBaseVolume(sound)
	local base = sound:GetAttribute(BASE_VOLUME_ATTRIBUTE)
	if typeof(base) == "number" then
		return base
	end

	local masterMultiplier = readPercentAttribute(MASTER_VOLUME_ATTRIBUTE, 100) / 100
	local sfxMultiplier = readPercentAttribute(SFX_VOLUME_ATTRIBUTE, 100) / 100

	local divisor = masterMultiplier
	if getSoundCategory(sound) == "SFX" then
		divisor = divisor * sfxMultiplier
	end

	if divisor <= 0 then
		base = sound.Volume
	else
		base = sound.Volume / divisor
	end

	base = math.clamp(base, 0, 10)
	sound:SetAttribute(BASE_VOLUME_ATTRIBUTE, base)
	return base
end

local function computeFinalSoundVolume(sound)
	local baseVolume = getBaseVolume(sound)
	local masterMultiplier = readPercentAttribute(MASTER_VOLUME_ATTRIBUTE, 100) / 100
	local sfxMultiplier = readPercentAttribute(SFX_VOLUME_ATTRIBUTE, 100) / 100

	local finalVolume = baseVolume * masterMultiplier
	if getSoundCategory(sound) == "SFX" then
		finalVolume = finalVolume * sfxMultiplier
	end

	return math.clamp(finalVolume, 0, 10)
end

local function applyManagedVolume(sound)
	if not sound or not sound.Parent then
		return
	end

	local finalVolume = computeFinalSoundVolume(sound)
	lastAppliedVolumes[sound] = finalVolume
	sound.Volume = finalVolume
end

local function cleanupManagedSound(sound)
	managedSounds[sound] = nil
	lastAppliedVolumes[sound] = nil

	local connections = managedSoundConnections[sound]
	if connections then
		for _, connection in ipairs(connections) do
			connection:Disconnect()
		end
	end

	managedSoundConnections[sound] = nil
end

local function registerManagedSound(sound)
	if managedSounds[sound] then
		return
	end

	managedSounds[sound] = true
	getBaseVolume(sound)
	applyManagedVolume(sound)

	managedSoundConnections[sound] = {
		sound:GetPropertyChangedSignal("Volume"):Connect(function()
			local lastApplied = lastAppliedVolumes[sound]
			if typeof(lastApplied) == "number" and math.abs(sound.Volume - lastApplied) < 0.0001 then
				return
			end

			sound:SetAttribute(BASE_VOLUME_ATTRIBUTE, math.clamp(sound.Volume, 0, 10))
			applyManagedVolume(sound)
		end),

		sound:GetAttributeChangedSignal(AUDIO_CATEGORY_ATTRIBUTE):Connect(function()
			applyManagedVolume(sound)
		end),

		sound.AncestryChanged:Connect(function(_, parent)
			if not parent then
				cleanupManagedSound(sound)
			end
		end),
	}
end

local function applyAllManagedVolumes()
	for sound in pairs(managedSounds) do
		if sound.Parent then
			applyManagedVolume(sound)
		else
			cleanupManagedSound(sound)
		end
	end
end

local function watchSoundContainer(container)
	for _, descendant in ipairs(container:GetDescendants()) do
		if descendant:IsA("Sound") then
			registerManagedSound(descendant)
		end
	end

	container.DescendantAdded:Connect(function(descendant)
		if descendant:IsA("Sound") then
			task.defer(function()
				if descendant.Parent then
					registerManagedSound(descendant)
				end
			end)
		end
	end)
end

local function initializeAudioSettings()
	writePercentAttribute(MASTER_VOLUME_ATTRIBUTE, readPercentAttribute(MASTER_VOLUME_ATTRIBUTE, 100))
	writePercentAttribute(SFX_VOLUME_ATTRIBUTE, readPercentAttribute(SFX_VOLUME_ATTRIBUTE, 100))

	SoundService:GetAttributeChangedSignal(MASTER_VOLUME_ATTRIBUTE):Connect(function()
		applyAllManagedVolumes()
	end)

	SoundService:GetAttributeChangedSignal(SFX_VOLUME_ATTRIBUTE):Connect(function()
		applyAllManagedVolumes()
	end)

	watchSoundContainer(Workspace)
	watchSoundContainer(SoundService)
	watchSoundContainer(player)

	applyAllManagedVolumes()
end

initializeAudioSettings()

---------------------------------------------------------
-- HELPERS
---------------------------------------------------------
local function notify(title, text, duration)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = tostring(title or "UNDERCOVER"),
			Text = tostring(text or ""),
			Duration = tonumber(duration) or 3,
		})
	end)
end

local function applyProperties(instance, props)
	local parent = nil

	for k, v in pairs(props or {}) do
		if k == "parent" then
			parent = v
		else
			instance[k] = v
		end
	end

	if parent then
		instance.Parent = parent
	end

	return instance
end

local function createFrame(props)
	return applyProperties(Instance.new("Frame"), props)
end

local function createLabel(props)
	return applyProperties(Instance.new("TextLabel"), props)
end

local function createIcon(props)
	local icon = applyProperties(Instance.new("ImageLabel"), props)
	icon.ScaleType = Enum.ScaleType.Fit
	icon.BackgroundTransparency = 1
	return icon
end

local function createButton(props)
	return applyProperties(Instance.new("TextButton"), props)
end

local function roundCorners(instance, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 12)
	corner.Parent = instance
	return corner
end

local function createGradient(instance, colorStart, colorEnd, rotation)
	local gradient = Instance.new("UIGradient")
	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, colorStart),
		ColorSequenceKeypoint.new(1, colorEnd),
	})
	gradient.Rotation = rotation or 0
	gradient.Parent = instance
	return gradient
end

local function addStroke(instance, color, thickness, transparency)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Thickness = thickness or 1
	stroke.Transparency = transparency or 0
	stroke.Parent = instance
	return stroke
end

local function addPadding(instance, left, right, top, bottom)
	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, left or 0)
	padding.PaddingRight = UDim.new(0, right or 0)
	padding.PaddingTop = UDim.new(0, top or 0)
	padding.PaddingBottom = UDim.new(0, bottom or 0)
	padding.Parent = instance
	return padding
end

local function animateButtonHover(button, normalColor, hoverColor)
	button.MouseEnter:Connect(function()
		TweenService:Create(
			button,
			TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ BackgroundColor3 = hoverColor }
		):Play()
	end)

	button.MouseLeave:Connect(function()
		TweenService:Create(
			button,
			TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ BackgroundColor3 = normalColor }
		):Play()
	end)
end

local function closePopup(immediate)
	if activePopup and activePopup.Parent then
		local popupToClose = activePopup
		activePopup = nil

		if immediate then
			popupToClose:Destroy()
			return
		end

		local overlay = popupToClose:FindFirstChild("Overlay")
		local panel = popupToClose:FindFirstChild("Panel")

		if overlay then
			TweenService:Create(
				overlay,
				TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{ BackgroundTransparency = 1 }
			):Play()
		end

		if panel then
			TweenService:Create(
				panel,
				TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In),
				{
					Size = panel.Size - UDim2.new(0, 20, 0, 20),
					BackgroundTransparency = 1,
				}
			):Play()

			for _, descendant in ipairs(panel:GetDescendants()) do
				if descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
					TweenService:Create(
						descendant,
						TweenInfo.new(0.15),
						{
							TextTransparency = 1,
							BackgroundTransparency = math.clamp((descendant.BackgroundTransparency or 0) + 0.3, 0, 1),
						}
					):Play()
				elseif descendant:IsA("Frame") or descendant:IsA("ScrollingFrame") or descendant:IsA("ImageLabel") then
					TweenService:Create(
						descendant,
						TweenInfo.new(0.15),
						{ BackgroundTransparency = math.clamp((descendant.BackgroundTransparency or 0) + 0.3, 0, 1) }
					):Play()
				end
			end
		end

		task.delay(0.22, function()
			if popupToClose and popupToClose.Parent then
				popupToClose:Destroy()
			end
		end)
	end
end

local function makeScrollingFrame(parent)
	local scrollFrame = Instance.new("ScrollingFrame")
	scrollFrame.Parent = parent
	scrollFrame.Size = UDim2.fromScale(1, 1)
	scrollFrame.BackgroundTransparency = 1
	scrollFrame.BorderSizePixel = 0
	scrollFrame.ScrollBarThickness = 6
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scrollFrame.ScrollingDirection = Enum.ScrollingDirection.Y
	scrollFrame.Active = true
	scrollFrame.ClipsDescendants = true
	scrollFrame.ZIndex = 84
	scrollFrame.VerticalScrollBarInset = Enum.ScrollBarInset.ScrollBar

	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, 15)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent = scrollFrame

	addPadding(scrollFrame, 0, 8, 0, 8)

	return scrollFrame, layout
end

local function createStepVolumeControl(parent, labelText, initialValue, callback, layoutOrder)
	initialValue = math.clamp(math.floor(initialValue or 50), 0, 100)

	local container = createFrame({
		parent = parent,
		Size = UDim2.new(1, 0, 0, 100),
		BackgroundColor3 = Color3.fromRGB(10, 18, 28),
		BorderSizePixel = 0,
		ZIndex = 85,
		LayoutOrder = layoutOrder or 1,
	})
	roundCorners(container, 14)
	addStroke(container, Color3.fromRGB(60, 85, 120), 1, 0.35)

	createLabel({
		parent = container,
		Text = labelText,
		Size = UDim2.new(1, -20, 0, 24),
		Position = UDim2.new(0, 14, 0, 10),
		BackgroundTransparency = 1,
		TextColor3 = COLORS.TEXT_PRIMARY,
		Font = Enum.Font.GothamSemibold,
		TextSize = 15,
		TextXAlignment = Enum.TextXAlignment.Left,
		ZIndex = 86,
	})

	local controlsRow = createFrame({
		parent = container,
		Size = UDim2.new(1, -28, 0, 42),
		Position = UDim2.new(0, 14, 0, 42),
		BackgroundTransparency = 1,
		ZIndex = 85,
	})

	local minusBtn = createButton({
		parent = controlsRow,
		Text = "-",
		Size = UDim2.new(0, 42, 0, 42),
		Position = UDim2.new(0, 0, 0, 0),
		BackgroundColor3 = COLORS.DANGER,
		BorderSizePixel = 0,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		Font = Enum.Font.GothamBlack,
		TextSize = 24,
		AutoButtonColor = false,
		ZIndex = 87,
		Active = true,
		Selectable = true,
	})
	roundCorners(minusBtn, 10)

	local valueBox = createLabel({
		parent = controlsRow,
		Text = tostring(initialValue) .. "%",
		Size = UDim2.new(1, -108, 0, 42),
		Position = UDim2.new(0, 54, 0, 0),
		BackgroundColor3 = Color3.fromRGB(30, 42, 58),
		BorderSizePixel = 0,
		TextColor3 = COLORS.PRIMARY,
		Font = Enum.Font.GothamBold,
		TextSize = 18,
		TextXAlignment = Enum.TextXAlignment.Center,
		ZIndex = 86,
	})
	roundCorners(valueBox, 10)

	local plusBtn = createButton({
		parent = controlsRow,
		Text = "+",
		Size = UDim2.new(0, 42, 0, 42),
		Position = UDim2.new(1, -42, 0, 0),
		BackgroundColor3 = COLORS.SUCCESS,
		BorderSizePixel = 0,
		TextColor3 = Color3.fromRGB(255, 255, 255),
		Font = Enum.Font.GothamBlack,
		TextSize = 24,
		AutoButtonColor = false,
		ZIndex = 87,
		Active = true,
		Selectable = true,
	})
	roundCorners(plusBtn, 10)

	animateButtonHover(minusBtn, COLORS.DANGER, Color3.fromRGB(220, 38, 38))
	animateButtonHover(plusBtn, COLORS.SUCCESS, Color3.fromRGB(22, 163, 74))

	local currentValue = initialValue

	local function updateValue(newValue)
		currentValue = math.clamp(math.floor(newValue), 0, 100)
		valueBox.Text = tostring(currentValue) .. "%"

		if callback then
			callback(currentValue)
		end
	end

	minusBtn.MouseButton1Click:Connect(function()
		updateValue(currentValue - 5)
	end)

	plusBtn.MouseButton1Click:Connect(function()
		updateValue(currentValue + 5)
	end)

	return container
end

local function showPopupMessage(parent, text)
	createLabel({
		parent = parent,
		Text = text,
		Size = UDim2.fromScale(1, 1),
		BackgroundTransparency = 1,
		TextColor3 = COLORS.TEXT_PRIMARY,
		Font = Enum.Font.GothamSemibold,
		TextSize = 16,
		TextWrapped = true,
		TextYAlignment = Enum.TextYAlignment.Center,
		TextXAlignment = Enum.TextXAlignment.Center,
		ZIndex = 85,
	})
end

