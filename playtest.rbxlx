          <string name="Source"><![CDATA[-- GuardOutside (Patrol + Basic Chase + Batched Suspicion)
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local sharedRoot = ReplicatedStorage:WaitForChild("Shared")
local SuspicionManager = require(sharedRoot:WaitForChild("SuspicionManager"))

local GUARD = Workspace:WaitForChild("GuardOutside")
local RIG = GUARD:WaitForChild("Rig")
local HUMANOID = RIG:WaitForChild("Humanoid")
local HRP = RIG:WaitForChild("HumanoidRootPart")

-- === SETTINGS ===
local PATROL_SPEED = 10
local CHASE_SPEED = 16
local VISION_RANGE = 80
local VISION_ANGLE = math.cos(math.rad(60))
local CHASE_TIMEOUT = 10
local PATROL_TICK_RATE = 0.2

-- Suspicion tuning (Outside)
local SUSPICION_TICK_SEEN = 2
local SUSPICION_TICK_RATE = 0.2

-- === SUSPICION THROTTLE/BATCH ===
local SUSPICION_PUSH_INTERVAL = 0.5
local pendingSuspicion = {}

local function queueSuspicion(player, amount)
	if not player or not player.UserId then
		return
	end

	local uid = player.UserId
	pendingSuspicion[uid] = (pendingSuspicion[uid] or 0) + (amount or 0)
end

local function flushSuspicion(player)
	if not player or not player.UserId then
		return
	end

	local uid = player.UserId
	local delta = pendingSuspicion[uid] or 0
	if delta > 0 then
		SuspicionManager.Add(delta, player)
		pendingSuspicion[uid] = 0
	end
end

task.spawn(function()
	while task.wait(SUSPICION_PUSH_INTERVAL) do
		for uid, delta in pairs(pendingSuspicion) do
			if delta and delta > 0 then
				local player = Players:GetPlayerByUserId(uid)
				if player then
					SuspicionManager.Add(delta, player)
				end
				pendingSuspicion[uid] = 0
			end
		end
	end
end)

-- === WALK ANIMATION ===
local WALK_ANIM_ID = "http://www.roblox.com/asset/?id=913402848"
local Animator = HUMANOID:FindFirstChildOfClass("Animator") or Instance.new("Animator", HUMANOID)
local WalkTrack do
	local anim = Instance.new("Animation")
	anim.AnimationId = WALK_ANIM_ID
	WalkTrack = Animator:LoadAnimation(anim)
	WalkTrack.Looped = true
	WalkTrack.Priority = Enum.AnimationPriority.Movement
end

local function playWalk()
	if WalkTrack and not WalkTrack.IsPlaying then
		WalkTrack:Play()
	end
end

local function stopWalk()
	if WalkTrack and WalkTrack.IsPlaying then
		WalkTrack:Stop()
	end
end

local function setMoveSpeed(speed)
	HUMANOID.WalkSpeed = speed
	if WalkTrack then
		WalkTrack:AdjustSpeed(math.max(speed / PATROL_SPEED, 0.1))
	end
end

-- === PATROL POINTS ===
local PatrolFolder = RIG:FindFirstChild("PatrolPoints") or GUARD:FindFirstChild("PatrolPoints")
local Waypoints = {}
if PatrolFolder then
	for _, part in ipairs(PatrolFolder:GetChildren()) do
		if part:IsA("BasePart") then
			table.insert(Waypoints, part)
		end
	end
	table.sort(Waypoints, function(a, b)
		local na = tonumber(a.Name:match("%d+")) or math.huge
		local nb = tonumber(b.Name:match("%d+")) or math.huge
		return na < nb
	end)
end
local currentPoint = 1

-- === HELPERS ===
local sightParams = RaycastParams.new()
sightParams.FilterType = Enum.RaycastFilterType.Exclude
sightParams.FilterDescendantsInstances = {GUARD}

local function safeAlive(humanoid)
	return humanoid and humanoid.Health > 0 and humanoid.Parent
end

local function getCharacterState(player)
	local char = player and player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChild("Humanoid")
	if hrp and safeAlive(hum) then
		return char, hrp, hum
	end
	return char, nil, hum
end

local function canSeePlayer(playerHRP)
	if not HRP or not playerHRP then
		return false
	end

	local diff = playerHRP.Position - HRP.Position
	local dist = diff.Magnitude
	if dist > VISION_RANGE then
		return false
	end

	local dir = diff.Unit
	if HRP.CFrame.LookVector:Dot(dir) < VISION_ANGLE then
		return false
	end

	local ray = Workspace:Raycast(HRP.Position, dir * dist, sightParams)
	if not ray then
		return true
	end

	local hitModel = ray.Instance and ray.Instance:FindFirstAncestorOfClass("Model")
	return hitModel and hitModel == playerHRP.Parent
end

local function moveTo(pos)
	if not HUMANOID or not HRP or not pos then
		return false
	end

	HUMANOID:MoveTo(pos)

	local distance = (HRP.Position - pos).Magnitude
	local speed = math.max(HUMANOID.WalkSpeed, 1)
	local deadline = os.clock() + (distance / speed) + 1

	while os.clock() < deadline do
		if (HRP.Position - pos).Magnitude <= 3 then
			return true
		end
		task.wait(0.1)
	end

	return false
end

local function findNearestVisiblePlayer()
	local nearestPlayer, nearestHRP, minDist = nil, nil, VISION_RANGE + 1

	for _, player in ipairs(Players:GetPlayers()) do
		local _, hrp = getCharacterState(player)
		if hrp then
			local dist = (hrp.Position - HRP.Position).Magnitude
			if dist < minDist and canSeePlayer(hrp) then
				minDist = dist
				nearestPlayer = player
				nearestHRP = hrp
			end
		end
	end

	return nearestPlayer, nearestHRP
end

-- === MAIN BEHAVIOR ===
local function patrol()
	while task.wait(PATROL_TICK_RATE) do
		local nearestPlayer, nearestHRP = findNearestVisiblePlayer()

		if nearestPlayer and nearestHRP then
			setMoveSpeed(CHASE_SPEED)
			playWalk()
			local startTime = os.clock()

			while os.clock() - startTime < CHASE_TIMEOUT do
				local _, currentHRP, hum = getCharacterState(nearestPlayer)
				if not currentHRP or not safeAlive(hum) then
					break
				end
				if not canSeePlayer(currentHRP) then
					break
				end

				queueSuspicion(nearestPlayer, SUSPICION_TICK_SEEN)
				HUMANOID:MoveTo(currentHRP.Position)
				task.wait(SUSPICION_TICK_RATE)
			end

			flushSuspicion(nearestPlayer)
			stopWalk()
			setMoveSpeed(PATROL_SPEED)
		end

		if #Waypoints > 0 then
			local point = Waypoints[currentPoint]
			if point then
				setMoveSpeed(PATROL_SPEED)
				playWalk()
				moveTo(point.Position)
				stopWalk()
				currentPoint = (currentPoint % #Waypoints) + 1
				task.wait(1)
			end
		else
			task.wait(0.5)
		end
	end
end

task.spawn(patrol)
]]></string>
