        <Properties>
          <string name="Name">DoorScript</string>
          <token name="RunContext">0</token>
          <string name="Source"><![CDATA[local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")

-- === CONFIG ===
local DOOR_MODEL_NAME = "S.S.R. Teknikk Door"
local PANEL_MODEL_NAME = "Panel"

local LEFT_NAME = "DoorLeft"
local RIGHT_NAME = "DoorRight"

local OPEN_DISTANCE = 8.5
local TWEEN_TIME = 1
local CLOSE_DELAY = 3

-- === OBJECTS ===
local doorModel = Workspace:WaitForChild(DOOR_MODEL_NAME)
local panelModel = Workspace:WaitForChild(PANEL_MODEL_NAME)

local leftDoor = doorModel:WaitForChild(LEFT_NAME)
local rightDoor = doorModel:WaitForChild(RIGHT_NAME)
local prompt = panelModel:FindFirstChildWhichIsA("ProximityPrompt", true)

if not prompt then
	error("No ProximityPrompt found inside panel model: " .. PANEL_MODEL_NAME)
end

print("Found prompt:", prompt:GetFullName())

local function getParts(obj)
	local parts = {}

	if obj:IsA("Model") then
		if not obj.PrimaryPart then
			local primary = obj:FindFirstChildWhichIsA("BasePart", true)
			if primary then
				obj.PrimaryPart = primary
			else
				error("Model '" .. obj.Name .. "' has no BasePart")
			end
		end

		for _, d in ipairs(obj:GetDescendants()) do
			if d:IsA("BasePart") then
				table.insert(parts, d)
			end
		end
	else
		table.insert(parts, obj)
	end

	return parts
end

local function getCFrame(obj)
	if obj:IsA("Model") then
		return obj:GetPrimaryPartCFrame()
	else
		return obj.CFrame
	end
end

local function setCFrame(obj, cf)
	if obj:IsA("Model") then
		obj:SetPrimaryPartCFrame(cf)
	else
		obj.CFrame = cf
	end
end

local function setDoorPhysics(obj, anchored, canCollide)
	for _, p in ipairs(getParts(obj)) do
		p.Anchored = anchored
		p.CanCollide = canCollide
	end
end

local function tweenDoor(obj, targetCFrame)
	local proxy = Instance.new("CFrameValue")
	proxy.Value = getCFrame(obj)

	local conn = proxy:GetPropertyChangedSignal("Value"):Connect(function()
		setCFrame(obj, proxy.Value)
	end)

	local tween = TweenService:Create(
		proxy,
		TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
		{Value = targetCFrame}
	)

	tween.Completed:Connect(function()
		conn:Disconnect()
		proxy:Destroy()
	end)

	tween:Play()
	return tween
end

-- === INITIAL SETUP ===
setDoorPhysics(leftDoor, true, true)
setDoorPhysics(rightDoor, true, true)

prompt.Enabled = true
prompt.ActionText = "Open Door"
prompt.ObjectText = "Door"
prompt.HoldDuration = 0
prompt.MaxActivationDistance = 10
prompt.RequiresLineOfSight = false

local leftClosed = getCFrame(leftDoor)
local rightClosed = getCFrame(rightDoor)

local leftOpen = leftClosed * CFrame.new(-OPEN_DISTANCE, 0, 0)
local rightOpen = rightClosed * CFrame.new(OPEN_DISTANCE, 0, 0)

local isOpen = false
local isMoving = false
local closeAt = 0

local function openDoors()
	if isMoving then
		return
	end

	if isOpen then
		closeAt = tick() + CLOSE_DELAY
		print("Door already open, extending close timer")
		return
	end

	isMoving = true
	print("Opening doors")

	setDoorPhysics(leftDoor, true, false)
	setDoorPhysics(rightDoor, true, false)

	tweenDoor(leftDoor, leftOpen)
	tweenDoor(rightDoor, rightOpen)

	task.wait(TWEEN_TIME)

	isOpen = true
	isMoving = false
	closeAt = tick() + CLOSE_DELAY

	print("Doors opened, will close at", closeAt)
end

local function closeDoors()
	if isMoving or not isOpen then
		return
	end

	isMoving = true
	print("Closing doors")

	setDoorPhysics(leftDoor, true, false)
	setDoorPhysics(rightDoor, true, false)

	tweenDoor(leftDoor, leftClosed)
	tweenDoor(rightDoor, rightClosed)

	task.wait(TWEEN_TIME)

	setDoorPhysics(leftDoor, true, true)
	setDoorPhysics(rightDoor, true, true)

	isOpen = false
	isMoving = false

	print("Doors closed")
end

prompt.Triggered:Connect(function(player)
	print("Prompt triggered by:", player.Name)
	openDoors()
end)

task.spawn(function()
	while true do
		if isOpen and not isMoving and closeAt > 0 and tick() >= closeAt then
			closeDoors()
		end

		task.wait(0.1)
	end
end)
]]></string>
